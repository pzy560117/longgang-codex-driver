{
  "name": "export-platform-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "kysely": "^0.27.4",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "worker:scheduler": "tsx src/workers/scheduler-worker.ts",
    "job:cleanup": "tsx src/jobs/cleanup-job.ts",
    "arch:check": "tsx scripts/arch-check.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.mjs tests/contract/*.test.mjs",
    "test:contract": "node --test tests/contract/*.test.mjs",
    "test:api": "node scripts/planned-test.mjs api",
    "test:db": "node scripts/planned-test.mjs db",
    "test:worker": "node scripts/planned-test.mjs worker",
    "test:query": "node scripts/planned-test.mjs query",
    "test:file": "node scripts/planned-test.mjs file",
    "test:sample": "node scripts/planned-test.mjs sample"
  }
}
