+};
+
+export type ExportRegistryRecord = {
+  taskCode: string;
+  subsystemCode: string;
+  displayName: string;
+  enabled: boolean;
+  concurrencyLimit: number;
+  fileRetentionDays: number;
+  taskHistoryRetentionDays: number;
