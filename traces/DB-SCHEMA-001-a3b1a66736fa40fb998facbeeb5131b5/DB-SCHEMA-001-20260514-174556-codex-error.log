+export type FileMetadataRecord = Omit<SaveFileMetadataInput, "now">;
+
+function toFileMetadataRecord(row: {
+  task_id: string;
+  attempt_no: number;
+  file_name: string;
+  content_type: string;
+  file_size: number;
+  checksum: string;
+  checksum_algorithm: string;
