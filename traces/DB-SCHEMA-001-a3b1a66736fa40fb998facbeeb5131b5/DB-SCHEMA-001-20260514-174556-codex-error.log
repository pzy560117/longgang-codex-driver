diff --git a/src/db/migrator.ts b/src/db/migrator.ts
new file mode 100644
index 0000000000000000000000000000000000000000..544d2aa61c901110ceb9aa4ee97e01ba0d49d00a
--- /dev/null
+++ b/src/db/migrator.ts
@@ -0,0 +1,30 @@
+import { FileMigrationProvider, Migrator, type Kysely } from "kysely";
+import { promises as fs } from "node:fs";
+import path from "node:path";
+import { fileURLToPath } from "node:url";
+import type { ExportPlatformDatabase } from "./schema.ts";
+
+const root = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..", "..");
+
+export async function runMigrations(db: Kysely<ExportPlatformDatabase>): Promise<void> {
+  const migrator = new Migrator({
+    db,
+    provider: new FileMigrationProvider({
+      fs,
+      path,
+      migrationFolder: path.join(root, "migrations")
+    })
+  });
+
+  const { error, results } = await migrator.migrateToLatest();
+
+  if (error) {
+    throw error;
+  }
+
+  for (const result of results ?? []) {
+    if (result.status === "Error") {
+      throw new Error(`Migration ${result.migrationName} failed`);
+    }
+  }
+}
