diff --git a/src/repositories/database-time.repository.ts b/src/repositories/database-time.repository.ts
new file mode 100644
index 0000000000000000000000000000000000000000..25ebf0e17df6ef388e30c586826829cf013c280a
--- /dev/null
+++ b/src/repositories/database-time.repository.ts
@@ -0,0 +1,14 @@
+import { sql, type Kysely } from "kysely";
+import type { ExportPlatformDatabase } from "../db/schema.ts";
+
+export async function getDatabaseTime(db: Kysely<ExportPlatformDatabase>): Promise<Date> {
+  const row = await sql<{ database_time: Date }>`SELECT CURRENT_TIMESTAMP(3) AS database_time`
+    .execute(db)
+    .then((result) => result.rows[0]);
+
+  if (!row?.database_time) {
+    throw new Error("Database time query returned no rows");
+  }
+
+  return new Date(row.database_time);
+}
diff --git a/src/repositories/export-audit.repository.ts b/src/repositories/export-audit.repository.ts
