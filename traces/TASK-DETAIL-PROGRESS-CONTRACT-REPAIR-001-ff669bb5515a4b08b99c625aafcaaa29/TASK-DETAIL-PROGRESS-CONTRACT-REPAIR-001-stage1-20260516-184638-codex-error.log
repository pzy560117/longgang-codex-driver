            - QUERY_BATCH_DONE
            - FILE_PART_WRITTEN
            - PACKAGE_DONE
            - FILE_VERIFIED
            - DELIVERY_READY
        requestId:
          type: string
        datasourceCode:
          type: string
        queryTemplateVersion:
          type: string
        batchCheckpoint:
          $ref: "#/components/schemas/BatchCheckpoint"
        occurredAt:
          type: string
          format: date-time

