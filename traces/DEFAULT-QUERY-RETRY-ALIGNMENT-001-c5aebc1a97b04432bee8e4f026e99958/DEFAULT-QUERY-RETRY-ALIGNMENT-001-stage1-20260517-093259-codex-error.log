800:function resolveTaskConcurrencyLimit(task: ExportTaskRecord): number {
801:  const registry = resolveTaskRegistrySnapshot(task);
802:  return Number.isInteger(registry?.concurrencyLimit) && Number(registry?.concurrencyLimit) > 0
803:    ? Number(registry?.concurrencyLimit)
804:    : 1;
805:}
