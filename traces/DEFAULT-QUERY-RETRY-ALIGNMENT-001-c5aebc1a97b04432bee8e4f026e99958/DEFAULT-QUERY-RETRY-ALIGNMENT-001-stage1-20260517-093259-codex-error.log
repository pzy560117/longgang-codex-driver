130:async function queryDatabaseTime(db: Kysely<ExportPlatformDatabase>): Promise<Date> {
131:  const row = await sql<{ database_time: Date }>`SELECT CURRENT_TIMESTAMP(3) AS database_time`
132:    .execute(db)
133:    .then((result) => result.rows[0]);
134:
135:  if (!row?.database_time) {
136:    throw new Error("Database time query returned no rows");
137:  }
138:
139:  return new Date(row.database_time);
