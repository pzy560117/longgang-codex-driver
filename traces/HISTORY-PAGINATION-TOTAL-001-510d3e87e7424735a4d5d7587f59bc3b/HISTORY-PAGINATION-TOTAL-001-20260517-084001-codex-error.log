  const concurrentResponses = [concurrentFirstResponse, concurrentSecondResponse];
  assert.deepEqual(
    concurrentResponses.map((response) => response.statusCode).sort(),
    [201, 409]
  );
  assert.equal(
    concurrentResponses.find((response) => response.statusCode === 409).json().code,
