        - fieldMappings
        - maskingPolicy
        - dataScopeTemplate
        - cursorField
        - orderBy
        - batchSize
      properties:
        taskCode:
          type: string
        subsystemCode:
          type: string
        displayName:
          type: string
        enabled:
          type: boolean
        concurrencyLimit:
          type: integer
          minimum: 1
        fileRetentionDays:
          type: integer
          minimum: 1
          default: 15
        taskHistoryRetentionDays:
          type: integer
          minimum: 1
          default: 30
        singleFileMaxRows:
          type: integer
          minimum: 1
          default: 20000
        exportMaxRows:
          type: integer
          minimum: 1
          default: 100000
        supportedFormats:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FileFormat"
        datasourceCode:
          type: string
          description: Must reference a registered read-only datasource or data platform dataset.
        parameterSchema:
          type: object
          additionalProperties: true
        queryTemplate:
          $ref: "#/components/schemas/QueryTemplateContract"
        fieldMappings:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FieldMapping"
        maskingPolicy:
          type: object
          additionalProperties: true
          description: Required masking policy. Any fieldMappings item with sensitive=true must reference a maskingRuleCode covered by this policy.
        dataScopeTemplate:
          type: string
          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.
        cursorField:
          type: string
        orderBy:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/OrderBy"
        batchSize:
          type: integer
          minimum: 1
    ExportRegistryEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportRegistry"
