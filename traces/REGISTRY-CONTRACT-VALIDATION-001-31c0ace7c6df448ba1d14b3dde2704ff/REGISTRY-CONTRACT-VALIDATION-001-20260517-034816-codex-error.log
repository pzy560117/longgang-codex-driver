function resolveDownloadMode(mode: string | undefined): DownloadDeliveryMode {
  if (!mode || mode === "SIGNED_URL") {
    return "SIGNED_URL";
  }
  if (mode === "STREAM") {
    return "STREAM";
  }

  throw new ApiError(400, "VALIDATION_ERROR", "mode must be SIGNED_URL or STREAM", {
    mode
  });
}

