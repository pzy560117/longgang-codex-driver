}

function parseOrderBy(value: string | null, cursorField: string): Array<{
  field: string;
  direction: "ASC" | "DESC";
}> {
  if (!value) {
    return [{ field: cursorField, direction: "ASC" }];
  }
  let orderBy: Array<{ field?: string; direction?: string }>;
