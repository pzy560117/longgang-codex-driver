366:       normalized.maskingRuleCode = requireOptionalString(
367:         `fieldMappings[${index}].maskingRuleCode`,
368:         mapping.maskingRuleCode,
369:         "FIELD_MAPPING_INVALID"
370:       );
371:     }
372: 
373:     return normalized;
374:   });
375: }
376: 
377: function requireOrderBy(value: unknown): ValidatedOrderBy[] {
378:   if (!Array.isArray(value) || value.length === 0) {
379:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "orderBy is required");
380:   }
381: 
382:   return value.map((item, index) => {
383:     const orderBy = requireObjectWithKeys(
384:       `orderBy[${index}]`,
385:       item,
386:       ORDER_BY_REQUIRED_FIELDS,
387:       "QUERY_TEMPLATE_INVALID"
388:     );
389:     const direction = requireNestedString(
390:       `orderBy[${index}].direction`,
391:       orderBy.direction,
392:       "QUERY_TEMPLATE_INVALID"
393:     ).toUpperCase();
394:     if (!ORDER_DIRECTIONS.has(direction)) {
395:       throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `orderBy[${index}].direction is invalid`);
396:     }
397: 
398:     return {
399:       field: requireNestedString(
400:         `orderBy[${index}].field`,
401:         orderBy.field,
402:         "QUERY_TEMPLATE_INVALID"
403:       ),
404:       direction: direction as "ASC" | "DESC"
405:     };
406:   });
407: }
408: 
409: function requireObjectWithKeys<T extends readonly string[]>(
410:   label: string,
411:   value: unknown,
412:   requiredKeys: T,
413:   code: string
414: ): Record<string, unknown> {
415:   if (!value || typeof value !== "object" || Array.isArray(value)) {
416:     throw new ApiError(400, code, `${label} is required`);
417:   }
418:   const record = value as Record<string, unknown>;
419:   for (const key of requiredKeys) {
420:     if (!Object.hasOwn(record, key) || record[key] === null) {
421:       throw new ApiError(400, code, `${label}.${key} is required`);
422:     }
423:   }
424:   return record;
425: }
426: 
427: function requireStringArray(label: string, value: unknown, code: string): string[] {
428:   if (!Array.isArray(value)) {
429:     throw new ApiError(400, code, `${label} is required`);
430:   }
431:   return value.map((item, index) =>
432:     requireNestedString(`${label}[${index}]`, item, code)
433:   );
434: }
435: 
436: function requireNestedString(label: string, value: unknown, code: string): string {
437:   if (typeof value !== "string" || value.trim() === "") {
438:     throw new ApiError(400, code, `${label} is required`);
439:   }
440:   return value;
441: }
442: 
443: function requireOptionalString(label: string, value: unknown, code: string): string {
444:   if (typeof value !== "string" || value.trim() === "") {
445:     throw new ApiError(400, code, `${label} must be a non-empty string`);
446:   }
447:   return value;
448: }
449: 
450: function requireNestedPositiveInteger(label: string, value: unknown, code: string): number {
451:   if (!Number.isInteger(value) || Number(value) < 1) {
452:     throw new ApiError(400, code, `${label} must be >= 1`);
453:   }
454:   return Number(value);
455: }
456: 
457: function requireNestedBoolean(label: string, value: unknown, code: string): boolean {
458:   if (typeof value !== "boolean") {
459:     throw new ApiError(400, code, `${label} is required`);
460:   }
461:   return value;
462: }

