30: function isDuplicateKeyError(error: unknown): boolean {
31:   let current: unknown = error;
32:   while (current && typeof current === "object") {
33:     const candidate = current as { code?: unknown; errno?: unknown; cause?: unknown };
34:     if (candidate.code === "ER_DUP_ENTRY" || candidate.errno === 1062) {
35:       return true;
36:     }
37:     current = candidate.cause;
38:   }
