info:
  title: Export Platform API Contract
  version: 1.0.0
  license:
    name: Internal
    url: https://example.invalid/internal-license
  description: |
    CONTRACT-001 defines the public API contract for FEAT-EXPORT-PLATFORM-001.
    The API consumes authentication context from upstream services and exposes
    only official task statuses: PENDING, EXECUTING, COMPLETED, FAILED,
    CANCELED, EXPIRED.
servers:
  - url: /api
    description: Relative platform API base path
tags:
  - name: ExportTasks
    description: Task creation, detail, history, download, cancel and retry APIs.
  - name: ExportRegistries
    description: Export task registry, enable/disable and configuration APIs.
security:
  - OperatorId: []
    TenantId: []
    RoleCodes: []
    OrgScope: []
    RequestId: []
x-contract-implementation-trace:
  description: |
    CONTRACT-REVIEW-001 requires every public operation to stay traceable to
    later HTTP handler, persistence, worker, audit, file and test obligations.
    Paths below are the current TASK-API-HTTP-001 implementation evidence.
  operations:
    createExportTask:
      http: POST /api/export/tasks
      requirements: [FR-001, FR-009, FR-013]
      acceptanceExamples: [AE-001, AE-009, AE-014]
      handler: src/routes/export/tasks/create-export-task.handler.ts
      service: src/task-api/service.ts
      repository: [src/repositories/export-task.repository.ts, src/repositories/export-registry.repository.ts, src/repositories/export-audit.repository.ts]
      adapter: [src/audit-log/auth-context.ts]
      db: [export_tasks, export_task_idempotency, export_registries, export_audit_logs]
      worker: [src/workers/scheduler-worker.ts must consume committed PENDING task with idempotency and snapshot invariants]
      audit: [CREATE]
      file: [none]
      tests:
        - tests/contract/openapi-route-mapping.contract.test.mjs
