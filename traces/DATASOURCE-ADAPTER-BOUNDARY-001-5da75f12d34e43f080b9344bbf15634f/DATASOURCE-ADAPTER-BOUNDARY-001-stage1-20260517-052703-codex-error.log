 792: function resolveTaskRegistrySnapshot(task: ExportTaskRecord): ExportRegistryRecord | undefined {
 793:   const snapshot = parseTaskRequestSnapshot(task).configSnapshot;
 794:   if (snapshot?.configSnapshotDigest === task.configSnapshotDigest) {
 795:     return snapshot;
 796:   }
 797:   return undefined;
 798: }
