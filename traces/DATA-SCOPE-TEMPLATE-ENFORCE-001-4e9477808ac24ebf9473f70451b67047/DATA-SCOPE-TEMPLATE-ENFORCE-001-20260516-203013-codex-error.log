+        tenant_id: "tenant-001",
+        org_id: "ORG-001",
+        order_no: "PO-2026-005",
+        order_status: "APPROVED",
+        supplier_id: "SUP-001",
+        purchase_org_id: "PO-001",
+        owner_operator_id: "u001",
+        allowed_role_code: "EXPORT_ADMIN",
