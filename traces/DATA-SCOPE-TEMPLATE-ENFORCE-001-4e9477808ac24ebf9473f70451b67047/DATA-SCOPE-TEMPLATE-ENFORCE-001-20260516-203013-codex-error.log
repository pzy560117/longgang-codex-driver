        purchaseOrgId: "PO-001",
        keyword: "PO-2026"
      },
      configSnapshot: snapshot
    }
  });

  await seedRegistry(db, {
    taskCode,
    subsystemCode,
    runId: "snapshot-v2",
    configSnapshotDigest: "sha256:config-v2",
    fieldMappings: [
      {
