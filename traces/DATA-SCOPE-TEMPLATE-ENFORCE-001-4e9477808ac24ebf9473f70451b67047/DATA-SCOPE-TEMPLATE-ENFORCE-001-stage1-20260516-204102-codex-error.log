350:function parseOrderBy(value: string | null, cursorField: string): Array<{
351:  field: string;
352:  direction: "ASC" | "DESC";
353:}> {
354:  if (!value) {
355:    return [{ field: cursorField, direction: "ASC" }];
356:  }
357:  let orderBy: Array<{ field?: string; direction?: string }>;
358:  try {
359:    orderBy = JSON.parse(value) as Array<{ field?: string; direction?: string }>;
360:  } catch {
361:    throw queryError("QUERY_TEMPLATE_INVALID", "orderBy must be valid JSON");
362:  }
363:  if (!Array.isArray(orderBy) || orderBy.length === 0) {
364:    return [{ field: cursorField, direction: "ASC" }];
365:  }
366:  const normalized: OrderByDefinition[] = orderBy.map((item) => ({
367:    field: requireText(item.field, "QUERY_TEMPLATE_INVALID"),
368:    direction: item.direction?.toUpperCase() === "DESC" ? "DESC" : "ASC"
369:  }));
370:  if (!normalized.some((item) => item.field === cursorField)) {
371:    normalized.push({ field: cursorField, direction: "ASC" });
372:  }
373:  return dedupeOrderBy(normalized);
374:}
