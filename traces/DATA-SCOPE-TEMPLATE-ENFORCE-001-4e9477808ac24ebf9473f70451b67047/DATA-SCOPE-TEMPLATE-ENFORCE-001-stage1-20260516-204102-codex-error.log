340:function parseFieldMappings(value: string | null): FieldMapping[] {
341:  const mappings = parseJson<FieldMapping[]>(value, "FIELD_MAPPING_INVALID");
342:  if (!Array.isArray(mappings) || mappings.length === 0) {
343:    throw queryError("FIELD_MAPPING_INVALID", "field mappings are required");
344:  }
345:  return mappings
