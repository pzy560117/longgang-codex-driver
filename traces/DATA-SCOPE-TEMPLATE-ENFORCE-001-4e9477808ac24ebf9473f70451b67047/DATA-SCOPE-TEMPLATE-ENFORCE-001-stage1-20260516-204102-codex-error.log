323:function validateTemplate(template: QueryTemplate): void {
324:  const normalized = template.templateText.trim();
325:  if (!/^select\b/i.test(normalized)) {
326:    throw queryError("QUERY_TEMPLATE_INVALID", "query template must be a SELECT statement");
327:  }
328:  if (normalized.includes(";") || unsafeKeywordPattern.test(normalized)) {
329:    throw queryError("QUERY_TEMPLATE_INVALID", "query template contains unsafe SQL");
330:  }
331:
332:  const allowed = new Set(template.allowedParameters ?? []);
333:  for (const placeholder of extractPlaceholders(normalized)) {
334:    if (!allowed.has(placeholder) && !["tenantId", "orgScope"].includes(placeholder)) {
335:      throw queryError("QUERY_TEMPLATE_INVALID", `placeholder ${placeholder} is not declared`);
336:    }
337:  }
338:}
