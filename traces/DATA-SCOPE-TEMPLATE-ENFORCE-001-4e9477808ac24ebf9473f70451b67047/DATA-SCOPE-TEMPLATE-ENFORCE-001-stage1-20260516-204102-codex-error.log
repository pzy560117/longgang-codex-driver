397:function compileDataScopeTemplate(value: string | null, scope: DataScope): CompiledDataScope {
398:  const template = requireText(value, "QUERY_TEMPLATE_INVALID").trim();
399:  if (template.includes(";") || unsafeKeywordPattern.test(template)) {
400:    throw queryError("QUERY_TEMPLATE_INVALID", "dataScopeTemplate contains unsafe SQL");
401:  }
402:  const values: unknown[] = [];
403:  const sql = template.replace(placeholderPattern, (_match, name: string) => {
404:    if (name === "tenantId") {
405:      values.push(scope.tenantId);
406:      return "?";
407:    }
408:    if (name === "operatorId") {
409:      values.push(scope.operatorId);
410:      return "?";
411:    }
412:    if (name === "roleCodes") {
413:      values.push(...scope.roleCodes);
414:      return parameterList(scope.roleCodes.length);
415:    }
416:    if (name === "orgScope") {
417:      values.push(...scope.orgScope);
418:      return parameterList(scope.orgScope.length);
419:    }
420:    throw queryError(
421:      "QUERY_TEMPLATE_INVALID",
422:      `dataScopeTemplate placeholder ${name} is not allowed`
423:    );
424:  });
425:
426:  return {
427:    sql,
428:    values,
429:    scope,
430:    expression: {
431:      template,
432:      operatorId: scope.operatorId,
433:      roleCodes: scope.roleCodes,
434:      orgScope: scope.orgScope
435:    }
436:  };
437:}
