        errorCode: failedEvent.errorCode,
        errorMessage:
          typeof failedEvent.errorMessage === "string"
            ? failedEvent.errorMessage
            : responseCodeMessage(failedEvent.errorCode)
      };
    }

    return {
      errorCode: null,
      errorMessage: null
    };
  }

