20: 
21: function toAuditLogRecord(row: {
22:   audit_id: string;
23:   task_id: string | null;
24:   attempt_no: number | null;
25:   task_code: string | null;
26:   subsystem_code: string | null;
27:   operator_id: string;
28:   action: string;
29:   result: string;
30:   error_code: string;
31:   request_id: string;
32:   occurred_at: Date;
33: }): AuditLogRecord {
34:   return {
35:     auditId: row.audit_id,
36:     taskId: row.task_id,
37:     attemptNo: row.attempt_no,
38:     taskCode: row.task_code,
39:     subsystemCode: row.subsystem_code,
40:     operatorId: row.operator_id,
41:     action: row.action,
42:     result: row.result,
43:     errorCode: row.error_code,
44:     requestId: row.request_id,
45:     occurredAt: row.occurred_at
46:   };
47: }
48: 
49: export function createExportAuditRepository(db: Kysely<ExportPlatformDatabase>) {
50:   return {
51:     async appendAuditLog(input: AppendAuditLogInput): Promise<void> {
52:       await db
53:         .insertInto("export_audit_logs")
54:         .values({
55:           audit_id: input.auditId,
56:           task_id: input.taskId,
57:           attempt_no: input.attemptNo,
58:           task_code: input.taskCode,
59:           subsystem_code: input.subsystemCode,
60:           operator_id: input.operatorId,
61:           action: input.action,
62:           result: input.result,
63:           error_code: input.errorCode,
64:           request_id: input.requestId,
65:           occurred_at: input.occurredAt,
66:           created_at: input.now
67:         })
68:         .execute();
69:     },
70: 
71:     async listAuditLogsForTask(taskId: string): Promise<AuditLogRecord[]> {
72:       const rows = await db
73:         .selectFrom("export_audit_logs")
74:         .selectAll()
75:         .where("task_id", "=", taskId)
76:         .orderBy("occurred_at", "asc")
77:         .execute();
78: 
79:       return rows.map(toAuditLogRecord);
80:     }
81:   };
82: }

