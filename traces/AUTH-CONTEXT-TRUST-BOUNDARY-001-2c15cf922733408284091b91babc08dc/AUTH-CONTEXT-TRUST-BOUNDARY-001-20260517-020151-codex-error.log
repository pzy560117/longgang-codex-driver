+      input.tenantId,
+      input.roleCodes,
+      input.orgScope,
+      input.requestId
+    ].join("\n"))
+    .digest("hex");
+}
+
+function assertValidSignature(value: string, expected: string): void {
+  const signature = Buffer.from(value, "hex");
+  const expectedSignature = Buffer.from(expected, "hex");
