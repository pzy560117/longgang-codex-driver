+  if (!value) {
+    throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
+  }
+  return value;
+}
+
+function requireAuthContextSigningSecret(): string {
+  const secret = process.env.EXPORT_PLATFORM_AUTH_CONTEXT_SIGNING_SECRET;
+  if (!secret) {
+    throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
+  }
+  return secret;
+}
