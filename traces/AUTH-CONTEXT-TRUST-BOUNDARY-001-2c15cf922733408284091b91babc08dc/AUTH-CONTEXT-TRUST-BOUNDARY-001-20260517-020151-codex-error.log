+  delete unsignedAdminHeaders["x-auth-context-signature"];
+  const unsignedRegistryResponse = await app.inject({
+    method: "POST",
+    url: "/api/export/registries",
+    headers: unsignedAdminHeaders,
+    payload: createRegistryPayload(taskCode)
+  });
+
