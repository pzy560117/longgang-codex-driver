import type { FastifyReply } from "fastify";
import { randomUUID } from "node:crypto";
import { appendAudit } from "../audit-log/service.ts";
import { ApiError, type AuthContext } from "../audit-log/auth-context.ts";
import { createDatabase } from "../db/kysely.ts";
import { sendJson } from "../http/types.ts";
import { getDatabaseTime } from "../repositories/index.ts";

export function sendSuccess(response: FastifyReply, statusCode: number, data: unknown): void {
  sendJson(response, statusCode, {
    code: "SUCCESS",
    message: "success",
    data
  });
}
function readHeader(response: FastifyReply, name: string): string | undefined {
  const value = response.request.headers[name.toLowerCase()];
  return Array.isArray(value) ? value[0] : value;
}

function authContextFromUntrustedHeaders(response: FastifyReply): AuthContext | null {
  const requestId = readHeader(response, "x-request-id")?.trim();
  if (!requestId) {
    return null;
  }

  return {
    operatorId: readHeader(response, "x-operator-id")?.trim() || "unverified-auth-context",
    tenantId: readHeader(response, "x-tenant-id")?.trim() || "",
    roleCodes: [],
    orgScope: readHeader(response, "x-org-scope")?.trim() || "",
    requestId
  };
}

function authFailureAuditTarget(response: FastifyReply): {
  action: string;
  taskId: string | null;
  taskCode: string | null;
} {
  const method = response.request.method;
  const pathname = response.request.url.split("?")[0];
  const segments = pathname.split("/").filter(Boolean);

  if (method === "POST" && pathname === "/api/export/registries") {
    return { action: "REGISTRY_CREATE", taskId: null, taskCode: null };
  }
  if (method === "GET" && segments[0] === "api" && segments[1] === "export" && segments[2] === "registries") {
    return { action: "REGISTRY_DETAIL", taskId: null, taskCode: segments[3] ?? null };
  }
  if (method === "GET" && pathname === "/api/export/tasks") {
    return { action: "QUERY_HISTORY", taskId: null, taskCode: null };
  }
  if (method === "GET" && segments[0] === "api" && segments[1] === "export" && segments[2] === "tasks" && segments[4] === "download") {
    return { action: "DOWNLOAD", taskId: segments[3] ?? null, taskCode: null };
  }
  if (method === "GET" && segments[0] === "api" && segments[1] === "export" && segments[2] === "tasks") {
    return { action: "DETAIL_VIEW", taskId: segments[3] ?? null, taskCode: null };
  }

  return { action: "CREATE", taskId: null, taskCode: null };
}

async function appendAuthContextFailureAudit(response: FastifyReply, error: ApiError): Promise<void> {
  const auth = authContextFromUntrustedHeaders(response);
  if (!auth) {
    return;
  }

  const db = createDatabase();
  try {
    const now = await getDatabaseTime(db);
    const target = authFailureAuditTarget(response);
    await appendAudit({
      db,
      auth: {
        ...auth,
        requestId: auth.requestId || `auth-context-missing-${randomUUID()}`
      },
      taskId: target.taskId,
      attemptNo: null,
      taskCode: target.taskCode,
      subsystemCode: null,
      action: target.action,
      result: "FAILED",
      errorCode: error.code,
      now
    });
  } catch {
    return;
  } finally {
    await db.destroy();
  }
}

export async function sendError(response: FastifyReply, error: unknown): Promise<void> {
  if (error instanceof ApiError) {
    if (error.code === "AUTH_CONTEXT_MISSING") {
      await appendAuthContextFailureAudit(response, error);
    }
    sendJson(response, error.statusCode, {
      code: error.code,
      message: error.message,
      data: error.data
    });
    return;
  }

  sendJson(response, 500, {
    code: "INTERNAL_ERROR",
    message: error instanceof Error ? error.message : "internal error",
    data: null
  });
}


