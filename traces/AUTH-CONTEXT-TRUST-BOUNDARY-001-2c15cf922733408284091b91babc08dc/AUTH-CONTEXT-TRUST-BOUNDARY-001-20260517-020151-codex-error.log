+    operatorId: "attacker",
+    tenantId: "tenant-999",
+    roleCodes: "EXPORT_ADMIN"
+  });
+  forgedAdminHeaders["x-auth-context-signature"] = signAuthContextHeaders({
+    ...forgedAdminHeaders,
