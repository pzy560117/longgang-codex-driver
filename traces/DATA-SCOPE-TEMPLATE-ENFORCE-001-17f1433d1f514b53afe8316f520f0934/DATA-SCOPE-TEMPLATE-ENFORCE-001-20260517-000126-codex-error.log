  assert.ok(audits.some((audit) => audit.action === "EXPIRE_MARK" && audit.result === "SUCCESS"));
  assert.ok(events.some((event) => event.eventType === "FILE_CLEANUP_DONE"));
  assert.equal(task.taskCode, taskCode);
});

