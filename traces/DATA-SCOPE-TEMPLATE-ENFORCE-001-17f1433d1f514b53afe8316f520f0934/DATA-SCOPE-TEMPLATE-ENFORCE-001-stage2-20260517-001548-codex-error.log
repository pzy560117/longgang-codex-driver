 376: function buildDataScope(auth: AuthSnapshot): DataScope {
 377:   const tenantId = requireText(auth.tenantId, "PERMISSION_DENIED");
 378:   const operatorId = requireText(auth.operatorId, "PERMISSION_DENIED");
 379:   const roleCodes = Array.isArray(auth.roleCodes)
 380:     ? auth.roleCodes.map((item) => requireText(item, "PERMISSION_DENIED"))
 381:     : [];
 382:   const orgScope = Array.isArray(auth.orgScope)
 383:     ? auth.orgScope
 384:     : typeof auth.orgScope === "string"
 385:       ? auth.orgScope.split(",").map((item) => item.trim()).filter(Boolean)
 386:       : [];
 387: 
 388:   if (roleCodes.length === 0) {
 389:     throw queryError("PERMISSION_DENIED", "auth roleCodes is required");
 390:   }
 391:   if (orgScope.length === 0) {
