    },
    {
      "id": "QUERY-TEMPLATE-HARDENING-001",
      "severity": "P1",
      "title": "registry-time query template semantic governance remains weak",
      "requirementIds": ["FR-008", "AC-008", "AC-E011"],
      "evidence": [
        "src/registry-config/contract.ts",
        "src/query-executor/index.ts",
        "tests/query/query-executor.test.mjs"
      ],
      "risk": "Registry-time validation checks query template structure but leaves SELECT, unsafe keyword and placeholder semantic checks to execution-time validation.",
