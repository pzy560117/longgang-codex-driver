      "id": "CREATE-TASK-LATENCY-EVIDENCE-001",
      "severity": "P1",
      "title": "create task one-second response SLA lacks explicit evidence",
      "requirementIds": ["FR-001", "AC-001"],
      "evidence": [
        "docs/product/acceptance-criteria.md",
        "docs/testing/ACCEPTANCE_EXAMPLES.md",
        "tests/api/export-http-api.test.mjs",
        "docs/testing/verify-matrix.md"
      ],
      "risk": "The product requires create task to return within one second, but there is no stable latency assertion or release gate sample.",
      "suggestedNextTaskId": "CREATE-TASK-LATENCY-EVIDENCE-001"
    },
    {
      "id": "HISTORY-PAGINATION-TOTAL-001",
      "severity": "P1",
      "title": "task history total reflects page size instead of filtered total",
      "requirementIds": ["FR-004", "AC-004"],
      "evidence": [
        "src/task-api/service.ts",
        "src/repositories/export-task.repository.ts",
        "tests/api/export-http-api.test.mjs"
      ],
      "risk": "Clients cannot reliably calculate total pages because the API total is based on the current page item count.",
      "suggestedNextTaskId": "HISTORY-PAGINATION-TOTAL-001"
    },
    {
      "id": "TASK-CANCEL-ATOMICITY-001",
      "severity": "P1",
      "title": "cancel status update lacks state and attempt compare-and-set",
      "requirementIds": ["FR-012", "AC-012", "AC-E015"],
      "evidence": [
        "src/task-api/service.ts",
        "src/repositories/export-task.repository.ts",
        "tests/api/export-http-api.test.mjs"
      ],
      "risk": "A worker transition between read and update can be overwritten by cancel, corrupting task state and audit consistency.",
      "suggestedNextTaskId": "TASK-CANCEL-ATOMICITY-001"
    },
    {
      "id": "DEFAULT-QUERY-RETRY-ALIGNMENT-001",
      "severity": "P1",
      "title": "scheduler default query retry count drifts from product default",
      "requirementIds": ["FR-006", "FR-010", "AC-020", "AC-E004", "AC-E020"],
      "evidence": [
        "docs/product/state-matrix.yaml",
        "src/scheduler/worker.ts",
        "tests/worker/scheduler-worker.test.mjs"
      ],
      "risk": "The product default is three query batch retries, while the scheduler default is two; transient query failures may enter FAILED earlier than expected.",
      "suggestedNextTaskId": "DEFAULT-QUERY-RETRY-ALIGNMENT-001"
    },
    {
      "id": "SAMPLE-CONTRACT-GENERIC-VALIDATION-001",
      "severity": "P1",
      "title": "purchase-order sample validation is coupled into the generic query executor",
      "requirementIds": ["FR-014", "AC-017", "AC-018"],
      "evidence": [
        "docs/architecture/constraints.md",
        "src/query-executor/index.ts",
        "src/sample-purchase-order/index.ts",
        "tests/sample/purchase-order-sample.test.mjs"
