1: import type { FastifyInstance, FastifyReply } from "fastify";
2: import { sendJson } from "../http/types.ts";
3: import { OPENAPI_OPERATION_ROUTES, type OperationRoute } from "./route-manifest.ts";
4: 
5: type RouteMatch = {
6:   route: OperationRoute;
7:   params: Record<string, string>;
8: };
9: 
10: function matchPath(pattern: string, actualPath: string): Record<string, string> | undefined {
11:   const patternSegments = pattern.split("/").filter(Boolean);
12:   const actualSegments = actualPath.split("/").filter(Boolean);
13: 
14:   if (patternSegments.length !== actualSegments.length) {
15:     return undefined;
16:   }
17: 
18:   const params: Record<string, string> = {};
19:   for (let index = 0; index < patternSegments.length; index += 1) {
20:     const patternSegment = patternSegments[index];
21:     const actualSegment = actualSegments[index];
22:     const paramMatch = patternSegment.match(/^\{([^}]+)\}$/);
23: 
24:     if (paramMatch) {
25:       params[paramMatch[1]] = decodeURIComponent(actualSegment);
26:       continue;
27:     }
28: 
29:     if (patternSegment !== actualSegment) {
30:       return undefined;
31:     }
32:   }
33: 
34:   return params;
35: }
36: 
37: function findRoute(method: string, pathname: string): RouteMatch | undefined {
38:   for (const route of OPENAPI_OPERATION_ROUTES) {
39:     if (route.method !== method) {
40:       continue;
41:     }
42: 
43:     const params = matchPath(route.path, pathname);
44:     if (params) {
45:       return { route, params };
46:     }
47:   }
48: 
49:   return undefined;
50: }
51: 
52: export async function handleApiRoute(
53:   method: string,
54:   pathname: string,
55:   response: FastifyReply
56: ): Promise<boolean> {
57:   const routeMatch = findRoute(method, pathname);
58: 
59:   if (!routeMatch) {
60:     return false;
61:   }
62: 
63:   routeMatch.route.handler(
64:     { params: routeMatch.params, request: response.request },
65:     response
66:   );
67:   return true;
68: }
69: 
70: export function sendNotFound(response: FastifyReply): void {
71:   sendJson(response, 404, {
72:     code: "TASK_NOT_FOUND",
73:     message: "route not found",
74:     data: null
75:   });
76: }
77: 
78: export function registerRoutes(app: FastifyInstance): void {
79:   for (const route of OPENAPI_OPERATION_ROUTES) {
80:     const fastifyPath = route.path.replace(/\{([^}]+)\}/g, ":$1");
81:     app.route({
82:       method: route.method,
83:       url: fastifyPath,
84:       handler: async (request, response) => {
85:         await route.handler({ params: request.params as Record<string, string>, request }, response);
86:       }
87:     });
88:   }
89: }

