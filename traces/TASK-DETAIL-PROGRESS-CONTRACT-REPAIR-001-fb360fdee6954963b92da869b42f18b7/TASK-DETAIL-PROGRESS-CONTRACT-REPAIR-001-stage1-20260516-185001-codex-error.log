225: function resolveTaskFailure(
226:   audits: AuditLogRecord[],
227:   events: TaskEventRecord[]
228: ): {
229:   errorCode: string | null;
230:   errorMessage: string | null;
231: } {
232:   const auditFailures = audits
233:     .filter((audit) => audit.result === "FAILED" && audit.errorCode !== "SUCCESS")
234:     .map((audit) => ({
235:       occurredAt: audit.occurredAt,
236:       errorCode: normalizePublicResponseCode(audit.errorCode, "QUERY_EXECUTION_ERROR"),
237:       errorMessage: responseCodeMessage(
238:         normalizePublicResponseCode(audit.errorCode, "QUERY_EXECUTION_ERROR")
239:       )
240:     }));
241: 
242:   const eventFailures = events.flatMap((event) => {
243:     const checkpoint = parseJsonRecord(event.batchCheckpoint);
244:     const rawErrorCode = readNonEmptyString(checkpoint?.errorCode);
245:     if (!rawErrorCode || rawErrorCode === "SUCCESS") {
246:       return [];
247:     }
248:     const errorCode = normalizePublicResponseCode(rawErrorCode, "QUERY_EXECUTION_ERROR");
249: 
250:     return [
251:       {
252:         occurredAt: event.occurredAt,
253:         errorCode,
254:         errorMessage: readNonEmptyString(checkpoint?.errorMessage) ?? responseCodeMessage(errorCode)
255:       }
256:     ];
257:   });
258: 
259:   const failedRecord = [...auditFailures, ...eventFailures].sort(
260:     (left, right) => right.occurredAt.getTime() - left.occurredAt.getTime()
261:   )[0];
262: 
263:   if (!failedRecord) {
264:     return {
265:       errorCode: null,
266:       errorMessage: null
267:     };
268:   }
269: 
270:   return {
271:     errorCode: failedRecord.errorCode,
272:     errorMessage: failedRecord.errorMessage
273:   };
274: }
