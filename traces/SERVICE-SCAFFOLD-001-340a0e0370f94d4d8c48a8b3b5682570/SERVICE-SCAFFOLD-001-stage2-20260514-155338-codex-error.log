ameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: \"#/components/schemas/CreateExportTaskRequest\"\n            examples:\n              purchaseOrder:\n                summary: Purchase order export task\n                value:\n                  taskCode: purchase-order-export\n                  subsystemCode: purchase\n                  fileFormat: XLSX\n                  clientRequestId: req-20260513-0001\n                  queryParams:\n                    createdAtFrom: \"2026-05-01T00:00:00+08:00\"\n                    createdAtTo: \"2026-05-13T23:59:59+08:00\"\n                    orderStatus: APPROVED\n                    supplierId: SUP-001\n                    purchaseOrgId: ORG-001\n                    keyword: PO-2026\n      x-contract-errorResponses:\n        - TASK_DISABLED\n        - EXPORT_LIMIT_EXCEEDED\n        - QUERY_TEMPLATE_INVALID\n        - DATASOURCE_UNAVAILABLE\n        - FIELD_MAPPING_INVALID\n        - MASKING_RULE_ERROR\n        - INTERNAL_ERROR\n      responses:\n        \"201\":\n          description: Task created.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/CreateExportTaskResponseEnvelope\"\n              examples:\n                created:\n                  value:\n                    code: SUCCESS\n                    message: success\n                    data:\n                      taskId: exp_20260513_000001\n                      taskCode: purchase-order-export\n                      subsystemCode: purchase\n                      status: PENDING\n                      clientRequestId: req-20260513-0001\n                      idempotencyHit: false\n                      idempotencyScope: tenant-001:u001:purchase-order-export:req-20260513-0001\n                      requestDigest: sha256:request-digest\n                      configSnapshotDigest: sha256:config-digest\n                      attemptNo: 0\n                      createdAt: \"2026-05-13T10:00:00+08:00\"\n        \"200\":\n          description: Existing task returned for idempotent replay with identical request digest.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/CreateExportTaskResponseEnvelope\"\n        \"400\":\n          $ref: \"#/components/responses/CreateTaskBadRequest\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotRegistered\"\n        \"409\":\n          $ref: \"#/components/responses/IdempotencyConflict\"\n        \"500\":\n          $ref: \"#/components/responses/DatasourceUnavailable\"\n      x-contract-errorResponseStatus:\n        TASK_DISABLED: 400\n        QUERY_PARAMS_TOO_LARGE: 400\n        EXPORT_LIMIT_EXCEEDED: 400\n        DATASOURCE_UNAVAILABLE: 500\n        INTERNAL_ERROR: 500\n    get:\n      tags: [ExportTasks]\n      summary: Search task history\n      description: |\n        Returns paged task history. Normal users can only see their own tasks;\n        administrators can see global tasks according to roleCodes and orgScope.\n      operationId: listExportTasks\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - name: taskCode\n          in: query\n          schema:\n            type: string\n        - name: status\n          in: query\n          schema:\n            $ref: \"#/components/schemas/TaskStatus\"\n        - name: createdBy\n          in: query\n          schema:\n            type: string\n        - name: createdAtFrom\n          in: query\n          schema:\n            type: string\n            format: date-time\n        - name: createdAtTo\n          in: query\n          schema:\n            type: string\n            format: date-time\n        - name: fileFormat\n          in: query\n          schema:\n            $ref: \"#/components/schemas/FileFormat\"\n        - name: subsystemCode\n          in: query\n          schema:\n            type: string\n        - name: page\n          in: query\n          schema:\n            type: integer\n            minimum: 1\n            default: 1\n        - name: pageSize\n          in: query\n          schema:\n            type: integer\n            minimum: 1\n            maximum: 100\n            default: 20\n      responses:\n        \"200\":\n          description: Paged task history.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportTaskPageEnvelope\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"500\":\n          $ref: \"#/components/responses/QueryExecutionError\"\n  /export/tasks/{taskId}:\n    get:\n      tags: [ExportTasks]\n      summary: Get task detail and progress\n      operationId: getExportTask\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskId\"\n      responses:\n        \"200\":\n          description: Task detail.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportTaskDetailEnvelope\"\n              examples:\n                executing:\n                  value:\n                    code: SUCCESS\n                    message: success\n                    data:\n                      taskId: exp_20260513_000001\n                      taskCode: purchase-order-export\n                      subsystemCode: purchase\n                      status: EXECUTING\n                      totalCount: 100000\n                      processedCount: 20000\n                      progressPercent: 20.0\n                      fileFormat: ZIP\n                      attemptNo: 1\n                      requestId: req-20260513-0001\n                      requestDigest: sha256:request-digest\n                      configSnapshotDigest: sha256:config-digest\n                      createdBy: u001\n                      createdAt: \"2026-05-13T10:00:00+08:00\"\n                      updatedAt: \"2026-05-13T10:05:00+08:00\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotFound\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n  /export/tasks/{taskId}/download:\n    get:\n      tags: [ExportTasks]\n      summary: Download exported file\n      description: |\n        The default mode returns a signed URL and file metadata. Stream delivery\n        is represented by application/octet-stream and equivalent metadata headers.\n      operationId: downloadExportTask\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskId\"\n        - name: mode\n          in: query\n          schema:\n            $ref: \"#/components/schemas/DeliveryMode\"\n            default: SIGNED_URL\n      responses:\n        \"200\":\n          description: Signed URL response or file stream.\n          headers:\n            X-Export-File-Name:\n              schema:\n                type: string\n            X-Export-File-Size:\n              schema:\n                type: integer\n                format: int64\n            X-Export-Checksum:\n              schema:\n                type: string\n            X-Export-Checksum-Algorithm:\n              schema:\n                type: string\n                enum: [SHA-256]\n            X-Export-Attempt-No:\n              schema:\n                type: integer\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/DownloadResponseEnvelope\"\n              examples:\n                signedUrl:\n                  value:\n                    code: SUCCESS\n                    message: success\n                    data:\n                      deliveryMode: SIGNED_URL\n                      downloadUrl: \"https://oss.example.com/signed-url\"\n                      expiresAt: \"2026-05-13T10:10:00+08:00\"\n                      fileName: purchase-order-export-20260513.zip\n                      fileSize: 1048576\n                      contentType: application/zip\n                      checksum: sha256:file-checksum\n                      checksumAlgorithm: SHA-256\n                      storageKey: exports/purchase/purchase-order-export/20260513/exp_20260513_000001/1/purchase-order-export-20260513.zip\n                      attemptNo: 1\n            application/octet-stream:\n              schema:\n                type: string\n                format: binary\n        \"400\":\n          $ref: \"#/components/responses/FileNotReady\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotFound\"\n        \"410\":\n          $ref: \"#/components/responses/FileExpired\"\n        \"500\":\n          $ref: \"#/components/responses/FileVerifyError\"\n        \"502\":\n          $ref: \"#/components/responses/ExportRenderError\"\n      x-contract-errorResponses:\n        - FILE_NOT_READY\n        - FILE_VERIFY_ERROR\n        - EXPORT_RENDER_ERROR\n        - INTERNAL_ERROR\n  /export/tasks/{taskId}/cancel:\n    post:\n      tags: [ExportTasks]\n      summary: Cancel export task\n      description: |\n        PENDING tasks can be canceled immediately. EXECUTING tasks accept cancel\n        intent and still return EXECUTING until the worker closes the task at a\n        batch boundary. The API never returns an internal cancel marker as a task status.\n      operationId: cancelExportTask\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskId\"\n      requestBody:\n        required: false\n        content:\n          application/json:\n            schema:\n              $ref: \"#/components/schemas/TaskActionRequest\"\n      responses:\n        \"200\":\n          description: Cancel accepted or completed.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/TaskActionResponseEnvelope\"\n        \"400\":\n          $ref: \"#/components/responses/InvalidTaskState\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotFound\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n  /export/tasks/{taskId}/retry:\n    post:\n      tags: [ExportTasks]\n      summary: Retry failed export task\n      description: |\n        Only FAILED tasks are retryable. Retry keeps the original taskId,\n        reuses the original config snapshot, increments attemptNo and creates no\n        second active execution attempt.\n      operationId: retryExportTask\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskId\"\n      requestBody:\n        required: false\n        content:\n          application/json:\n            schema:\n              $ref: \"#/components/schemas/TaskActionRequest\"\n      responses:\n        \"200\":\n          description: Retry accepted.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/TaskActionResponseEnvelope\"\n        \"400\":\n          $ref: \"#/components/responses/InvalidTaskState\"\n        \"409\":\n          $ref: \"#/components/responses/ActiveAttemptConflict\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotFound\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n  /export/registries:\n    post:\n      tags: [ExportRegistries]\n      summary: Create export registry\n      operationId: createExportRegistry\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: \"#/components/schemas/ExportRegistryUpsertRequest\"\n            examples:\n              purchaseOrderRegistry:\n                value:\n                  taskCode: purchase-order-export\n                  subsystemCode: purchase\n                  displayName: Purchase order export\n                  enabled: true\n                  concurrencyLimit: 3\n                  fileRetentionDays: 15\n                  taskHistoryRetentionDays: 30\n                  singleFileMaxRows: 20000\n                  exportMaxRows: 100000\n                  supportedFormats: [XLSX, ZIP]\n                  datasourceCode: purchase_ro\n                  parameterSchema:\n                    required: [createdAtFrom, createdAtTo]\n                    properties:\n                      createdAtFrom:\n                        type: string\n                        format: date-time\n                      createdAtTo:\n                        type: string\n                        format: date-time\n                      orderStatus:\n                        type: string\n                      supplierId:\n                        type: string\n                      purchaseOrgId:\n                        type: string\n                      keyword:\n                        type: string\n                  queryTemplate:\n                    queryTemplateVersion: v1\n                    templateText: \"select ... where created_at between :createdAtFrom and :createdAtTo order by order_id asc\"\n                    allowedParameters: [createdAtFrom, createdAtTo, orderStatus, supplierId, purchaseOrgId, keyword]\n                  fieldMappings:\n                    - fieldCode: orderNo\n                      headerName: Order No\n                      fieldType: STRING\n                      orderNo: 1\n                      sensitive: false\n                      exportable: true\n                    - fieldCode: contactPhone\n                      headerName: Contact Phone\n                      fieldType: STRING\n                      orderNo: 10\n                      sensitive: true\n                      exportable: true\n                      maskingRuleCode: phone_mask\n                  maskingPolicy:\n                    rules:\n                      phone_mask:\n                        type: PHONE\n                        preservePrefix: 3\n                        preserveSuffix: 4\n                  dataScopeTemplate: \"tenant_id = :tenantId and org_id in (:orgScope)\"\n                  cursorField: orderId\n                  orderBy:\n                    - field: orderId\n                      direction: ASC\n                  batchSize: 1000\n      x-contract-errorResponses:\n        - QUERY_TEMPLATE_INVALID\n        - FIELD_MAPPING_INVALID\n        - MASKING_RULE_ERROR\n        - REGISTRY_CONFLICT\n        - INTERNAL_ERROR\n      responses:\n        \"201\":\n          description: Registry created.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryEnvelope\"\n        \"400\":\n          $ref: \"#/components/responses/RegistryBadRequest\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"409\":\n          $ref: \"#/components/responses/RegistryConflict\"\n        \"500\":\n          $ref: \"#/components/responses/RegistryServerError\"\n    get:\n      tags: [ExportRegistries]\n      summary: List export registries\n      operationId: listExportRegistries\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - name: taskCode\n          in: query\n          schema:\n            type: string\n        - name: subsystemCode\n          in: query\n          schema:\n            type: string\n        - name: enabled\n          in: query\n          schema:\n            type: boolean\n        - name: page\n          in: query\n          schema:\n            type: integer\n            minimum: 1\n            default: 1\n        - name: pageSize\n          in: query\n          schema:\n            type: integer\n            minimum: 1\n            maximum: 100\n            default: 20\n      responses:\n        \"200\":\n          description: Paged registry list.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryPageEnvelope\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n  /export/registries/{taskCode}:\n    get:\n      tags: [ExportRegistries]\n      summary: Get export registry\n      operationId: getExportRegistry\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskCode\"\n      responses:\n        \"200\":\n          description: Registry detail.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryEnvelope\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotRegistered\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n    put:\n      tags: [ExportRegistries]\n      summary: Update export registry\n      description: Registry updates only affect tasks created after the update.\n      operationId: updateExportRegistry\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskCode\"\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: \"#/components/schemas/ExportRegistryUpsertRequest\"\n      x-contract-errorResponses:\n        - QUERY_TEMPLATE_INVALID\n        - FIELD_MAPPING_INVALID\n        - MASKING_RULE_ERROR\n        - INTERNAL_ERROR\n      responses:\n        \"200\":\n          description: Registry updated.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryEnvelope\"\n        \"400\":\n          $ref: \"#/components/responses/RegistryBadRequest\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotRegistered\"\n        \"500\":\n          $ref: \"#/components/responses/RegistryServerError\"\n  /export/registries/{taskCode}/enable:\n    post:\n      tags: [ExportRegistries]\n      summary: Enable export registry\n      operationId: enableExportRegistry\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskCode\"\n      responses:\n        \"200\":\n          description: Registry enabled.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryEnvelope\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotRegistered\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\n  /export/registries/{taskCode}/disable:\n    post:\n      tags: [ExportRegistries]\n      summary: Disable export registry\n      operationId: disableExportRegistry\n      parameters:\n        - $ref: \"#/components/parameters/XOperatorId\"\n        - $ref: \"#/components/parameters/XTenantId\"\n        - $ref: \"#/components/parameters/XRoleCodes\"\n        - $ref: \"#/components/parameters/XOrgScope\"\n        - $ref: \"#/components/parameters/XRequestId\"\n        - $ref: \"#/components/parameters/TaskCode\"\n      responses:\n        \"200\":\n          description: Registry disabled.\n          content:\n            application/json:\n              schema:\n                $ref: \"#/components/schemas/ExportRegistryEnvelope\"\n        \"401\":\n          $ref: \"#/components/responses/AuthContextMissing\"\n        \"403\":\n          $ref: \"#/components/responses/PermissionDenied\"\n        \"404\":\n          $ref: \"#/components/responses/TaskNotRegistered\"\n        \"500\":\n          $ref: \"#/components/responses/InternalError\"\ncomponents:\n  securitySchemes:\n    OperatorId:\n      type: apiKey\n      in: header\n      name: X-Operator-Id\n      description: Authenticated operator id forwarded by gateway or caller.\n    TenantId:\n      type: apiKey\n      in: header\n      name: X-Tenant-Id\n      description: Tenant id forwarded by gateway or caller.\n    RoleCodes:\n      type: apiKey\n      in: header\n      name: X-Role-Codes\n      description: Comma-separated role codes forwarded by gateway or caller.\n    OrgScope:\n      type: apiKey\n      in: header\n      name: X-Org-Scope\n      description: Organization scope forwarded by gateway or caller.\n    RequestId:\n      type: apiKey\n      in: header\n      name: X-Request-Id\n      description: Request id used by audit logs and task events.\n  parameters:\n    XOperatorId:\n      name: X-Operator-Id\n      in: header\n      required: true\n      schema:\n        type: string\n      description: Authenticated operator id.\n    XTenantId:\n      name: X-Tenant-Id\n      in: header\n      required: true\n      schema:\n        type: string\n      description: Tenant id for task visibility and data scope.\n    XRoleCodes:\n      name: X-Role-Codes\n      in: header\n      required: true\n      schema:\n        type: string\n      description: Comma-separated role codes.\n    XOrgScope:\n      name: X-Org-Scope\n      in: header\n      required: true\n      schema:\n        type: string\n      description: Organization scope expression or encoded scope list.\n    XRequestId:\n      name: X-Request-Id\n      in: header\n      required: true\n      schema:\n        type: string\n      description: Upstream request id used by audit logs and task events.\n    TaskId:\n      name: taskId\n      in: path\n      required: true\n      schema:\n        type: string\n    TaskCode:\n      name: taskCode\n      in: path\n      required: true\n      schema:\n        type: string\n  responses:\n    AuthContextMissing:\n      description: Required auth context is missing or malformed.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            authMissing:\n              value:\n                code: AUTH_CONTEXT_MISSING\n                message: auth context missing\n                data: null\n    PermissionDenied:\n      description: Operator has no permission for the task, registry or file.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            denied:\n              value:\n                code: PERMISSION_DENIED\n                message: permission denied\n                data: null\n    TaskNotFound:\n      description: Task not found or invisible to current operator.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            notFound:\n              value:\n                code: TASK_NOT_FOUND\n                message: task not found\n                data: null\n    TaskNotRegistered:\n      description: taskCode is not registered.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            notRegistered:\n              value:\n                code: TASK_NOT_REGISTERED\n                message: task code not registered\n                data: null\n    CreateTaskBadRequest:\n      description: Create task request is invalid, disabled or exceeds configured limits.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            validation:\n              value:\n                code: VALIDATION_ERROR\n                message: validation failed\n                data: null\n                errors:\n                  - field: taskCode\n                    reason: required\n            taskDisabled:\n              value:\n                code: TASK_DISABLED\n                message: task code is disabled\n                data:\n                  taskCode: purchase-order-export\n            queryParamsTooLarge:\n              value:\n                code: QUERY_PARAMS_TOO_LARGE\n                message: queryParams exceeds 32768 bytes\n                data: null\n            exportLimitExceeded:\n              value:\n                code: EXPORT_LIMIT_EXCEEDED\n                message: export limit exceeded\n                data:\n                  exportMaxRows: 100000\n    IdempotencyConflict:\n      description: Same idempotency scope with different request digest.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            conflict:\n              value:\n                code: IDEMPOTENCY_CONFLICT\n                message: clientRequestId conflicts with a different request digest\n                data:\n                  idempotencyScope: tenant-001:u001:purchase-order-export:req-20260513-0001\n    InvalidTaskState:\n      description: Operation is not allowed for current official task status.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            invalidRetry:\n              value:\n                code: INVALID_TASK_STATE\n                message: current task status does not allow this operation\n                data:\n                  status: EXECUTING\n    ActiveAttemptConflict:\n      description: Another active execution attempt already exists.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            activeAttempt:\n              value:\n                code: ACTIVE_ATTEMPT_CONFLICT\n                message: active execution attempt already exists\n                data:\n                  taskId: exp_20260513_000001\n                  attemptNo: 1\n    FileExpired:\n      description: File is expired or marked as not downloadable.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            expired:\n              value:\n                code: FILE_EXPIRED\n                message: file expired\n                data: null\n    FileNotReady:\n      description: File is not published or the task is not completed yet.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            notReady:\n              value:\n                code: FILE_NOT_READY\n                message: file is not ready for download\n                data:\n                  status: EXECUTING\n    FileVerifyError:\n      description: File upload, metadata or checksum verification failed before publish.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            verifyFailed:\n              value:\n                code: FILE_VERIFY_ERROR\n                message: file verification failed\n                data:\n                  checksumAlgorithm: SHA-256\n    DatasourceUnavailable:\n      description: Datasource or datasource credential is unavailable.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            datasourceUnavailable:\n              value:\n                code: DATASOURCE_UNAVAILABLE\n                message: datasource unavailable\n                data:\n                  datasourceCode: purchase_ro\n    QueryExecutionError:\n      description: Query execution failed, batch retries exhausted or cursor contract violated.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            queryFailed:\n              value:\n                code: QUERY_EXECUTION_ERROR\n                message: query execution failed\n                data:\n                  cursorField: orderId\n    RegistryBadRequest:\n      description: Registry request is invalid, exceeds limits, or contains invalid field/masking configuration.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            validation:\n              value:\n                code: VALIDATION_ERROR\n                message: validation failed\n                data: null\n            exportLimitExceeded:\n              value:\n                code: EXPORT_LIMIT_EXCEEDED\n                message: export limit exceeded\n                data:\n                  exportMaxRows: 100000\n            fieldMappingInvalid:\n              value:\n                code: FIELD_MAPPING_INVALID\n                message: field mapping invalid\n                data:\n                  fieldCode: contactPhone\n            maskingRuleError:\n              value:\n                code: MASKING_RULE_ERROR\n                message: masking rule error\n                data:\n                  maskingRuleCode: phone_mask\n    RegistryServerError:\n      description: Registry contract references an invalid query template, datasource, field mapping or masking backend.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            queryTemplateInvalid:\n              value:\n                code: QUERY_TEMPLATE_INVALID\n                message: query template invalid\n                data:\n                  taskCode: purchase-order-export\n            datasourceUnavailable:\n              value:\n                code: DATASOURCE_UNAVAILABLE\n                message: datasource unavailable\n                data:\n                  datasourceCode: purchase_ro\n            fieldMappingInvalid:\n              value:\n                code: FIELD_MAPPING_INVALID\n                message: field mapping invalid\n                data:\n                  fieldCode: contactPhone\n            maskingRuleError:\n              value:\n                code: MASKING_RULE_ERROR\n                message: masking rule error\n                data:\n                  maskingRuleCode: phone_mask\n    ExportRenderError:\n      description: XLSX or ZIP render failed.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            renderFailed:\n              value:\n                code: EXPORT_RENDER_ERROR\n                message: export render error\n                data:\n                  fileFormat: ZIP\n    RegistryConflict:\n      description: Registry taskCode already exists or conflicts with immutable fields.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            duplicate:\n              value:\n                code: REGISTRY_CONFLICT\n                message: taskCode already exists\n                data: null\n    InternalError:\n      description: Unclassified server-side error. Specific platform errors should use a more precise response when known.\n      content:\n        application/json:\n          schema:\n            $ref: \"#/components/schemas/ErrorEnvelope\"\n          examples:\n            internalError:\n              value:\n                code: INTERNAL_ERROR\n                message: internal error\n                data: null\n  schemas:\n    ResponseCode:\n      type: string\n      enum:\n        - SUCCESS\n        - VALIDATION_ERROR\n        - AUTH_CONTEXT_MISSING\n        - PERMISSION_DENIED\n        - TASK_NOT_FOUND\n        - TASK_NOT_REGISTERED\n        - TASK_DISABLED\n        - QUERY_PARAMS_TOO_LARGE\n        - IDEMPOTENCY_CONFLICT\n        - INVALID_TASK_STATE\n        - FILE_EXPIRED\n        - FILE_NOT_READY\n        - FILE_VERIFY_ERROR\n        - QUERY_TEMPLATE_INVALID\n        - DATASOURCE_UNAVAILABLE\n        - QUERY_EXECUTION_ERROR\n        - FIELD_MAPPING_INVALID\n        - MASKING_RULE_ERROR\n        - EXPORT_RENDER_ERROR\n        - EXPORT_LIMIT_EXCEEDED\n        - REGISTRY_CONFLICT\n        - ACTIVE_ATTEMPT_CONFLICT\n        - INTERNAL_ERROR\n    TaskStatus:\n      type: string\n      description: Official public task status. Internal cancel flags are not valid values.\n      enum: [PENDING, EXECUTING, COMPLETED, FAILED, CANCELED, EXPIRED]\n    FileFormat:\n      type: string\n      enum: [XLSX, ZIP]\n    DeliveryMode:\n      type: string\n      enum: [SIGNED_URL, STREAM]\n    Envelope:\n      type: object\n      required: [code, message]\n      properties:\n        code:\n          $ref: \"#/components/schemas/ResponseCode\"\n        message:\n          type: string\n    ErrorEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          properties:\n            data:\n              type: object\n              nullable: true\n              additionalProperties: true\n            errors:\n              type: array\n              items:\n                $ref: \"#/components/schemas/FieldError\"\n    FieldError:\n      type: object\n      required: [field, reason]\n      properties:\n        field:\n          type: string\n        reason:\n          type: string\n    CreateExportTaskRequest:\n      type: object\n      required: [taskCode, subsystemCode, fileFormat, queryParams]\n      properties:\n        taskCode:\n          type: string\n        subsystemCode:\n          type: string\n        fileFormat:\n          $ref: \"#/components/schemas/FileFormat\"\n        clientRequestId:\n          type: string\n          maxLength: 128\n          description: Optional idempotency key scoped by tenantId/operatorId/taskCode.\n        queryParams:\n          type: object\n          additionalProperties: true\n          description: Must match registry parameter schema and must not exceed 32768 bytes after canonical JSON serialization.\n        deliveryPreference:\n          $ref: \"#/components/schemas/DeliveryMode\"\n    CreateExportTaskResponseEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/CreateExportTaskResponse\"\n    CreateExportTaskResponse:\n      type: object\n      required:\n        - taskId\n        - taskCode\n        - subsystemCode\n        - status\n        - idempotencyScope\n        - requestDigest\n        - configSnapshotDigest\n        - attemptNo\n        - createdAt\n      properties:\n        taskId:\n          type: string\n        taskCode:\n          type: string\n        subsystemCode:\n          type: string\n        status:\n          type: string\n          enum: [PENDING]\n        clientRequestId:\n          type: string\n        idempotencyHit:\n          type: boolean\n        idempotencyScope:\n          type: string\n          description: Stable success-response evidence for the tenantId + operatorId + taskCode + clientRequestId idempotency scope.\n        requestDigest:\n          type: string\n        configSnapshotDigest:\n          type: string\n        attemptNo:\n          type: integer\n          minimum: 0\n        createdAt:\n          type: string\n          format: date-time\n    ExportTaskDetailEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/ExportTaskDetail\"\n    ExportTaskDetail:\n      type: object\n      required:\n        - taskId\n        - taskCode\n        - subsystemCode\n        - status\n        - totalCount\n        - processedCount\n        - progressPercent\n        - attemptNo\n        - requestId\n        - requestDigest\n        - configSnapshotDigest\n        - createdBy\n        - createdAt\n        - updatedAt\n      properties:\n        taskId:\n          type: string\n        taskCode:\n          type: string\n        subsystemCode:\n          type: string\n        status:\n          $ref: \"#/components/schemas/TaskStatus\"\n        totalCount:\n          type: integer\n          format: int64\n          minimum: 0\n        processedCount:\n          type: integer\n          format: int64\n          minimum: 0\n        progressPercent:\n          type: number\n          minimum: 0\n          maximum: 100\n        fileFormat:\n          $ref: \"#/components/schemas/FileFormat\"\n        attemptNo:\n          type: integer\n          minimum: 0\n        errorCode:\n          $ref: \"#/components/schemas/ResponseCode\"\n        errorMessage:\n          type: string\n        failureStage:\n          type: string\n        lastSuccessStage:\n          type: string\n        requestId:\n          type: string\n        requestDigest:\n          type: string\n        configSnapshotDigest:\n          type: string\n        createdBy:\n          type: string\n        createdAt:\n          type: string\n          format: date-time\n        updatedAt:\n          type: string\n          format: date-time\n        file:\n          $ref: \"#/components/schemas/FileMetadata\"\n        batchCheckpoint:\n          $ref: \"#/components/schemas/BatchCheckpoint\"\n        recentEvents:\n          type: array\n          items:\n            $ref: \"#/components/schemas/TaskEvent\"\n        auditEvents:\n          type: array\n          items:\n            $ref: \"#/components/schemas/AuditEvent\"\n    ExportTaskPageEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/ExportTaskPage\"\n    ExportTaskPage:\n      type: object\n      required: [items, page, pageSize, total]\n      properties:\n        items:\n          type: array\n          items:\n            $ref: \"#/components/schemas/ExportTaskDetail\"\n        page:\n          type: integer\n        pageSize:\n          type: integer\n        total:\n          type: integer\n          format: int64\n    DownloadResponseEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/DownloadResponse\"\n    DownloadResponse:\n      allOf:\n        - $ref: \"#/components/schemas/FileMetadata\"\n        - type: object\n          required: [deliveryMode, expiresAt]\n          properties:\n            deliveryMode:\n              $ref: \"#/components/schemas/DeliveryMode\"\n            downloadUrl:\n              type: string\n              format: uri\n            expiresAt:\n              type: string\n              format: date-time\n    FileMetadata:\n      type: object\n      required:\n        - fileName\n        - fileSize\n        - contentType\n        - checksum\n        - checksumAlgorithm\n        - storageKey\n        - expiresAt\n        - attemptNo\n      properties:\n        fileName:\n          type: string\n        fileSize:\n          type: integer\n          format: int64\n        contentType:\n          type: string\n        tempStorageKey:\n          type: string\n        publishedStorageKey:\n          type: string\n        storageKey:\n          type: string\n        expiresAt:\n          type: string\n          format: date-time\n          description: Published file retention expiry time. Signed URL responses also use expiresAt for URL expiry.\n        checksum:\n          type: string\n        checksumAlgorithm:\n          type: string\n          enum: [SHA-256]\n        checksumVerifiedAt:\n          type: string\n          format: date-time\n        publishedAt:\n          type: string\n          format: date-time\n        deliveryReadyAt:\n          type: string\n          format: date-time\n        attemptNo:\n          type: integer\n          minimum: 1\n    TaskActionRequest:\n      type: object\n      properties:\n        reason:\n          type: string\n          maxLength: 500\n    TaskActionResponseEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/TaskActionResponse\"\n    TaskActionResponse:\n      type: object\n      required: [taskId, status, attemptNo, acceptedAt]\n      properties:\n        taskId:\n          type: string\n        status:\n          $ref: \"#/components/schemas/TaskStatus\"\n        attemptNo:\n          type: integer\n        cancelAccepted:\n          type: boolean\n          description: True means an EXECUTING task will stop at a batch boundary; this is not a task status.\n        retryAccepted:\n          type: boolean\n        configSnapshotDigest:\n          type: string\n        acceptedAt:\n          type: string\n          format: date-time\n    ExportRegistryUpsertRequest:\n      type: object\n      required:\n        - taskCode\n        - subsystemCode\n        - displayName\n        - enabled\n        - concurrencyLimit\n        - fileRetentionDays\n        - taskHistoryRetentionDays\n        - singleFileMaxRows\n        - exportMaxRows\n        - supportedFormats\n        - datasourceCode\n        - parameterSchema\n        - queryTemplate\n        - fieldMappings\n        - maskingPolicy\n        - dataScopeTemplate\n        - cursorField\n        - orderBy\n        - batchSize\n      properties:\n        taskCode:\n          type: string\n        subsystemCode:\n          type: string\n        displayName:\n          type: string\n        enabled:\n          type: boolean\n        concurrencyLimit:\n          type: integer\n          minimum: 1\n        fileRetentionDays:\n          type: integer\n          minimum: 1\n          default: 15\n        taskHistoryRetentionDays:\n          type: integer\n          minimum: 1\n          default: 30\n        singleFileMaxRows:\n          type: integer\n          minimum: 1\n          default: 20000\n        exportMaxRows:\n          type: integer\n          minimum: 1\n          default: 100000\n        supportedFormats:\n          type: array\n          minItems: 1\n          items:\n            $ref: \"#/components/schemas/FileFormat\"\n        datasourceCode:\n          type: string\n          description: Must reference a registered read-only datasource or data platform dataset.\n        parameterSchema:\n          type: object\n          additionalProperties: true\n        queryTemplate:\n          $ref: \"#/components/schemas/QueryTemplateContract\"\n        fieldMappings:\n          type: array\n          minItems: 1\n          items:\n            $ref: \"#/components/schemas/FieldMapping\"\n        maskingPolicy:\n          type: object\n          additionalProperties: true\n          description: Required masking policy. Any fieldMappings item with sensitive=true must reference a maskingRuleCode covered by this policy.\n        dataScopeTemplate:\n          type: string\n          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.\n        cursorField:\n          type: string\n        orderBy:\n          type: array\n          minItems: 1\n          items:\n            $ref: \"#/components/schemas/OrderBy\"\n        batchSize:\n          type: integer\n          minimum: 1\n    ExportRegistryEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              $ref: \"#/components/schemas/ExportRegistry\"\n    ExportRegistryPageEnvelope:\n      allOf:\n        - $ref: \"#/components/schemas/Envelope\"\n        - type: object\n          required: [data]\n          properties:\n            data:\n              type: object\n              required: [items, page, pageSize, total]\n              properties:\n                items:\n                  type: array\n                  items:\n                    $ref: \"#/components/schemas/ExportRegistry\"\n                page:\n                  type: integer\n                pageSize:\n                  type: integer\n                total:\n                  type: integer\n                  format: int64\n    ExportRegistry:\n      allOf:\n        - $ref: \"#/components/schemas/ExportRegistryUpsertRequest\"\n        - type: object\n          required:\n            - configSnapshotDigest\n            - parameterSchemaDigest\n            - fieldMappingDigest\n            - maskingPolicyDigest\n            - updatedAt\n            - updatedBy\n          properties:\n            configSnapshotDigest:\n              type: string\n            parameterSchemaDigest:\n              type: string\n              description: Digest of the effective parameter schema used by future config snapshots.\n            fieldMappingDigest:\n              type: string\n              description: Digest of ordered field mappings and exportable whitelist.\n            maskingPolicyDigest:\n              type: string\n              description: Digest of masking policy and sensitive field rules.\n            updatedAt:\n              type: string\n              format: date-time\n            updatedBy:\n              type: string\n    QueryTemplateContract:\n      type: object\n      required: [queryTemplateVersion, templateText, allowedParameters]\n      properties:\n        queryTemplateVersion:\n          type: string\n        templateText:\n          type: string\n          description: Parameterized query template. Raw SQL from callers is forbidden.\n        allowedParameters:\n          type: array\n          items:\n            type: string\n    FieldMapping:\n      type: object\n      required: [fieldCode, headerName, fieldType, orderNo, sensitive, exportable]\n      properties:\n        fieldCode:\n          type: string\n        headerName:\n          type: string\n        fieldType:\n          type: string\n          enum: [STRING, NUMBER, DECIMAL, DATETIME, DATE, BOOLEAN]\n        orderNo:\n          type: integer\n          minimum: 1\n        sensitive:\n          type: boolean\n        exportable:\n          type: boolean\n        maskingRuleCode:\n          type: string\n    OrderBy:\n      type: object\n      required: [field, direction]\n      properties:\n        field:\n          type: string\n        direction:\n          type: string\n          enum: [ASC, DESC]\n    BatchCheckpoint:\n      type: object\n      required:\n        - attemptNo\n        - lockOwner\n        - lockExpireAt\n        - leaseRenewedAt\n        - databaseTime\n      properties:\n        lastCursor:\n          type: string\n        processedCount:\n          type: integer\n          format: int64\n        filePartNo:\n          type: integer\n        attemptNo:\n          type: integer\n        batchSize:\n          type: integer\n        batchRowCount:\n          type: integer\n        retryCount:\n          type: integer\n        backoffMs:\n          type: integer\n        lockOwner:\n          type: string\n          description: Worker identity that owns the database lease for the current attempt.\n        lockExpireAt:\n          type: string\n          format: date-time\n          description: Lease expiry based on database time; default lease is five minutes unless registry config overrides it.\n        leaseRenewedAt:\n          type: string\n          format: date-time\n          description: Last successful lease renewal time based on database time.\n        databaseTime:\n          type: string\n          format: date-time\n          description: Database clock snapshot used for lock acquisition, renewal and takeover decisions.\n        takeoverRule:\n          type: string\n          description: Workers may take over only after database time is later than lockExpireAt; takeover keeps the same attemptNo.\n    AuditEvent:\n      type: object\n      required:\n        - taskId\n        - taskCode\n        - subsystemCode\n        - operatorId\n        - action\n        - result\n        - errorCode\n        - requestId\n        - occurredAt\n      properties:\n        taskId:\n          type: string\n        taskCode:\n          type: string\n        subsystemCode:\n          type: string\n        operatorId:\n          type: string\n        action:\n          type: string\n          enum:\n            - CREATE\n            - QUERY_HISTORY\n            - DETAIL_VIEW\n            - DISPATCH\n            - EXECUTE_START\n            - EXECUTE_SUCCESS\n            - EXECUTE_FAILED\n            - CANCEL_REQUEST\n            - CANCEL_DONE\n            - RETRY_REQUEST\n            - DOWNLOAD\n            - EXPIRE_MARK\n            - CLEANUP_FAILED\n            - REGISTRY_CREATE\n            - REGISTRY_QUERY\n            - REGISTRY_DETAIL\n            - REGISTRY_UPDATE\n            - REGISTRY_ENABLE\n            - REGISTRY_DISABLE\n        result:\n          type: string\n          enum: [SUCCESS, FAILED, ACCEPTED]\n        errorCode:\n          $ref: \"#/components/schemas/ResponseCode\"\n        requestId:\n          type: string\n        occurredAt:\n          type: string\n          format: date-time\n    TaskEvent:\n      type: object\n      required: [taskId, attemptNo, eventType, requestId, occurredAt]\n      properties:\n        taskId:\n          type: string\n        attemptNo:\n          type: integer\n        eventType:\n          type: string\n          enum:\n        