        - FIELD_MAPPING_INVALID
        - MASKING_RULE_ERROR
        - EXPORT_RENDER_ERROR
        - EXPORT_LIMIT_EXCEEDED
        - REGISTRY_CONFLICT
        - ACTIVE_ATTEMPT_CONFLICT
        - INTERNAL_ERROR
    TaskStatus:
      type: string
