function batchResult(lastCursor, processedCount) {
  return {
    checkpoint: {
      lastCursor,
      processedCount,
      filePartNo: 1,
      retryCount: 0,
      batchSize: 500,
      batchRowCount: processedCount,
      backoffMs: 0
    },
    outcome: "continue"
  };
}

