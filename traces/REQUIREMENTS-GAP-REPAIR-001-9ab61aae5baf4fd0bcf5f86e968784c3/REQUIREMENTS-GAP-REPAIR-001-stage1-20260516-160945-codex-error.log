        tenant_id: "tenant-001",
        org_id: "ORG-002",
        order_no: "PO-2026-002",
        order_status: "APPROVED",
        supplier_id: "SUP-001",
        purchase_org_id: "PO-001",
        contact_phone: "13987654321",
        keyword_text: "PO-2026 bananas",
        created_at: now
      },
      {
        order_id: "order-003",
        tenant_id: "tenant-002",
