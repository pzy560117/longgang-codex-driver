+      return db.transaction().execute(async (trx) => {
+        const task = await trx
+          .selectFrom("export_tasks")
+          .select(["status", "attempt_no"])
+          .where("task_id", "=", input.taskId)
+          .forUpdate()
+          .executeTakeFirst();
+
