+            attempt_no: task.attempt_no + 1,
+            lock_owner: null,
+            lock_expire_at: null,
+            lease_renewed_at: null,
+            updated_at: input.now
+          })
+          .where("task_id", "=", input.taskId)
+          .execute();
+
+        const row = await trx
+          .selectFrom("export_tasks")
+          .selectAll()
