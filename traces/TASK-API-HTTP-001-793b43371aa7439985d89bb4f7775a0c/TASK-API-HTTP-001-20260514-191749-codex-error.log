  return {
    "content-type": "application/json",
    "x-operator-id": "u001",
    "x-tenant-id": "tenant-001",
    "x-role-codes": "EXPORT_ADMIN",
    "x-org-scope": "ORG-001",
    "x-request-id": requestId
  };
}

