+      limit?: number;
+      offset?: number;
+    } = {}): Promise<ExportTaskRecord[]> {
+      let query = db.selectFrom("export_tasks").selectAll();
+
+      if (filters.taskCode) {
+        query = query.where("task_code", "=", filters.taskCode);
+      }
+      if (filters.status) {
