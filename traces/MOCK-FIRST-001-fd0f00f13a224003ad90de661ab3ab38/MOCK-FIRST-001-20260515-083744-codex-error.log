    const requirementId = `FR-${String(index).padStart(3, "0")}`;
    const rowPattern = new RegExp(
      `\\| ${requirementId} \\|[^\\n]*local/dev evidence[^\\n]*\\|[^\\n]*失败态[^\\n]*\\|[^\\n]*(?:不是|不得替代) release evidence`,
