    "QUERY_TEMPLATE_INVALID",
    "sample queryTemplate allowedParameters"
  );

  const fieldMappings = parseJsonValue<Array<Record<string, unknown>>>(
    registry.fieldMappings,
    "FIELD_MAPPING_INVALID",
    "sample fieldMappings"
  );
  assertPropertyNames(
