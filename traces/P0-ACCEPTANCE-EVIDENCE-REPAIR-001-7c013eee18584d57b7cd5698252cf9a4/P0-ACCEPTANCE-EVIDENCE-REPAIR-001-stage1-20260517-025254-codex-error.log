397:function compileDataScopeTemplate(value: string | null, scope: DataScope): CompiledDataScope {
398:  const template = requireText(value, "QUERY_TEMPLATE_INVALID").trim();
399:  if (template.includes(";") || unsafeKeywordPattern.test(template)) {
400:    throw queryError("QUERY_TEMPLATE_INVALID", "dataScopeTemplate contains unsafe SQL");
401:  }
402:  const values: unknown[] = [];
403:  const boundPlaceholders = new Set<string>();
404:  const sql = template.replace(placeholderPattern, (_match, name: string) => {
405:    if (name === "tenantId") {
406:      boundPlaceholders.add(name);
407:      values.push(scope.tenantId);
408:      return "?";
409:    }
410:    if (name === "operatorId") {
411:      boundPlaceholders.add(name);
412:      values.push(scope.operatorId);
413:      return "?";
414:    }
415:    if (name === "roleCodes") {
416:      boundPlaceholders.add(name);
417:      values.push(...scope.roleCodes);
418:      return parameterList(scope.roleCodes.length);
419:    }
420:    if (name === "orgScope") {
421:      boundPlaceholders.add(name);
422:      values.push(...scope.orgScope);
423:      return parameterList(scope.orgScope.length);
424:    }
425:    throw queryError(
426:      "QUERY_TEMPLATE_INVALID",
427:      `dataScopeTemplate placeholder ${name} is not allowed`
428:    );
429:  });
430:  for (const requiredPlaceholder of ["tenantId", "operatorId", "roleCodes", "orgScope"]) {
431:    if (!boundPlaceholders.has(requiredPlaceholder)) {
432:      throw queryError(
433:        "QUERY_TEMPLATE_INVALID",
434:        `dataScopeTemplate must bind ${requiredPlaceholder}`
435:      );
436:    }
437:  }
438:
439:  return {
440:    sql,
441:    values,
442:    scope,
443:    expression: {
444:      template,
445:      operatorId: scope.operatorId,
446:      roleCodes: scope.roleCodes,
447:      orgScope: scope.orgScope
448:    }
449:  };
450:}
