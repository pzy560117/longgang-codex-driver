510:async function collectCompletedRows(input: {
511:  db: Kysely<ExportPlatformDatabase>;
512:  template: QueryTemplate;
513:  queryParams: Record<string, unknown>;
514:  dataScope: CompiledDataScope;
515:  orderBy: OrderByDefinition[];
516:  batchSize: number;
517:  fieldMappings: FieldMapping[];
518:  maskingPolicy: MaskingPolicy;
519:  expectedCount: number;
520:  exportMaxRows: number;
521:}): Promise<Record<string, unknown>[]> {
522:  const rows: Record<string, unknown>[] = [];
523:  let cursorToken: CursorToken | null = null;
524:
525:  while (rows.length < input.expectedCount) {
526:    const compiled = compileQuery({
527:      template: input.template,
528:      queryParams: input.queryParams,
529:      authSnapshot: {},
530:      dataScope: input.dataScope,
531:      lastCursor: cursorToken,
532:      orderBy: input.orderBy,
533:      limit: input.batchSize + 1
534:    });
535:    const rawRows = await executeSelect(input.db, compiled.sqlText, compiled.values);
536:    const limitedRows = rawRows.slice(0, input.batchSize);
537:    validateCursorRows(limitedRows, input.orderBy, cursorToken);
538:
539:    if (limitedRows.length === 0) {
540:      break;
541:    }
542:
543:    rows.push(
544:      ...mapRows({
545:        rows: limitedRows,
546:        mappings: input.fieldMappings,
547:        maskingPolicy: input.maskingPolicy
548:      })
549:    );
550:    if (rows.length > input.exportMaxRows) {
551:      throw queryError("EXPORT_LIMIT_EXCEEDED", "query result exceeds registry exportMaxRows");
552:    }
553:
554:    cursorToken = createCursorToken(limitedRows[limitedRows.length - 1], input.orderBy);
555:    if (rawRows.length <= input.batchSize) {
556:      break;
557:    }
558:  }
559:
560:  if (rows.length !== input.expectedCount) {
561:    throw queryError(
562:      "QUERY_EXECUTION_ERROR",
563:      `completed batch reconstruction mismatch: expected ${input.expectedCount} rows, got ${rows.length}`
564:    );
565:  }
566:
567:  return rows;
568:}
