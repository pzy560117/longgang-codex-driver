749:function validateCursorRows(
750:  rows: Record<string, unknown>[],
751:  orderBy: OrderByDefinition[],
752:  lastCursor: CursorToken | null
753:): void {
754:  let previous = lastCursor;
755:  for (const row of rows) {
756:    const current = createCursorToken(row, orderBy);
757:    if (previous && compareCursorTokens(previous, current, orderBy) >= 0) {
758:      throw queryExecutionError("cursor values are duplicate or non-increasing");
759:    }
760:    previous = current;
761:  }
762:}
763:
764:function compareCursorTokens(
765:  left: CursorToken,
766:  right: CursorToken,
767:  orderBy: OrderByDefinition[]
768:): number {
769:  for (const item of orderBy) {
770:    const leftValue = readCursorField(left, item.field);
771:    const rightValue = readCursorField(right, item.field);
772:    const comparison = compareCursorValues(leftValue, rightValue);
773:    if (comparison === 0) {
774:      continue;
775:    }
776:    return item.direction === "DESC" ? comparison * -1 : comparison;
777:  }
778:  return 0;
779:}
