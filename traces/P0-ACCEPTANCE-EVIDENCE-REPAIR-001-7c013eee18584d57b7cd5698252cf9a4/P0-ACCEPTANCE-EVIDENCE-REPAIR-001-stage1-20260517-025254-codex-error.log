452:function compileQuery(input: {
453:  template: QueryTemplate;
454:  queryParams: Record<string, unknown>;
455:  authSnapshot: AuthSnapshot;
456:  dataScope: CompiledDataScope;
457:  lastCursor: CursorToken | null;
458:  orderBy: OrderByDefinition[];
459:  limit: number;
460:}): { sqlText: string; values: unknown[] } {
461:  const values: unknown[] = [];
462:  const sqlText = input.template.templateText.replace(
463:    placeholderPattern,
464:    (_match, name: string) => {
465:      if (name === "orgScope") {
466:        values.push(...input.dataScope.scope.orgScope);
467:        return parameterList(input.dataScope.scope.orgScope.length);
468:      }
469:      if (name === "tenantId") {
470:        values.push(input.dataScope.scope.tenantId);
471:        return "?";
472:      }
473:      const value = input.queryParams[name] ?? null;
474:      values.push(name === "keyword" && typeof value === "string" ? `%${value}%` : value);
475:      return "?";
476:    }
477:  );
478:
479:  values.push(...input.dataScope.values);
480:
481:  const cursorPredicate = buildCursorPredicate(input.orderBy, input.lastCursor);
482:  values.push(...cursorPredicate.values);
483:
484:  const orderSql = input.orderBy
485:    .map((item) => `${quoteIdentifier(item.field)} ${item.direction}`)
486:    .join(", ");
487:  values.push(input.limit);
488:
489:  return {
490:    sqlText: `SELECT * FROM (${sqlText}) AS export_query WHERE (${input.dataScope.sql})${cursorPredicate.sql} ORDER BY ${orderSql} LIMIT ?`,
491:    values
492:  };
493:}
