 700: function createCursorToken(row: Record<string, unknown>, orderBy: OrderByDefinition[]): CursorToken {
 701:   const values: CursorToken["values"] = {};
 702:   for (const item of orderBy) {
 703:     values[item.field] = normalizeCursorValue(row[item.field], item.field);
 704:   }
 705:   return { version: 1, values };
 706: }
