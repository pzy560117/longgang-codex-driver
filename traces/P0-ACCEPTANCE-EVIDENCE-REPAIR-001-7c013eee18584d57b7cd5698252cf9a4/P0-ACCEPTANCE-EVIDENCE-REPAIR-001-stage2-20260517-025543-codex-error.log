 409:     }
 410:     if (name === "operatorId") {
 411:       boundPlaceholders.add(name);
 412:       values.push(scope.operatorId);
 413:       return "?";
 414:     }
 415:     if (name === "roleCodes") {
 416:       boundPlaceholders.add(name);
 417:       values.push(...scope.roleCodes);
 418:       return parameterList(scope.roleCodes.length);
 419:     }
 420:     if (name === "orgScope") {
 421:       boundPlaceholders.add(name);
 422:       values.push(...scope.orgScope);
 423:       return parameterList(scope.orgScope.length);
 424:     }
 425:     throw queryError(
 426:       "QUERY_TEMPLATE_INVALID",
 427:       `dataScopeTemplate placeholder ${name} is not allowed`
 428:     );
 429:   });
 430:   for (const requiredPlaceholder of ["tenantId", "operatorId", "roleCodes", "orgScope"]) {
 431:     if (!boundPlaceholders.has(requiredPlaceholder)) {
 432:       throw queryError(
