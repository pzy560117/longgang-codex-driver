 660: function dedupeOrderBy(orderBy: OrderByDefinition[]): OrderByDefinition[] {
 661:   const seen = new Set<string>();
 662:   const normalized: OrderByDefinition[] = [];
 663:   for (const item of orderBy) {
 664:     if (seen.has(item.field)) {
 665:       continue;
 666:     }
 667:     seen.add(item.field);
 668:     normalized.push(item);
 669:   }
 670:   return normalized;
 671: }
