 463:     placeholderPattern,
 464:     (_match, name: string) => {
 465:       if (name === "orgScope") {
 466:         values.push(...input.dataScope.scope.orgScope);
 467:         return parameterList(input.dataScope.scope.orgScope.length);
 468:       }
 469:       if (name === "tenantId") {
 470:         values.push(input.dataScope.scope.tenantId);
 471:         return "?";
 472:       }
 473:       const value = input.queryParams[name] ?? null;
 474:       values.push(name === "keyword" && typeof value === "string" ? `%${value}%` : value);
