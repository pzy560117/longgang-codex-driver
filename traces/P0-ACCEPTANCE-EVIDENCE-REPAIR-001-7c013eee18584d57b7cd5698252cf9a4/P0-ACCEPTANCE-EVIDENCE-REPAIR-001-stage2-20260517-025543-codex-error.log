 439:   return {
 440:     sql,
 441:     values,
 442:     scope,
 443:     expression: {
 444:       template,
 445:       operatorId: scope.operatorId,
 446:       roleCodes: scope.roleCodes,
 447:       orgScope: scope.orgScope
