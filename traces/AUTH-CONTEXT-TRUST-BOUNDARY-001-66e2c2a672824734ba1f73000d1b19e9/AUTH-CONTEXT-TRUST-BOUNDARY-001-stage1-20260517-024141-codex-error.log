 139: async function auditAuthContextFailure(
 140:   request: FastifyRequest,
 141:   action: string,
 142:   error: ApiError
 143: ): Promise<void> {
 144:   const requestId = readOptionalHeader(request, "x-request-id");
 145:   if (!requestId) {
 146:     return;
 147:   }
 148: 
 149:   const db = createDatabase();
 150:   try {
 151:     const now = await getDatabaseTime(db);
 152:     await appendAudit({
 153:       db,
 154:       auth: {
 155:         operatorId: readOptionalHeader(request, "x-operator-id") ?? "untrusted",
 156:         tenantId: readOptionalHeader(request, "x-tenant-id") ?? "untrusted",
 157:         roleCodes: [],
 158:         orgScope: readOptionalHeader(request, "x-org-scope") ?? "untrusted",
 159:         requestId
 160:       },
 161:       taskId: null,
 162:       attemptNo: null,
 163:       taskCode: null,
 164:       subsystemCode: null,
 165:       action,
 166:       result: "FAILED",
 167:       errorCode: error.code,
 168:       now
 169:     });
 170:   } catch {
 171:     // Keep authentication failures generic even if audit persistence is unavailable.
 172:   } finally {
 173:     await db.destroy();
 174:   }
 175: }
