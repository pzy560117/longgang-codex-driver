  78: 
  79: function requireAuthContextSigningSecret(): string {
  80:   const secret = process.env.EXPORT_PLATFORM_AUTH_CONTEXT_SIGNING_SECRET;
  81:   if (!secret) {
  82:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
