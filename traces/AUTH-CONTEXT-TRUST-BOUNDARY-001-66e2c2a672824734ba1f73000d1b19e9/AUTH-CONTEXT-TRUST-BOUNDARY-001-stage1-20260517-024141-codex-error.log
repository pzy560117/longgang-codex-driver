  86: 
  87: function createAuthContextSignature(input: {
  88:   operatorId: string;
  89:   tenantId: string;
  90:   roleCodes: string;
  91:   orgScope: string;
  92:   requestId: string;
  93:   issuedAt: string;
  94:   secret: string;
  95: }): string {
  96:   return createHmac("sha256", input.secret)
  97:     .update([
  98:       input.operatorId,
  99:       input.tenantId,
 100:       input.roleCodes,
 101:       input.orgScope,
 102:       input.requestId,
 103:       input.issuedAt
 104:     ].join("\n"))
 105:     .digest("hex");
