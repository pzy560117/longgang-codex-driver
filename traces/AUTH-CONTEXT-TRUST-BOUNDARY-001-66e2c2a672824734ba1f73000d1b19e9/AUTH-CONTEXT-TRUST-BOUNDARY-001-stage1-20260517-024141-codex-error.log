 177: function readAuthContext(request: FastifyRequest): AuthContext {
 178:   const operatorId = readRequiredHeader(request, "x-operator-id");
 179:   const tenantId = readRequiredHeader(request, "x-tenant-id");
 180:   const roleCodesHeader = readRequiredHeader(request, "x-role-codes");
 181:   const orgScope = readRequiredHeader(request, "x-org-scope");
 182:   const requestId = readRequiredHeader(request, "x-request-id");
 183:   const issuedAt = readRequiredHeader(request, "x-auth-context-issued-at");
 184:   const signatureAlgorithm = readRequiredHeader(request, "x-auth-context-signature-algorithm");
 185:   const signature = readRequiredHeader(request, "x-auth-context-signature");
 186:   const roleCodes = roleCodesHeader.split(",").map((role) => role.trim()).filter(Boolean);
 187:   const issuedAtTime = parseIssuedAt(issuedAt);
 188:
 189:   for (const [name, value] of [
 190:     ["operatorId", operatorId],
 191:     ["tenantId", tenantId],
 192:     ["orgScope", orgScope],
 193:     ["requestId", requestId],
 194:     ["issuedAt", issuedAt]
 195:   ] as const) {
 196:     assertValidAuthField(name, value);
 197:   }
 198:
 199:   if (roleCodes.length === 0 || signatureAlgorithm !== "HMAC-SHA256") {
 200:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
 201:   }
 202:
 203:   assertAuthContextFreshness(issuedAtTime);
 204:
 205:   assertValidSignature(
 206:     signature,
 207:     createAuthContextSignature({
 208:       operatorId,
 209:       tenantId,
 210:       roleCodes: roleCodesHeader,
 211:       orgScope,
 212:       requestId,
 213:       issuedAt,
 214:       secret: requireAuthContextSigningSecret()
 215:     })
 216:   );
 217:
 218:   return {
 219:     operatorId,
 220:     tenantId,
 221:     roleCodes,
 222:     orgScope,
 223:     requestId
 224:   };
 225: }
