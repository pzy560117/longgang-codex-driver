  61: function readHeader(request: FastifyRequest, name: string): string | undefined {
  62:   const value = request.headers[name.toLowerCase()];
  63:   return Array.isArray(value) ? value[0] : value;
  64: }
  65: 
  66: function readRequiredHeader(request: FastifyRequest, name: string): string {
