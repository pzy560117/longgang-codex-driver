  71:   throw new Error(`Architecture check failed: ${message}`);
  72: }
  73:
  74: function read(relativePath: string): string {
  75:   return readFileSync(path.join(root, relativePath), "utf8");
  76: }
  77:
  78: function requireFile(relativePath: string): void {
  79:   if (!existsSync(path.join(root, relativePath))) {
  80:     fail(`missing required file ${relativePath}`);
  81:   }
  82: }
  83:
  84: function collectTypeScriptFiles(relativePath: string): string[] {
  85:   const absolutePath = path.join(root, relativePath);
  86:   if (!existsSync(absolutePath)) {
  87:     return [];
  88:   }
  89:
  90:   const stat = statSync(absolutePath);
  91:   if (stat.isFile()) {
  92:     return relativePath.endsWith(".ts") ? [relativePath] : [];
  93:   }
  94:
  95:   const files: string[] = [];
  96:   for (const entry of readdirSync(absolutePath)) {
  97:     files.push(...collectTypeScriptFiles(path.join(relativePath, entry)));
  98:   }
  99:   return files;
 100: }
 101:
 102: function parseOpenApiOperations(openapiText: string): OpenApiOperation[] {
 103:   const operations: OpenApiOperation[] = [];
 104:   let currentPath = "";
 105:   let currentMethod = "";
 106:
 107:   for (const line of openapiText.split(/\r?\n/)) {
 108:     const pathMatch = line.match(/^  (\/[^:]+):\s*$/);
 109:     if (pathMatch) {
 110:       currentPath = pathMatch[1];
 111:       currentMethod = "";
 112:       continue;
 113:     }
 114:
 115:     const methodMatch = line.match(/^    (get|post|put|delete|patch):\s*$/);
 116:     if (methodMatch) {
 117:       currentMethod = methodMatch[1].toUpperCase();
 118:       continue;
 119:     }
 120:
 121:     const operationMatch = line.match(/^\s+operationId:\s*([A-Za-z0-9_]+)\s*$/);
 122:     if (operationMatch && currentPath && currentMethod) {
 123:       operations.push({
 124:         operationId: operationMatch[1],
 125:         method: currentMethod,
 126:         path: `/api${currentPath}`
 127:       });
 128:     }
 129:   }
 130:
 131:   return operations;
 132: }
 133:
 134: function checkPackageScripts(): void {
 135:   const packageJson = JSON.parse(read("package.json")) as { scripts?: Record<string, string> };
 136:   for (const script of requiredScripts) {
 137:     if (!packageJson.scripts?.[script]) {
 138:       fail(`package.json missing script ${script}`);
 139:     }
 140:   }
 141: }
 142:
 143: function checkRequiredFiles(): void {
 144:   for (const relativePath of requiredFiles) {
 145:     requireFile(relativePath);
 146:   }
 147: }
 148:
 149: function checkNoForbiddenProductionReferences(): void {
 150:   const productionFiles = productionScanRoots.flatMap((scanRoot) =>
 151:     collectTypeScriptFiles(scanRoot)
 152:   );
 153:
 154:   checkFilesForForbiddenProductionReferences(productionFiles, read);
 155: }
 156:
 157: function checkFilesForForbiddenProductionReferences(
 158:   relativePaths: string[],
 159:   readFile: (relativePath: string) => string
 160: ): void {
 161:   for (const relativePath of relativePaths) {
 162:     const content = readFile(relativePath);
 163:     if (forbiddenProductionPattern.test(content)) {
 164:       fail(`${relativePath} references forbidden test double terminology`);
 165:     }
 166:   }
 167: }
 168:
 169: function checkOpenApiRouteMapping(): void {
 170:   const operations = parseOpenApiOperations(read("contracts/openapi.yaml"));
 171:   if (operations.length === 0) {
 172:     fail("contracts/openapi.yaml exposes no operationId entries");
 173:   }
 174:
 175:   const routesByOperation = new Map(
 176:     OPENAPI_OPERATION_ROUTES.map((route) => [route.operationId, route])
 177:   );
 178:
 179:   for (const operation of operations) {
 180:     const route = routesByOperation.get(operation.operationId);
 181:     if (!route) {
 182:       fail(`missing route mapping for operationId ${operation.operationId}`);
 183:     }
 184:     if (route.method !== operation.method || route.path !== operation.path) {
 185:       fail(
 186:         `${operation.operationId} route mismatch: expected ${operation.method} ${operation.path}, got ${route.method} ${route.path}`
 187:       );
 188:     }
 189:     requireFile(route.handlerPath);
 190:     if (route.tests.length === 0) {
 191:       fail(`${operation.operationId} has no test mapping`);
 192:     }
 193:     for (const testPath of route.tests) {
 194:       requireFile(testPath);
 195:     }
 196:   }
 197: }
 198:
 199: function checkMigrationCoverage(): void {
 200:   const migration = collectMigrationSql().toLowerCase();
 201:   for (const marker of requiredMigrationMarkers) {
 202:     if (!migration.includes(marker)) {
 203:       fail(`migration missing marker ${marker}`);
 204:     }
 205:   }
 206: }
 207:
 208: function checkSqlMigrationSyntaxGuards(migrationSql: string): void {
 209:   if (/,\s*\);/m.test(migrationSql)) {
 210:     fail("SQL migration contains a dangling comma before table close");
 211:   }
 212: }
 213:
 214: function checkSqlMigrationSyntax(): void {
 215:   checkSqlMigrationSyntaxGuards(collectMigrationSql());
 216: }
 217:
 218: function collectMigrationSql(): string {
 219:   const migrationDir = path.join(root, "migrations");
 220:   return readdirSync(migrationDir)
 221:     .filter((fileName) => fileName.endsWith(".sql"))
 222:     .sort()
 223:     .map((fileName) => read(path.join("migrations", fileName)))
 224:     .join("\n");
 225: }
 226:
 227: function getExpectedDatabaseTableNames(): string[] {
 228:   return [...requiredMigrationMarkers];
 229: }
 230:
 231: function getProductionScanRoots(): string[] {
 232:   return [...productionScanRoots];
 233: }
 234:
 235: function main(): void {
 236:   checkRequiredFiles();
 237:   checkPackageScripts();
 238:   checkOpenApiRouteMapping();
 239:   checkNoForbiddenProductionReferences();
 240:   checkMigrationCoverage();
 241:   checkSqlMigrationSyntax();
 242:
 243:   console.log("Architecture check passed.");
 244: }
 245:
 246: if (process.argv[1] === fileURLToPath(import.meta.url)) {
 247:   main();
 248: }
