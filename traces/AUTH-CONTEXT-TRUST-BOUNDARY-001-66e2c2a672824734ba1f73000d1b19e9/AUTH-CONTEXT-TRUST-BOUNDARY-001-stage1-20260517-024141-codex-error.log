 108: function assertValidSignature(value: string, expected: string): void {
 109:   const signature = Buffer.from(value, "hex");
 110:   const expectedSignature = Buffer.from(expected, "hex");
 111:   if (signature.length !== expectedSignature.length || !timingSafeEqual(signature, expectedSignature)) {
 112:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
 113:   }
 114: }
