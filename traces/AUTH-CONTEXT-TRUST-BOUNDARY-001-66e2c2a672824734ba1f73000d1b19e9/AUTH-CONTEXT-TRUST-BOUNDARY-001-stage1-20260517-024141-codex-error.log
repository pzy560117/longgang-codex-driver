 122: function parseIssuedAt(value: string): number {
 123:   const issuedAtTime = Date.parse(value);
 124:   if (!Number.isFinite(issuedAtTime)) {
 125:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
 126:   }
 127:   return issuedAtTime;
 128: }
 129: 
 130: function assertAuthContextFreshness(issuedAtTime: number, now = Date.now()): void {
 131:   const oldestAcceptedIssuedAt = now - AUTH_CONTEXT_MAX_AGE_MS - AUTH_CONTEXT_CLOCK_SKEW_MS;
 132:   const newestAcceptedIssuedAt = now + AUTH_CONTEXT_CLOCK_SKEW_MS;
 133: 
 134:   if (issuedAtTime < oldestAcceptedIssuedAt || issuedAtTime > newestAcceptedIssuedAt) {
 135:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
 136:   }
 137: }
