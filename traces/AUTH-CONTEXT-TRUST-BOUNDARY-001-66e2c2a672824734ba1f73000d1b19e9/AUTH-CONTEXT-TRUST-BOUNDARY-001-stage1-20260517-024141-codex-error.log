 119: function createHeaders(requestId, overrides = {}) {
 120:   const headers = {
 121:     "content-type": "application/json",
 122:     "x-operator-id": overrides.operatorId ?? "u001",
 123:     "x-tenant-id": overrides.tenantId ?? "tenant-001",
 124:     "x-role-codes": overrides.roleCodes ?? "EXPORT_ADMIN",
 125:     "x-org-scope": overrides.orgScope ?? "ORG-001",
 126:     "x-request-id": requestId,
 127:     "x-auth-context-issued-at": overrides.issuedAt ?? new Date().toISOString(),
 128:     "x-auth-context-signature-algorithm": "HMAC-SHA256"
 129:   };
 130:   headers["x-auth-context-signature"] =
 131:     overrides.signature ?? signAuthContextHeaders(headers, overrides.secret);
 132:   return headers;
 133: }
 134:
 135: function signAuthContextHeaders(headers, secret = authContextSigningSecret) {
 136:   return createHmac("sha256", secret)
 137:     .update([
 138:       headers["x-operator-id"],
 139:       headers["x-tenant-id"],
 140:       headers["x-role-codes"],
 141:       headers["x-org-scope"],
 142:       headers["x-request-id"],
 143:       headers["x-auth-context-issued-at"]
 144:     ].join("\n"))
 145:     .digest("hex");
 146: }
