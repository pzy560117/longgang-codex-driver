    checksumAlgorithm: file.checksumAlgorithm,
    attemptNo: file.attemptNo
  };
}

function requireDownloadSigningSecret(): string {
  const secret = process.env.EXPORT_PLATFORM_DOWNLOAD_URL_SIGNING_SECRET;
  if (!secret) {
    throw new ApiError(
      500,
      "FILE_VERIFY_ERROR",
