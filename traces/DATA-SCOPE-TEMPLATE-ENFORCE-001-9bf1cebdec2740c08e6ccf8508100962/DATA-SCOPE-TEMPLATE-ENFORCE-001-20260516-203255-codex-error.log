        processedCount: 1,
        filePartNo: 1,
        retryCount: 0,
        batchSize: 500,
        batchRowCount: 1,
        backoffMs: 0
      },
      outcome: "completed",
      rows: [{ "Order No": "PO-SNAPSHOT" }]
    }),
    fileService: {
