 122: function createProductionEquivalentObjectStorageAdapter() {
 123:   const objects = new Map();
 124:   const writes = [];
 125:   const publishes = [];
 126: 
 127:   return {
 128:     objects,
 129:     writes,
 130:     publishes,
 131:     async putObject(input) {
 132:       writes.push(input);
 133:       objects.set(input.storageKey, Buffer.from(input.body));
 134:     },
 135:     async readObject(storageKey) {
 136:       const object = objects.get(storageKey);
 137:       if (!object) {
 138:         throw new Error(`missing object ${storageKey}`);
 139:       }
 140:       return Buffer.from(object);
 141:     },
 142:     async publishObject(input) {
 143:       publishes.push(input);
 144:       const object = objects.get(input.tempStorageKey);
 145:       if (!object) {
 146:         throw new Error(`missing temp object ${input.tempStorageKey}`);
 147:       }
 148:       objects.set(input.publishedStorageKey, Buffer.from(object));
 149:     },
 150:     async createDownloadUrl(storageKey) {
 151:       return `signed://adapter/${storageKey}`;
 152:     }
 153:   };
 154: }
