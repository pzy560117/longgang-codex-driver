+  });
+  await seedPurchaseOrders(db, now);
+  const task = await seedTask(db, {
+    taskId: "exp-query-data-scope-missing-auth-placeholders",
+    taskCode,
+    subsystemCode
+  });
+  const processor = createQueryExecutorBatchProcessor();
+
