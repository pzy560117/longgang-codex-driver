function createQueryParamsWithCanonicalSize(size) {
  const prefix = Buffer.byteLength('{"payload":"', "utf8");
  const suffix = Buffer.byteLength('"}', "utf8");
  return {
    payload: "x".repeat(size - prefix - suffix)
  };
}

