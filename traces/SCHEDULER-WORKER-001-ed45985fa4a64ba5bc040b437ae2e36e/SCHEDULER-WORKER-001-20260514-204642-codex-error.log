+  let polling = false;
+
   console.log(
     JSON.stringify({
       event: "export-platform.scheduler.started",
@@ -23,7 +34,33 @@
       leaseModel: runtime.leaseModel
     })
   );
-  return setInterval(() => undefined, runtime.pollIntervalMs);
