  317: function parsePositiveInteger(value: unknown, fallback: number): number {
  318:   if (typeof value !== "string" && typeof value !== "number") {
  319:     return fallback;
  320:   }
  321: 
  322:   const parsed = Number(value);
  323:   if (!Number.isInteger(parsed) || parsed <= 0) {
  324:     return fallback;
  325:   }
  326: 
  327:   return parsed;
  328: }
