  308: function parseDateFilter(value: unknown): Date | undefined {
  309:   if (typeof value !== "string") {
  310:     return undefined;
  311:   }
  312: 
  313:   const date = new Date(value);
  314:   return Number.isNaN(date.getTime()) ? undefined : date;
