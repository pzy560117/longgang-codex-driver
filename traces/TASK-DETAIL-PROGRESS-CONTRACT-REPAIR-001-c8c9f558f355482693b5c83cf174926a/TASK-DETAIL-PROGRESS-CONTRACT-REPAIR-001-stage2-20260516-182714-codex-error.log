 377: function toStorageApiError(error: unknown, file: { checksumAlgorithm: string }): ApiError {
 378:   if (error instanceof ApiError) {
 379:     return error;
 380:   }
 381: 
 382:   if (error instanceof Error && error.name === "EXPORT_RENDER_ERROR") {
 383:     return new ApiError(502, "EXPORT_RENDER_ERROR", error.message);
 384:   }
 385: 
 386:   if (error instanceof Error && error.name === "FILE_VERIFY_ERROR") {
 387:     return new ApiError(500, "FILE_VERIFY_ERROR", error.message, {
 388:       checksumAlgorithm: file.checksumAlgorithm
 389:     });
 390:   }
 391: 
 392:   return new ApiError(500, "FILE_VERIFY_ERROR", "file verification failed", {
 393:     checksumAlgorithm: file.checksumAlgorithm
 394:   });
 395: }
