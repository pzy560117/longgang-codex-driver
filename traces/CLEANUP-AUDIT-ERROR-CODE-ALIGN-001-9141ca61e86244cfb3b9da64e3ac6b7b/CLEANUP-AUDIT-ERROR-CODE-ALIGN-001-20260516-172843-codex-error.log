    '          ? candidate.lock_owner\n' +
    '          : null;\n' +
    '\n' +
    '      await trx\n' +
    '        .updateTable("export_tasks")\n' +
    '        .set({\n' +
    '          status: "EXECUTING",\n' +
    '          lock_owner: input.workerId,\n' +
