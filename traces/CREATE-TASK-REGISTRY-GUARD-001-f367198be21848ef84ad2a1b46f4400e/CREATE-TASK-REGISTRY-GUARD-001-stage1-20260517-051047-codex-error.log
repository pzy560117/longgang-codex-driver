 142: function normalizeCreateTaskQueryParams(value: unknown): Record<string, unknown> {
 143:   if (!value || typeof value !== "object" || Array.isArray(value)) {
 144:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "queryParams must be an object");
 145:   }
 146:   return value as Record<string, unknown>;
 147: }
 148: 
 149: function parseRegistryParameterSchema(schemaPayload: string | null): RegistryParameterSchema {
 150:   const schema = parseRegistryJson<RegistryParameterSchema>(schemaPayload, "parameterSchema");
 151:   if (!schema || typeof schema !== "object" || Array.isArray(schema)) {
 152:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "parameterSchema is invalid");
 153:   }
 154:   if (schema.type && schema.type !== "object") {
 155:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "parameterSchema must describe an object");
 156:   }
 157:   if (schema.required !== undefined && !Array.isArray(schema.required)) {
 158:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "parameterSchema.required must be an array");
 159:   }
 160:   if (
 161:     schema.properties !== undefined &&
 162:     (!schema.properties || typeof schema.properties !== "object" || Array.isArray(schema.properties))
 163:   ) {
 164:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "parameterSchema.properties must be an object");
 165:   }
 166:   return schema;
 167: }
 168: 
 169: function assertRegistryParameterValueType(key: string, value: unknown, expectedType: string): void {
 170:   if (value === undefined || value === null) {
 171:     return;
 172:   }
 173: 
 174:   const valid =
 175:     (expectedType === "string" && typeof value === "string") ||
 176:     (expectedType === "number" && typeof value === "number" && Number.isFinite(value)) ||
 177:     (expectedType === "integer" && Number.isInteger(value)) ||
 178:     (expectedType === "boolean" && typeof value === "boolean") ||
 179:     (expectedType === "object" && typeof value === "object" && !Array.isArray(value)) ||
 180:     (expectedType === "array" && Array.isArray(value));
 181: 
 182:   if (!valid) {
 183:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `parameter ${key} must be a ${expectedType}`);
 184:   }
 185: }
 186: 
 187: function assertRegistryParameterSchema(schemaPayload: string | null, value: unknown): void {
 188:   const queryParams = normalizeCreateTaskQueryParams(value);
 189:   const schema = parseRegistryParameterSchema(schemaPayload);
 190:   const properties = schema.properties ?? {};
 191: 
 192:   for (const required of schema.required ?? []) {
 193:     if (typeof required !== "string") {
 194:       throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "parameterSchema.required must contain strings");
 195:     }
 196:     if (queryParams[required] === undefined || queryParams[required] === null) {
 197:       throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `required parameter ${required} is missing`);
 198:     }
 199:   }
 200: 
 201:   const declaredKeys = new Set(Object.keys(properties));
 202:   for (const key of Object.keys(queryParams)) {
 203:     if (
 204:       (declaredKeys.size > 0 && !declaredKeys.has(key)) ||
 205:       (declaredKeys.size === 0 && schema.additionalProperties === false)
 206:     ) {
 207:       throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `parameter ${key} is not declared`);
 208:     }
 209:   }
 210: 
 211:   for (const [key, definition] of Object.entries(properties)) {
 212:     if (!definition || typeof definition !== "object" || Array.isArray(definition)) {
 213:       throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `parameter ${key} schema is invalid`);
 214:     }
 215:     if (definition.type) {
 216:       assertRegistryParameterValueType(key, queryParams[key], definition.type);
 217:     }
 218:   }
 219: }
