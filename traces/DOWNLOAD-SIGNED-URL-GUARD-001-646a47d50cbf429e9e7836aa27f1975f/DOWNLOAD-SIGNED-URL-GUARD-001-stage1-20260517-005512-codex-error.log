  481: function createPlatformSignedDownloadUrl(input: {
  482:   taskId: string;
  483:   storageKey: string;
  484:   expiresAt: string;
  485:   auth: AuthContext;
  486:   secret: string;
  487: }): string {
  488:   const baseUrl = process.env.EXPORT_PLATFORM_PUBLIC_BASE_URL ?? "http://export-platform.local";
  489:   const url = new URL(`/api/export/tasks/${encodeURIComponent(input.taskId)}/download`, baseUrl);
  490:   const roleCodes = input.auth.roleCodes.join(",");
  491:   url.searchParams.set("mode", "SIGNED_URL");
  492:   url.searchParams.set("expiresAt", input.expiresAt);
  493:   url.searchParams.set("signatureAlgorithm", "HMAC-SHA256");
  494:   url.searchParams.set("operatorId", input.auth.operatorId);
  495:   url.searchParams.set("tenantId", input.auth.tenantId);
  496:   url.searchParams.set("roleCodes", roleCodes);
  497:   url.searchParams.set("orgScope", input.auth.orgScope);
  498:   url.searchParams.set("requestId", input.auth.requestId);
  499:   url.searchParams.set(
  500:     "signature",
  501:     createSignedDownloadSignature({
  502:       taskId: input.taskId,
  503:       storageKey: input.storageKey,
  504:       expiresAt: input.expiresAt,
  505:       operatorId: input.auth.operatorId,
  506:       tenantId: input.auth.tenantId,
  507:       roleCodes,
  508:       orgScope: input.auth.orgScope,
  509:       requestId: input.auth.requestId,
  510:       secret: input.secret
  511:     })
  512:   );
  513:   return url.toString();
  514: }
