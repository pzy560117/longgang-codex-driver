  280: function checksum(body) {
  281:   return `sha256:${createHash("sha256").update(body).digest("hex")}`;
  282: }
  283: 
  284: function signDownloadUrl({ bucket, storageKey, expiresAt, secret }) {
  285:   return createHmac("sha256", secret)
  286:     .update(["GET", bucket, storageKey, expiresAt].join("\n"))
  287:     .digest("hex");
  288: }
  289: 
  290: function verifyDownloadUrl({ bucket, storageKey, expiresAt, signature, secret, now }) {
  291:   if (!expiresAt || !signature) {
  292:     return { valid: false, reason: "SIGNATURE_REQUIRED" };
  293:   }
  294:   const expiresAtTime = Date.parse(expiresAt);
  295:   if (!Number.isFinite(expiresAtTime)) {
  296:     return { valid: false, reason: "SIGNATURE_EXPIRES_AT_INVALID" };
  297:   }
  298:   if (expiresAtTime <= now.getTime()) {
  299:     return { valid: false, reason: "SIGNATURE_EXPIRED" };
  300:   }
  301:   const expected = signDownloadUrl({ bucket, storageKey, expiresAt, secret });
  302:   const expectedBuffer = Buffer.from(expected, "hex");
  303:   const signatureBuffer = Buffer.from(signature, "hex");
  304:   if (
  305:     expectedBuffer.length !== signatureBuffer.length ||
  306:     !timingSafeEqual(expectedBuffer, signatureBuffer)
  307:   ) {
  308:     return { valid: false, reason: "SIGNATURE_INVALID" };
  309:   }
  310:   return { valid: true, reason: "OK" };
  311: }
