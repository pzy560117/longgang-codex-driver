  181: async function createLocalObjectStorageServer(t, options = {}) {
  182:   const bucket = options.bucket ?? "export-platform-test";
  183:   const signingSecret = options.signingSecret ?? downloadSigningSecret;
  184:   const objects = new Map();
  185:   const requests = [];
  186:   const server = http.createServer(async (request, response) => {
  187:     const url = new URL(request.url ?? "/", `http://${request.headers.host ?? "127.0.0.1"}`);
  188:     const pathSegments = url.pathname.split("/").filter(Boolean);
  189:     const requestBucket = pathSegments.shift();
  190:     const storageKey = decodeStorageKey(pathSegments);
  191: 
  192:     if (requestBucket !== bucket || !storageKey) {
  193:       response.statusCode = 404;
  194:       response.end("not found");
  195:       return;
  196:     }
  197: 
  198:     const copySource = request.headers["x-export-copy-source"];
  199:     requests.push({
  200:       method: request.method ?? "GET",
  201:       storageKey,
  202:       pathname: url.pathname,
  203:       search: url.search,
  204:       copySource: typeof copySource === "string" ? copySource : null,
  205:       contentType: request.headers["content-type"] ?? null
  206:     });
  207: 
  208:     if (request.method === "PUT") {
  209:       if (typeof copySource === "string") {
  210:         const [sourceBucket, ...sourceKeySegments] = copySource.split("/");
  211:         const sourceStorageKey = sourceKeySegments.join("/");
  212:         if (sourceBucket !== bucket || !objects.has(sourceStorageKey)) {
  213:           response.statusCode = 404;
  214:           response.end("missing source object");
  215:           return;
  216:         }
  217:         objects.set(storageKey, Buffer.from(objects.get(sourceStorageKey)));
  218:         response.statusCode = 201;
  219:         response.end("copied");
  220:         return;
  221:       }
  222: 
  223:       const body = await readRequestBody(request);
  224:       objects.set(storageKey, body);
  225:       response.statusCode = 201;
  226:       response.end("stored");
  227:       return;
  228:     }
  229: 
  230:     if (request.method === "GET") {
  231:       const internalRead = request.headers["x-export-internal-object-read"] === "true";
  232:       if (!internalRead) {
  233:         const signatureResult = verifyDownloadUrl({
  234:           bucket,
  235:           storageKey,
  236:           expiresAt: url.searchParams.get("expiresAt"),
  237:           signature: url.searchParams.get("signature"),
  238:           secret: signingSecret,
  239:           now: options.now ?? new Date()
  240:         });
  241:         requests[requests.length - 1].signatureResult = signatureResult;
  242:         if (!signatureResult.valid) {
  243:           response.statusCode = 403;
  244:           response.end(signatureResult.reason);
  245:           return;
  246:         }
  247:       }
  248: 
  249:       const body = objects.get(storageKey);
  250:       if (!body) {
  251:         response.statusCode = 404;
  252:         response.end("missing object");
  253:         return;
  254:       }
  255: 
  256:       response.statusCode = 200;
  257:       response.setHeader("content-type", "application/octet-stream");
  258:       response.end(body);
  259:       return;
  260:     }

