  449: function createSignedDownloadSignature(input: {
  450:   taskId: string;
  451:   storageKey: string;
  452:   expiresAt: string;
  453:   operatorId: string;
  454:   tenantId: string;
  455:   roleCodes: string;
  456:   orgScope: string;
  457:   requestId: string;
  458:   secret: string;
  459: }): string {
  460:   return createHmac("sha256", input.secret)
  461:     .update([
  462:       "GET",
  463:       input.taskId,
  464:       input.storageKey,
  465:       input.expiresAt,
  466:       input.operatorId,
  467:       input.tenantId,
  468:       input.roleCodes,
  469:       input.orgScope,
  470:       input.requestId
  471:     ].join("\n"))
  472:     .digest("hex");
  473: }
  474: 
  475: function isValidSignature(value: string, expected: string): boolean {
  476:   const signature = Buffer.from(value, "hex");
  477:   const expectedSignature = Buffer.from(expected, "hex");
  478:   return signature.length === expectedSignature.length && timingSafeEqual(signature, expectedSignature);
  479: }
