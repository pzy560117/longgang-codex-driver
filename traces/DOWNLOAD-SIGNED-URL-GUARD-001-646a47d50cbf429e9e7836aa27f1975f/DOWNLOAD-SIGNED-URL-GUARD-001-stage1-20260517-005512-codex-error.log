  369: function createProductionEquivalentObjectStorageAdapter(options = {}) {
  370:   const objects = new Map();
  371:   const writes = [];
  372:   const publishes = [];
  373:   const deletes = [];
  374: 
  375:   return {
  376:     objects,
  377:     writes,
  378:     publishes,
  379:     deletes,
  380:     async putObject(input) {
  381:       writes.push(input);
  382:       if (options.putError) {
  383:         throw options.putError;
  384:       }
  385:       objects.set(input.storageKey, Buffer.from(input.body));
  386:     },
  387:     async readObject(storageKey) {
  388:       if (options.readError) {
  389:         throw options.readError;
  390:       }
  391:       const object = objects.get(storageKey);
  392:       if (!object) {
  393:         throw new Error(`missing object ${storageKey}`);
  394:       }
  395:       return options.corruptReads ? Buffer.from("corrupted") : Buffer.from(object);
  396:     },
  397:     async publishObject(input) {
  398:       publishes.push(input);
  399:       if (options.publishError) {
  400:         throw options.publishError;
  401:       }
  402:       const object = objects.get(input.tempStorageKey);
  403:       if (!object) {
  404:         throw new Error(`missing temp object ${input.tempStorageKey}`);
  405:       }
  406:       objects.set(input.publishedStorageKey, Buffer.from(object));
  407:     },
  408:     async deleteObject(storageKey) {
  409:       deletes.push(storageKey);
  410:       if (options.deleteError) {
  411:         throw options.deleteError;
  412:       }
  413:       objects.delete(storageKey);
  414:     },
  415:     async createDownloadUrl(storageKey) {
  416:       return `signed://download/${storageKey}`;
  417:     }
  418:   };
  419: }
