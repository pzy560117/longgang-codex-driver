    9: };
   10: 
   11: export class ApiError extends Error {
   12:   constructor(
   13:     public readonly statusCode: number,
   14:     public readonly code: string,
   15:     message: string,
   16:     public readonly data: unknown = null
   17:   ) {
   18:     super(message);
   19:   }
   20: }
   21: 
   22: export function hasRole(auth: AuthContext, roleCode: string): boolean {
   23:   return auth.roleCodes.includes(roleCode);
   24: }
   25: 
   26: export function isExportAdmin(auth: AuthContext): boolean {
   27:   return hasRole(auth, "EXPORT_ADMIN");
   28: }
   29: 
   30: export function assertExportPermission(auth: AuthContext, allowedRoles: string[]): void {
   31:   if (allowedRoles.some((roleCode) => hasRole(auth, roleCode))) {
   32:     return;
   33:   }
   34: 
   35:   throw new ApiError(403, "PERMISSION_DENIED", "operator has no permission", {
   36:     operatorId: auth.operatorId,
   37:     requiredRoles: allowedRoles
   38:   });
   39: }
   40: 
   41: function readHeader(request: FastifyRequest, name: string): string | undefined {
   42:   const value = request.headers[name.toLowerCase()];
   43:   return Array.isArray(value) ? value[0] : value;
   44: }
   45: 
   46: export function requireAuthContext(request: FastifyRequest): AuthContext {
   47:   const operatorId = readHeader(request, "x-operator-id");
   48:   const tenantId = readHeader(request, "x-tenant-id");
   49:   const roleCodes = readHeader(request, "x-role-codes");
   50:   const orgScope = readHeader(request, "x-org-scope");
   51:   const requestId = readHeader(request, "x-request-id");
   52: 
   53:   if (!operatorId || !tenantId || !roleCodes || !orgScope || !requestId) {
   54:     throw new ApiError(401, "AUTH_CONTEXT_MISSING", "auth context missing");
   55:   }
   56: 
   57:   return {
   58:     operatorId,
