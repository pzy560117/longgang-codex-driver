  556:           action: "CREATE",
  557:           now,
  558:           taskCode: body.taskCode ?? null,
  559:           subsystemCode: body.subsystemCode ?? null
  560:         });
  561:       }
  562:       throw error;
  563:     }
  564: 
  565:     if (!body.taskCode || !body.subsystemCode || !body.fileFormat) {
  566:       throw new ApiError(
  567:         400,
  568:         "QUERY_TEMPLATE_INVALID",
  569:         "taskCode, subsystemCode and fileFormat are required"
  570:       );
  571:     }
  572: 
  573:     const registries = createExportRegistryRepository(db);
  574:     const tasks = createExportTaskRepository(db);
  575:     const registry = await registries.findRegistryByTaskCode(body.taskCode);
  576: 
  577:     if (!registry) {
  578:       return rejectWithAudit({
  579:         db,
  580:         auth,
  581:         error: new ApiError(404, "TASK_NOT_REGISTERED", "task code is not registered"),
  582:         action: "CREATE",
  583:         now,
  584:         taskCode: body.taskCode,
  585:         subsystemCode: body.subsystemCode
  586:       });
  587:     }
  588:     if (!registry.enabled) {
  589:       return rejectWithAudit({
  590:         db,
  591:         auth,
  592:         error: new ApiError(400, "TASK_DISABLED", "task code is disabled", {
  593:           taskCode: body.taskCode
  594:         }),
  595:         action: "CREATE",
  596:         now,
  597:         taskCode: body.taskCode,
  598:         subsystemCode: body.subsystemCode
  599:       });
  600:     }
  601: 
  602:     const requestDigest = digest({
  603:       taskCode: body.taskCode,
  604:       subsystemCode: body.subsystemCode,
  605:       fileFormat: body.fileFormat,
  606:       queryParams: body.queryParams ?? null
  607:     });
  608:     const idempotencyScope = body.clientRequestId
  609:       ? `${auth.tenantId}:${auth.operatorId}:${body.taskCode}:${body.clientRequestId}`
  610:       : null;
  611: 
  612:     if (idempotencyScope) {
  613:       const existing = await tasks.findByIdempotencyScope(idempotencyScope);
  614:       if (existing) {
  615:         if (existing.requestDigest !== requestDigest) {
  616:           return rejectWithAudit({
  617:             db,
  618:             auth,
  619:             error: new ApiError(409, "IDEMPOTENCY_CONFLICT", "clientRequestId conflicts", {
  620:               idempotencyScope
  621:             }),
  622:             action: "CREATE",
  623:             now,
  624:             taskCode: body.taskCode,
  625:             subsystemCode: body.subsystemCode
  626:           });
  627:         }
  628: 
  629:         const task = await tasks.findTaskById(existing.taskId);
  630:         if (!task) {
  631:           return rejectWithAudit({
  632:             db,
  633:             auth,
  634:             error: new ApiError(404, "TASK_NOT_FOUND", "task not found"),
  635:             action: "CREATE",
  636:             now,
  637:             taskCode: body.taskCode,
  638:             subsystemCode: body.subsystemCode
  639:           });
  640:         }
  641:         return {
  642:           statusCode: 200,
  643:           data: taskEnvelope(task, { idempotencyHit: true, requestId: auth.requestId })
  644:         };
  645:       }
  646:     }
  647: 
  648:     const task = await tasks.createPendingTask({
  649:       taskId: `exp_${randomUUID()}`,
  650:       taskCode: body.taskCode,
  651:       subsystemCode: body.subsystemCode,
  652:       tenantId: auth.tenantId,
  653:       createdBy: auth.operatorId,
  654:       fileFormat: body.fileFormat,
  655:       clientRequestId: body.clientRequestId ?? null,
  656:       idempotencyScope,
  657:       requestDigest,
  658:       configSnapshotDigest: registry.configSnapshotDigest,
  659:       requestPayload: JSON.stringify({
  660:         fileFormat: body.fileFormat,
  661:         queryParams: body.queryParams ?? null,
  662:         configSnapshot: {
  663:           taskCode: registry.taskCode,
  664:           subsystemCode: registry.subsystemCode,
  665:           displayName: registry.displayName,
  666:           enabled: registry.enabled,
  667:           concurrencyLimit: registry.concurrencyLimit,
  668:           fileRetentionDays: registry.fileRetentionDays,
  669:           taskHistoryRetentionDays: registry.taskHistoryRetentionDays,
  670:           singleFileMaxRows: registry.singleFileMaxRows,
  671:           exportMaxRows: registry.exportMaxRows,
  672:           datasourceCode: registry.datasourceCode,
  673:           supportedFormats: registry.supportedFormats,
  674:           parameterSchema: registry.parameterSchema,
  675:           queryTemplate: registry.queryTemplate,
  676:           fieldMappings: registry.fieldMappings,
  677:           maskingPolicy: registry.maskingPolicy,
  678:           dataScopeTemplate: registry.dataScopeTemplate,
  679:           cursorField: registry.cursorField,
  680:           orderBy: registry.orderBy,
  681:           batchSize: registry.batchSize,
  682:           configSnapshotDigest: registry.configSnapshotDigest
  683:         }
  684:       }),
  685:       authContextPayload: JSON.stringify({
  686:         operatorId: auth.operatorId,
  687:         tenantId: auth.tenantId,
  688:         roleCodes: auth.roleCodes,
  689:         orgScope: auth.orgScope,
  690:         requestId: auth.requestId
  691:       }),
  692:       now
  693:     });
  694: 
  695:     await appendAudit({
  696:       db,
  697:       auth,
  698:       taskId: task.taskId,
  699:       attemptNo: task.attemptNo,
  700:       taskCode: task.taskCode,
  701:       subsystemCode: task.subsystemCode,
  702:       action: "CREATE",
  703:       now
