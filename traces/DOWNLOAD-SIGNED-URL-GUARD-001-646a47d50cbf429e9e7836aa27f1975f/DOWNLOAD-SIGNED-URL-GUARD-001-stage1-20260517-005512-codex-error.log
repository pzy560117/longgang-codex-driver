  340: function signDownloadUrl({ bucket, storageKey, expiresAt, secret }) {
  341:   return createHmac("sha256", secret)
  342:     .update(["GET", bucket, storageKey, expiresAt].join("\n"))
  343:     .digest("hex");
  344: }
  345: 
  346: function verifyDownloadUrl({ bucket, storageKey, expiresAt, signature, secret, now }) {
  347:   if (!expiresAt || !signature) {
  348:     return { valid: false, reason: "SIGNATURE_REQUIRED" };
  349:   }
  350:   const expiresAtTime = Date.parse(expiresAt);
  351:   if (!Number.isFinite(expiresAtTime)) {
  352:     return { valid: false, reason: "SIGNATURE_EXPIRES_AT_INVALID" };
  353:   }
  354:   if (expiresAtTime <= now.getTime()) {
  355:     return { valid: false, reason: "SIGNATURE_EXPIRED" };
  356:   }
  357:   const expected = signDownloadUrl({ bucket, storageKey, expiresAt, secret });
  358:   const expectedBuffer = Buffer.from(expected, "hex");
  359:   const signatureBuffer = Buffer.from(signature, "hex");
  360:   if (
  361:     expectedBuffer.length !== signatureBuffer.length ||
  362:     !timingSafeEqual(expectedBuffer, signatureBuffer)
  363:   ) {
  364:     return { valid: false, reason: "SIGNATURE_INVALID" };
  365:   }
  366:   return { valid: true, reason: "OK" };
  367: }
