  516: function toStorageApiError(error: unknown, file: { checksumAlgorithm: string }): ApiError {
  517:   if (error instanceof ApiError) {
  518:     return error;
  519:   }
  520: 
  521:   if (error instanceof Error && error.name === "EXPORT_RENDER_ERROR") {
  522:     return new ApiError(502, "EXPORT_RENDER_ERROR", error.message);
  523:   }
  524: 
  525:   if (error instanceof Error && error.name === "FILE_VERIFY_ERROR") {
  526:     return new ApiError(500, "FILE_VERIFY_ERROR", error.message, {
  527:       checksumAlgorithm: file.checksumAlgorithm
  528:     });
  529:   }
  530: 
  531:   return new ApiError(500, "FILE_VERIFY_ERROR", "file verification failed", {
  532:     checksumAlgorithm: file.checksumAlgorithm
  533:   });
  534: }
