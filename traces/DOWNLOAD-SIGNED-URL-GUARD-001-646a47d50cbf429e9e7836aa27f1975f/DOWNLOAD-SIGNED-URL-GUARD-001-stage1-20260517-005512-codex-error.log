  865:           now,
  866:           taskId,
  867:           attemptNo: task.attemptNo,
  868:           taskCode: task.taskCode,
  869:           subsystemCode: task.subsystemCode
  870:         });
  871:       }
  872:       throw error;
  873:     }
  874: 
  875:     const file = await createExportFileRepository(db).findFileMetadata(taskId, task.attemptNo);
  876:     if (task.status !== "COMPLETED" || !file || !file.publishedStorageKey || !file.deliveryReadyAt) {
  877:       return rejectWithAudit({
  878:         db,
  879:         auth,
  880:         error: new ApiError(400, "FILE_NOT_READY", "file is not ready"),
  881:         action: "DOWNLOAD",
  882:         now,
  883:         taskId,
  884:         attemptNo: task.attemptNo,
  885:         taskCode: task.taskCode,
  886:         subsystemCode: task.subsystemCode
  887:       });
  888:     }
  889:     if (file.expiresAt <= now) {
  890:       return rejectWithAudit({
  891:         db,
  892:         auth,
  893:         error: new ApiError(410, "FILE_EXPIRED", "file expired"),
  894:         action: "DOWNLOAD",
  895:         now,
  896:         taskId,
  897:         attemptNo: task.attemptNo,
  898:         taskCode: task.taskCode,
  899:         subsystemCode: task.subsystemCode
  900:       });
  901:     }
  902:     if (!file.checksumVerifiedAt || !file.publishedAt) {
  903:       return rejectWithAudit({
  904:         db,
  905:         auth,
  906:         error: new ApiError(500, "FILE_VERIFY_ERROR", "file verification failed", {
  907:           checksumAlgorithm: file.checksumAlgorithm
  908:         }),
  909:         action: "DOWNLOAD",
  910:         now,
  911:         taskId,
  912:         attemptNo: task.attemptNo,
  913:         taskCode: task.taskCode,
  914:         subsystemCode: task.subsystemCode
  915:       });
  916:     }
  917: 
  918:     const fileService = createExportFileService({ db });
  919:     const metadata = toDownloadMetadata(file);
  920:     let responseData: DownloadSignedUrlResponse | DownloadStreamResponse;
  921: 
  922:     try {
  923:       if (deliveryMode === "STREAM") {
  924:         const body = await fileService.readObject(file.publishedStorageKey);
  925:         validateStreamBody(file, body);
  926:         responseData = {
  927:           deliveryMode,
  928:           body,
  929:           ...metadata
  930:         };
  931:       } else {
  932:         const signedDownload = await fileService.createDownloadUrl(file.publishedStorageKey, {
  933:           now
  934:         });
  935:         const downloadUrl = createPlatformSignedDownloadUrl({
  936:           taskId,
  937:           storageKey: file.publishedStorageKey,
  938:           expiresAt: signedDownload.expiresAt.toISOString(),
  939:           auth,
  940:           secret: requireDownloadSigningSecret()
  941:         });
  942:         responseData = {
  943:           deliveryMode,
  944:           downloadUrl,
  945:           ...metadata,
  946:           expiresAt: signedDownload.expiresAt.toISOString()
  947:         };
  948:       }
  949:     } catch (error) {
  950:       return rejectWithAudit({
  951:         db,
  952:         auth,
  953:         error: toStorageApiError(error, file),
  954:         action: "DOWNLOAD",
  955:         now,
  956:         taskId,
  957:         attemptNo: task.attemptNo,
  958:         taskCode: task.taskCode,
  959:         subsystemCode: task.subsystemCode
  960:       });
  961:     }
  962: 
  963:     await appendAudit({
  964:       db,
  965:       auth,
  966:       taskId,
  967:       attemptNo: task.attemptNo,
  968:       taskCode: task.taskCode,
  969:       subsystemCode: task.subsystemCode,
  970:       action: "DOWNLOAD",
  971:       now
  972:     });
  973: 
  974:     return responseData;
  975:   });
  976: }
