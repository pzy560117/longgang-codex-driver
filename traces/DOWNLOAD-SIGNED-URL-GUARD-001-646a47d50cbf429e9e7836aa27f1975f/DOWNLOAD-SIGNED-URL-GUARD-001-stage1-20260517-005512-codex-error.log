  184: async function createLocalObjectStorageServer(t, options = {}) {
  185:   const bucket = options.bucket ?? "export-platform-test";
  186:   const signingSecret = options.signingSecret ?? downloadSigningSecret;
  187:   const clock = options.clock ?? { now: new Date() };
  188:   const objects = new Map();
  189:   const requests = [];
  190:   const server = http.createServer(async (request, response) => {
  191:     const url = new URL(request.url ?? "/", `http://${request.headers.host ?? "127.0.0.1"}`);
  192:     const pathSegments = url.pathname.split("/").filter(Boolean);
  193:     const requestBucket = pathSegments.shift();
  194:     const storageKey = decodeStorageKey(pathSegments);
  195: 
  196:     if (requestBucket !== bucket || !storageKey) {
  197:       response.statusCode = 404;
  198:       response.end("not found");
  199:       return;
  200:     }
  201: 
  202:     requests.push({
  203:       method: request.method ?? "GET",
  204:       storageKey,
  205:       search: url.search,
  206:       internalRead: request.headers["x-export-internal-object-read"] === "true",
  207:       signatureResult: null
  208:     });
  209: 
  210:     if (request.method === "GET") {
  211:       const latestRequest = requests[requests.length - 1];
  212:       if (!latestRequest.internalRead) {
  213:         const signatureResult = verifyDownloadUrl({
  214:           bucket,
  215:           storageKey,
  216:           expiresAt: url.searchParams.get("expiresAt"),
  217:           signature: url.searchParams.get("signature"),
  218:           secret: signingSecret,
  219:           now: clock.now ?? new Date()
  220:         });
  221:         latestRequest.signatureResult = signatureResult;
  222:         if (!signatureResult.valid) {
  223:           response.statusCode = 403;
  224:           response.end(signatureResult.reason);
  225:           return;
  226:         }
  227:       }
  228: 
  229:       const body = objects.get(storageKey);
  230:       if (!body) {
  231:         response.statusCode = 404;
  232:         response.end("missing object");
  233:         return;
  234:       }
  235: 
  236:       response.statusCode = 200;
  237:       response.setHeader("content-type", "application/octet-stream");
  238:       response.end(body);
  239:       return;
  240:     }
  241: 
  242:     response.statusCode = 405;
  243:     response.end("method not allowed");
  244:   });
  245: 
  246:   server.listen(0, "127.0.0.1");
  247:   await once(server, "listening");
  248: 
  249:   t.after(
  250:     () =>
  251:       new Promise((resolve, reject) => {
  252:         server.close((error) => {
  253:           if (error) {
  254:             reject(error);
  255:             return;
  256:           }
  257:           resolve();
  258:         });
  259:       })
  260:   );

