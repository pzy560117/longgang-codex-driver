  837: export async function downloadExportTask(
  838:   auth: AuthContext,
  839:   taskId: string,
  840:   requestedMode?: string
  841: ): Promise<DownloadSignedUrlResponse | DownloadStreamResponse> {
  842:   return withDatabase(async (db) => {
  843:     const now = await getDatabaseTime(db);
  844:     const deliveryMode = resolveDownloadMode(requestedMode);
  845:     const task = await createExportTaskRepository(db).findTaskById(taskId);
  846:     if (!task) {
  847:       return rejectWithAudit({
  848:         db,
  849:         auth,
  850:         error: new ApiError(404, "TASK_NOT_FOUND", "task not found"),
  851:         action: "DOWNLOAD",
  852:         now,
  853:         taskId
  854:       });
  855:     }
  856:     try {
  857:       assertTaskVisible(auth, task);
