  167: function resolveTotalCount(input: {
  168:   task: ExportTaskRecord;
  169:   checkpoint: CheckpointRecord | undefined;
  170:   events: TaskEventRecord[];
  171: }): number {
  172:   const eventTotal = input.events.reduce<number | null>((current, event) => {
  173:     const checkpoint = parseJsonRecord(event.batchCheckpoint);
  174:     const totalCount = readNonNegativeInteger(checkpoint?.totalCount);
  175:     if (totalCount !== null) {
  176:       return current === null ? totalCount : Math.max(current, totalCount);
  177:     }
  178:     return current;
  179:   }, null);
  180: 
  181:   if (eventTotal !== null) {
  182:     return eventTotal;
  183:   }
  184: 
  185:   if (input.task.status === "COMPLETED") {
  186:     return input.checkpoint?.processedCount ?? 0;
  187:   }
  188: 
  189:   return 0;
  190: }
  191: 
  192: function resolveProcessedCount(input: {
  193:   task: ExportTaskRecord;
  194:   checkpoint: CheckpointRecord | undefined;
  195:   totalCount: number;
  196: }): number {
  197:   const checkpointCount = input.checkpoint?.processedCount ?? 0;
  198:   if (input.totalCount > 0) {
  199:     return Math.min(checkpointCount, input.totalCount);
  200:   }
  201: 
  202:   if (input.task.status === "COMPLETED" && checkpointCount === 0) {
  203:     return input.totalCount;
  204:   }
  205: 
  206:   return checkpointCount;
  207: }
  208: 
  209: function resolveProgressPercent(input: {
  210:   task: ExportTaskRecord;
  211:   processedCount: number;
  212:   totalCount: number;
  213: }): number {
  214:   if (input.totalCount > 0) {
  215:     return clampProgressPercent((input.processedCount / input.totalCount) * 100);
  216:   }
  217: 
  218:   if (input.task.status === "COMPLETED") {
  219:     return 100;
  220:   }
  221: 
  222:   return 0;
  223: }
