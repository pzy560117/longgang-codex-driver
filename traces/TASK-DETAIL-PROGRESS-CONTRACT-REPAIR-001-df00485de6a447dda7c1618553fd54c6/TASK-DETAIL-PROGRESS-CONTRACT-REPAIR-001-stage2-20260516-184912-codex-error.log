  117:   if (typeof value !== "number" || !Number.isFinite(value)) {
  118:     return null;
  119:   }
  120: 
  121:   if (value < 0) {
  122:     return null;
  123:   }
  124: 
  125:   return Math.trunc(value);
  126: }
  127: 
  128: function readNonEmptyString(value: unknown): string | null {
  129:   if (typeof value !== "string" || value.trim() === "") {
  130:     return null;
  131:   }
  132: 
  133:   return value;
  134: }
  135: 
  136: function clampProgressPercent(value: number): number {
  137:   if (!Number.isFinite(value)) {
  138:     return 0;
  139:   }
  140: 
  141:   return Math.min(100, Math.max(0, Number(value.toFixed(2))));
  142: }
  143: 
  144: function responseCodeMessage(code: string | null): string | null {
  145:   switch (code) {
  146:     case "QUERY_EXECUTION_ERROR":
  147:       return "query execution error";
  148:     case "DATASOURCE_UNAVAILABLE":
  149:       return "datasource unavailable";
  150:     case "QUERY_TEMPLATE_INVALID":
  151:       return "query template invalid";
  152:     case "FIELD_MAPPING_INVALID":
  153:       return "field mapping invalid";
  154:     case "MASKING_RULE_ERROR":
  155:       return "masking rule error";
  156:     case "EXPORT_RENDER_ERROR":
  157:       return "export render error";
  158:     case "FILE_VERIFY_ERROR":
  159:       return "file verification failed";
  160:     case "EXPORT_LIMIT_EXCEEDED":
  161:       return "export limit exceeded";
  162:     default:
  163:       return null;
  164:   }
  165: }
