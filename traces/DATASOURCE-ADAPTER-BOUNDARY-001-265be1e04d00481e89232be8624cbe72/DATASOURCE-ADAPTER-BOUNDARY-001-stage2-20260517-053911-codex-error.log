 771: function readCursorField(
 772:   token: CursorToken,
 773:   field: string
 774: ): string | number | boolean | null {
 775:   if (!(field in token.values)) {
 776:     throw queryExecutionError(`cursor field ${field} is missing from checkpoint`);
 777:   }
 778:   return token.values[field] ?? null;
 779: }
