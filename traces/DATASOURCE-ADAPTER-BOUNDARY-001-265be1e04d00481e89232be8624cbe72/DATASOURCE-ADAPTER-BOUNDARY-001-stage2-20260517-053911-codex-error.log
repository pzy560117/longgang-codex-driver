 740: function buildCursorPredicate(
 741:   orderBy: OrderByDefinition[],
 742:   lastCursor: CursorToken | null
 743: ): { sql: string; values: Array<string | number | boolean | null> } {
 744:   if (!lastCursor) {
 745:     return { sql: "", values: [] };
 746:   }
 747: 
 748:   const clauses: string[] = [];
 749:   const values: Array<string | number | boolean | null> = [];
 750:   for (let index = 0; index < orderBy.length; index += 1) {
 751:     const andParts: string[] = [];
 752:     for (let prefixIndex = 0; prefixIndex < index; prefixIndex += 1) {
 753:       const prefixField = orderBy[prefixIndex].field;
 754:       andParts.push(`${quoteIdentifier(prefixField)} = ?`);
 755:       values.push(readCursorField(lastCursor, prefixField));
 756:     }
 757:     const field = orderBy[index].field;
 758:     andParts.push(
 759:       `${quoteIdentifier(field)} ${orderBy[index].direction === "DESC" ? "<" : ">"} ?`
 760:     );
 761:     values.push(readCursorField(lastCursor, field));
 762:     clauses.push(`(${andParts.join(" AND ")})`);
 763:   }
 764: 
 765:   return {
 766:     sql: ` AND (${clauses.join(" OR ")})`,
 767:     values
 768:   };
 769: }
