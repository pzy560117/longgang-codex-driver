 775: function leaseLostError(message: string): Error {
 776:   const error = new Error(message);
 777:   error.name = "WORKER_LEASE_LOST";
 778:   return error;
 779: }
 780: 
 781: function isLeaseLostError(error: unknown): boolean {
 782:   return error instanceof Error && error.name === "WORKER_LEASE_LOST";
 783: }
 784: 
 785: function isRetryableBatchError(error: unknown): boolean {
 786:   return (
 787:     error instanceof Error &&
 788:     ["QUERY_EXECUTION_ERROR", "DATASOURCE_UNAVAILABLE"].includes(error.name)
 789:   );
 790: }
 791: 
 792: function resolveTaskRegistrySnapshot(task: ExportTaskRecord): ExportRegistryRecord | undefined {
 793:   const snapshot = parseTaskRequestSnapshot(task).configSnapshot;
 794:   if (snapshot?.configSnapshotDigest === task.configSnapshotDigest) {
 795:     return snapshot;
 796:   }
 797:   return undefined;
 798: }
 799: 
 800: function resolveTaskConcurrencyLimit(task: ExportTaskRecord): number {
 801:   const registry = resolveTaskRegistrySnapshot(task);
 802:   return Number.isInteger(registry?.concurrencyLimit) && Number(registry?.concurrencyLimit) > 0
 803:     ? Number(registry?.concurrencyLimit)
 804:     : 1;
 805: }
 806: 
 807: function parseTaskRequestSnapshot(task: ExportTaskRecord): TaskRequestSnapshot {
 808:   if (!task.requestPayload) {
 809:     return {};
 810:   }
 811:   try {
 812:     const parsed = JSON.parse(task.requestPayload) as TaskRequestSnapshot;
 813:     return parsed && typeof parsed === "object" ? parsed : {};
 814:   } catch {
 815:     return {};
 816:   }
 817: }
 818: 
 819: function calculateBackoffMs(baseMs: number, retryCount: number): number {
 820:   const normalizedBase = Number.isInteger(baseMs) && baseMs > 0 ? baseMs : 1000;
 821:   return normalizedBase * 2 ** Math.max(0, retryCount - 1);
 822: }
 823: 
 824: function toUpdatedRowCount(value: bigint | number | undefined): number {
 825:   if (typeof value === "bigint") {
 826:     return Number(value);
 827:   }
 828:   return Number(value ?? 0);
 829: }

