 705: function decodeCursorToken(
 706:   lastCursor: string | null,
 707:   orderBy: OrderByDefinition[]
 708: ): CursorToken | null {
 709:   if (!lastCursor) {
 710:     return null;
 711:   }
 712:   try {
 713:     const parsed = JSON.parse(lastCursor) as CursorToken;
 714:     if (parsed?.version === 1 && parsed.values && typeof parsed.values === "object") {
 715:       return parsed;
 716:     }
 717:   } catch {
 718:     // Older checkpoints only persist the terminal cursor field value.
 719:   }
 720:   return {
 721:     version: 1,
 722:     values: {
 723:       [orderBy[orderBy.length - 1].field]: lastCursor
 724:     }
 725:   };
 726: }
 727: 
 728: function encodeCursorToken(token: CursorToken): string {
 729:   return JSON.stringify(token);
 730: }
