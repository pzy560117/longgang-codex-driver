 854:   const day = String(value.getDate()).padStart(2, "0");
 855:   const hours = String(value.getHours()).padStart(2, "0");
 856:   const minutes = String(value.getMinutes()).padStart(2, "0");
 857:   const seconds = String(value.getSeconds()).padStart(2, "0");
 858:   const milliseconds = String(value.getMilliseconds()).padStart(3, "0");
 859:   return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}.${milliseconds}`;
 860: }
