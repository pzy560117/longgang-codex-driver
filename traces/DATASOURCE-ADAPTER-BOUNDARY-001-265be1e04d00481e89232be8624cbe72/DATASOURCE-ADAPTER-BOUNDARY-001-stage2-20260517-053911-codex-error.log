 732: function createCursorToken(row: Record<string, unknown>, orderBy: OrderByDefinition[]): CursorToken {
 733:   const values: CursorToken["values"] = {};
 734:   for (const item of orderBy) {
 735:     values[item.field] = normalizeCursorValue(row[item.field], item.field);
 736:   }
 737:   return { version: 1, values };
 738: }
