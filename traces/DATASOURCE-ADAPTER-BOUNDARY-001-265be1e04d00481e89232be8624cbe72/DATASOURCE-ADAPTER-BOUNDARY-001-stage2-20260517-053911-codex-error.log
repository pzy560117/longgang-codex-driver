 894: export function mapDatasourceAdapterError(error: unknown): Error {
 895:   const code = readErrorCode(error);
 896:   if (
 897:     [
 898:       "ECONNREFUSED",
 899:       "ECONNRESET",
 900:       "ENOTFOUND",
 901:       "ETIMEDOUT",
 902:       "EHOSTUNREACH",
 903:       "PROTOCOL_CONNECTION_LOST",
 904:       "ER_ACCESS_DENIED_ERROR",
 905:       "ER_DBACCESS_DENIED_ERROR",
 906:       "ER_ACCESS_DENIED_NO_PASSWORD_ERROR",
 907:       "ER_CON_COUNT_ERROR",
 908:       "ERR_INVALID_ARG_TYPE",
 909:       "ERR_INVALID_URL"
 910:     ].includes(code)
 911:   ) {
 912:     return queryError("DATASOURCE_UNAVAILABLE", "datasource unavailable");
 913:   }
 914: 
 915:   if (error instanceof TypeError || error instanceof RangeError) {
 916:     return queryError("DATASOURCE_UNAVAILABLE", "datasource unavailable");
 917:   }
 918: 
 919:   if (error instanceof Error && error.name === "DATASOURCE_UNAVAILABLE") {
 920:     return queryError("DATASOURCE_UNAVAILABLE", "datasource unavailable");
 921:   }
 922: 
 923:   return queryExecutionError("query execution failed");
 924: }
