 692: function dedupeOrderBy(orderBy: OrderByDefinition[]): OrderByDefinition[] {
 693:   const seen = new Set<string>();
 694:   const normalized: OrderByDefinition[] = [];
 695:   for (const item of orderBy) {
 696:     if (seen.has(item.field)) {
 697:       continue;
 698:     }
 699:     seen.add(item.field);
 700:     normalized.push(item);
