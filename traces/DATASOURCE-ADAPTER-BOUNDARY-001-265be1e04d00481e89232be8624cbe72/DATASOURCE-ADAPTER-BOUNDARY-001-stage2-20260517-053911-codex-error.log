 716: async function hasAcceptedCancelRequest(
 717:   db: Kysely<ExportPlatformDatabase>,
 718:   taskId: string,
 719:   attemptNo: number
 720: ): Promise<boolean> {
 721:   const row = await db
 722:     .selectFrom("export_audit_logs")
 723:     .select((eb) => eb.fn.count<number>("audit_id").as("cancel_count"))
 724:     .where("task_id", "=", taskId)
 725:     .where("attempt_no", "=", attemptNo)
 726:     .where("action", "=", "CANCEL_REQUEST")
 727:     .where("result", "=", "ACCEPTED")
 728:     .executeTakeFirst();
 729: 
 730:   return Number(row?.cancel_count ?? 0) > 0;
 731: }
