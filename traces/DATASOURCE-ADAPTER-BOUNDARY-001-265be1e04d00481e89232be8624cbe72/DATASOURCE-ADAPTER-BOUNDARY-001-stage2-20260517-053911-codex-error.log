 277: function parseJson<T>(value: string | null | undefined, code: string): T {
 278:   if (!value) {
 279:     throw queryError(code, "required JSON snapshot is missing");
 280:   }
 281:   try {
 282:     return JSON.parse(value) as T;
 283:   } catch {
 284:     throw queryError(code, "required JSON snapshot is invalid");
 285:   }
 286: }
