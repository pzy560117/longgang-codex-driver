 781: function validateCursorRows(
 782:   rows: Record<string, unknown>[],
 783:   orderBy: OrderByDefinition[],
 784:   lastCursor: CursorToken | null
 785: ): void {
 786:   let previous = lastCursor;
 787:   for (const row of rows) {
 788:     const current = createCursorToken(row, orderBy);
 789:     if (previous && compareCursorTokens(previous, current, orderBy) >= 0) {
 790:       throw queryExecutionError("cursor values are duplicate or non-increasing");
 791:     }
 792:     previous = current;
 793:   }
 794: }
 795: 
 796: function compareCursorTokens(
 797:   left: CursorToken,
 798:   right: CursorToken,
 799:   orderBy: OrderByDefinition[]
 800: ): number {
 801:   for (const item of orderBy) {
 802:     const leftValue = readCursorField(left, item.field);
 803:     const rightValue = readCursorField(right, item.field);
 804:     const comparison = compareCursorValues(leftValue, rightValue);
 805:     if (comparison === 0) {
 806:       continue;
 807:     }
 808:     return item.direction === "DESC" ? comparison * -1 : comparison;
 809:   }
 810:   return 0;
 811: }
 812: 
 813: function compareCursorValues(
 814:   left: string | number | boolean | null,
 815:   right: string | number | boolean | null
 816: ): number {
 817:   if (left === right) {
 818:     return 0;
 819:   }
 820:   if (left === null || right === null) {
 821:     throw queryExecutionError("cursor field is missing or null");
 822:   }
 823:   if (typeof left === "number" && typeof right === "number") {
 824:     return left < right ? -1 : 1;
 825:   }
 826:   const leftText = String(left);
 827:   const rightText = String(right);
 828:   return leftText.localeCompare(rightText);
 829: }
