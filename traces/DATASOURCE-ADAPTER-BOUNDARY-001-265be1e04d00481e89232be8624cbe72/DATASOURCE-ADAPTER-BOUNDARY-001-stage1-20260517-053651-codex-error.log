          takeoverRule: "PENDING_OR_EXPIRED_KEEP_ATTEMPT"
        },
        checkpoint: undefined,
        requestId: "req-query-adapter-provider-throws"
      }),
    (error) => {
      assert.equal(error.name, "DATASOURCE_UNAVAILABLE");
