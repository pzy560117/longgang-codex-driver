  632:       subsystemCode: typeof query.subsystemCode === "string" ? query.subsystemCode : undefined,
  633:       tenantId: isExportAdmin(auth) ? undefined : auth.tenantId,
  634:       createdBy,
  635:       fileFormat: typeof query.fileFormat === "string" ? query.fileFormat : undefined,
  636:       createdAtFrom: parseDateFilter(query.createdAtFrom),
