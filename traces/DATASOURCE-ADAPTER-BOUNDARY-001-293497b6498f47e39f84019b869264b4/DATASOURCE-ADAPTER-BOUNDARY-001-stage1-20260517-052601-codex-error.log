170:function checkOpenApiRouteMapping(): void {
171:  const operations = parseOpenApiOperations(read("contracts/openapi.yaml"));
172:  if (operations.length === 0) {
173:    fail("contracts/openapi.yaml exposes no operationId entries");
174:  }
175:
176:  const routesByOperation = new Map(
177:    OPENAPI_OPERATION_ROUTES.map((route) => [route.operationId, route])
178:  );
179:
180:  for (const operation of operations) {
181:    const route = routesByOperation.get(operation.operationId);
182:    if (!route) {
183:      fail(`missing route mapping for operationId ${operation.operationId}`);
184:    }
185:    if (route.method !== operation.method || route.path !== operation.path) {
186:      fail(
187:        `${operation.operationId} route mismatch: expected ${operation.method} ${operation.path}, got ${route.method} ${route.path}`
188:      );
189:    }
190:    requireFile(route.handlerPath);
191:    if (route.tests.length === 0) {
192:      fail(`${operation.operationId} has no test mapping`);
193:    }
194:    for (const testPath of route.tests) {
195:      requireFile(testPath);
196:    }
197:  }
198:}
199:
200:function checkMigrationCoverage(): void {
201:  const migration = collectMigrationSql().toLowerCase();
202:  for (const marker of requiredMigrationMarkers) {
203:    if (!migration.includes(marker)) {
204:      fail(`migration missing marker ${marker}`);
205:    }
206:  }
207:}
208:
209:function checkSqlMigrationSyntaxGuards(migrationSql: string): void {
210:  if (/,\s*\);/m.test(migrationSql)) {
211:    fail("SQL migration contains a dangling comma before table close");
212:  }
213:}
214:
215:function checkSqlMigrationSyntax(): void {
216:  checkSqlMigrationSyntaxGuards(collectMigrationSql());
217:}
218:
219:function collectMigrationSql(): string {
220:  const migrationDir = path.join(root, "migrations");
221:  return readdirSync(migrationDir)
222:    .filter((fileName) => fileName.endsWith(".sql"))
223:    .sort()
224:    .map((fileName) => read(path.join("migrations", fileName)))
225:    .join("\n");
226:}
227:
228:function getExpectedDatabaseTableNames(): string[] {
229:  return [...requiredMigrationMarkers];
230:}
231:
232:function getProductionScanRoots(): string[] {
233:  return [...productionScanRoots];
234:}
235:
236:function main(): void {
237:  checkRequiredFiles();
238:  checkPackageScripts();
239:  checkOpenApiRouteMapping();
240:  checkNoForbiddenProductionReferences();
241:  checkMigrationCoverage();
242:  checkSqlMigrationSyntax();
243:
244:  console.log("Architecture check passed.");
245:}
246:
247:if (process.argv[1] === fileURLToPath(import.meta.url)) {
248:  main();
249:}
250:
251:export {
252:  checkMigrationCoverage,
253:  checkFilesForForbiddenProductionReferences,
254:  checkNoForbiddenProductionReferences,
255:  checkOpenApiRouteMapping,
256:  checkPackageScripts,
257:  checkRequiredFiles,
258:  checkSqlMigrationSyntaxGuards,
259:  collectMigrationSql,
260:  getExpectedDatabaseTableNames,
261:  getProductionScanRoots,
262:  parseOpenApiOperations
263:};

