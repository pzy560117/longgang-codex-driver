263:async function resolveTaskRegistrySnapshot(
264:  context: SchedulerBatchContext,
265:  requestSnapshot: RequestSnapshot
266:): Promise<ExportRegistryRecord | undefined> {
267:  if (
268:    requestSnapshot.configSnapshot &&
269:    requestSnapshot.configSnapshot.configSnapshotDigest === context.task.configSnapshotDigest
270:  ) {
