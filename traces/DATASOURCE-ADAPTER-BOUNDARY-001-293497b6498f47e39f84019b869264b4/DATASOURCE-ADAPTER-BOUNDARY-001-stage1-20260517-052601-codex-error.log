1:import mysql from "mysql2/promise";
2:
3:export type ReadonlyDatasourceAdapter = {
4:  executeSelect(
5:    sqlText: string,
6:    values: readonly unknown[]
7:  ): Promise<Record<string, unknown>[]>;
8:};
9:
10:export type ReadonlyDatasourceAdapterProvider = {
11:  resolveReadonlyAdapter(
12:    datasourceCode: string
13:  ): Promise<ReadonlyDatasourceAdapter | undefined>;
14:};
15:
16:type DatasourceUrlMap = Record<string, string | { url?: string }>;
17:
18:export function createEnvReadonlyDatasourceAdapterProvider(input?: {
19:  env?: NodeJS.ProcessEnv;
20:}): ReadonlyDatasourceAdapterProvider {
21:  const env = input?.env ?? process.env;
22:  return {
23:    async resolveReadonlyAdapter(datasourceCode) {
24:      const datasourceUrl = resolveDatasourceUrl(env, datasourceCode);
25:      if (!datasourceUrl) {
26:        return undefined;
27:      }
28:      return createMysqlReadonlyDatasourceAdapter(datasourceUrl);
29:    }
30:  };
31:}
32:
33:export function createMysqlReadonlyDatasourceAdapter(
34:  datasourceUrl: string
35:): ReadonlyDatasourceAdapter {
36:  return {
37:    async executeSelect(sqlText, values) {
38:      const connection = await mysql.createConnection(datasourceUrl);
39:      try {
40:        await connection.query("SET TRANSACTION READ ONLY");
41:        await connection.beginTransaction();
42:        const [rows] = await connection.query(sqlText, [...values]);
43:        await connection.commit();
44:        return Array.isArray(rows) ? (rows as Record<string, unknown>[]) : [];
45:      } catch (error) {
46:        try {
47:          await connection.rollback();
48:        } catch {
49:          // The original datasource error is more useful to the caller.
50:        }
51:        throw error;
52:      } finally {
53:        await connection.end();
54:      }
55:    }
56:  };
57:}
58:
59:function resolveDatasourceUrl(
60:  env: NodeJS.ProcessEnv,
61:  datasourceCode: string
62:): string | undefined {
63:  const directKey = `EXPORT_PLATFORM_DATASOURCE_${toEnvKey(datasourceCode)}_URL`;
64:  const direct = env[directKey];
65:  if (direct) {
66:    return direct;
67:  }
68:
69:  const mapped = resolveDatasourceUrlFromMap(env.EXPORT_PLATFORM_DATASOURCES_JSON, datasourceCode);
70:  if (mapped) {
71:    return mapped;
72:  }
73:
74:  return undefined;
75:}
76:
77:function resolveDatasourceUrlFromMap(
78:  payload: string | undefined,
79:  datasourceCode: string
80:): string | undefined {
81:  if (!payload) {
82:    return undefined;
83:  }
84:
85:  try {
86:    const parsed = JSON.parse(payload) as DatasourceUrlMap;
87:    const value = parsed[datasourceCode];
88:    if (typeof value === "string") {
89:      return value;
90:    }
91:    return typeof value?.url === "string" ? value.url : undefined;
92:  } catch {
93:    return undefined;
94:  }
95:}
96:
97:function toEnvKey(datasourceCode: string): string {
98:  return datasourceCode
99:    .trim()
100:    .toUpperCase()
101:    .replace(/[^A-Z0-9]+/g, "_")
102:    .replace(/^_+|_+$/g, "");
103:}

