226:    await appendQueryEvent({
227:      context,
228:      eventType: "QUERY_READY",
229:      datasourceCode: registry.datasourceCode,
230:      queryTemplateVersion: template.queryTemplateVersion ?? context.task.configSnapshotDigest,
231:      batchCheckpoint: {
232:        taskId: context.task.taskId,
233:        attemptNo: context.lease.attemptNo,
234:        requestId: context.requestId,
235:        datasourceCode: registry.datasourceCode,
236:        queryTemplateVersion: template.queryTemplateVersion ?? null,
237:        dataScopeExpression: dataScope.expression
238:      },
239:      now
240:    });
241:
242:    await appendQueryEvent({
243:      context,
244:      eventType: "QUERY_BATCH_DONE",
245:      datasourceCode: registry.datasourceCode,
246:      queryTemplateVersion: template.queryTemplateVersion ?? context.task.configSnapshotDigest,
247:      batchCheckpoint: {
248:        ...checkpoint,
249:        dataScopeExpression: dataScope.expression
250:      },
251:      now: batchEventTime
252:    });
253:
254:    return {
255:      rows,
256:      checkpoint,
257:      outcome,
258:      registry
259:    };
260:  };
261:}
