103:function parseOpenApiOperations(openapiText: string): OpenApiOperation[] {
104:  const operations: OpenApiOperation[] = [];
105:  let currentPath = "";
106:  let currentMethod = "";
107:
108:  for (const line of openapiText.split(/\r?\n/)) {
109:    const pathMatch = line.match(/^  (\/[^:]+):\s*$/);
110:    if (pathMatch) {
111:      currentPath = pathMatch[1];
112:      currentMethod = "";
113:      continue;
