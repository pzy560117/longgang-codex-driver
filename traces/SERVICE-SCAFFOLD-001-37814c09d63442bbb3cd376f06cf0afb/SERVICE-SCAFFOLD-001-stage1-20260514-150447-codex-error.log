65: function parseOpenApiOperations(openapiText: string): OpenApiOperation[] {
66:   const operations: OpenApiOperation[] = [];
67:   let currentPath = "";
68:   let currentMethod = "";
69: 
70:   for (const line of openapiText.split(/\r?\n/)) {
71:     const pathMatch = line.match(/^  (\/[^:]+):\s*$/);
72:     if (pathMatch) {
73:       currentPath = pathMatch[1];
74:       currentMethod = "";
75:       continue;
76:     }
77: 
78:     const methodMatch = line.match(/^    (get|post|put|delete|patch):\s*$/);
79:     if (methodMatch) {
80:       currentMethod = methodMatch[1].toUpperCase();
81:       continue;
82:     }
83: 
84:     const operationMatch = line.match(/^\s+operationId:\s*([A-Za-z0-9_]+)\s*$/);
85:     if (operationMatch && currentPath && currentMethod) {
86:       operations.push({
87:         operationId: operationMatch[1],
88:         method: currentMethod,
89:         path: `/api${currentPath}`
90:       });
91:     }
92:   }
93: 
94:   return operations;
95: }
