       processedCount:\\n          type: integer\\n          format: int64\\n        filePartNo:\\n          type: integer\\n        attemptNo:\\n          type: integer\\n        batchSize:\\n          type: integer\\n        batchRowCount:\\n          type: integer\\n        retryCount:\\n          type: integer\\n        backoffMs:\\n          type: integer\\n        lockOwner:\\n          type: string\\n          description: Worker identity that owns the database lease for the current attempt.\\n        lockExpireAt:\\n          type: string\\n          format: date-time\\n          description: Lease expiry based on database time; default lease is five minutes unless registry config overrides it.\\n        leaseRenewedAt:\\n          type: string\\n          format: date-time\\n          description: Last successful lease renewal time based on database time.\\n        databaseTime:\\n          type: string\\n          format: date-time\\n          description: Database clock snapshot used for lock acquisition, renewal and takeover decisions.\\n        takeoverRule:\\n          type: string\\n          description: Workers may take over only after database time is later than lockExpireAt; takeover keeps the same attemptNo.\\n    AuditEvent:\\n      type: object\\n      required:\\n        - taskId\\n        - taskCode\\n        - subsystemCode\\n        - operatorId\\n        - action\\n        - result\\n        - errorCode\\n        - requestId\\n        - occurredAt\\n      properties:\\n        taskId:\\n          type: string\\n        taskCode:\\n          type: string\\n        subsystemCode:\\n          type: string\\n        operatorId:\\n          type: string\\n        action:\\n          type: string\\n          enum:\\n            - CREATE\\n            - QUERY_HISTORY\\n            - DETAIL_VIEW\\n            - DISPATCH\\n            - EXECUTE_START\\n            - EXECUTE_SUCCESS\\n            - EXECUTE_FAILED\\n            - CANCEL_REQUEST\\n   