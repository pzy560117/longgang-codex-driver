\n      summary: Create export task\\n      description: |\\n        Creates a PENDING export task when taskCode is registered and enabled.\\n        clientRequestId is idempotent in scope tenantId + operatorId + taskCode + clientRequestId.\\n      operationId: createExportTask\\n      parameters:\\n        - $ref: \\\"#/components/parameters/XOperatorId\\\"\\n        - $ref: \\\"#/components/parameters/XTenantId\\\"\\n        - $ref: \\\"#/components/parameters/XRoleCodes\\\"\\n        - $ref: \\\"#/components/parameters/XOrgScope\\\"\\n        - $ref: \\\"#/components/parameters/XRequestId\\\"\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              $ref: \\\"#/components/schemas/CreateExportTaskRequest\\\"\\n            examples:\\n              purchaseOrder:\\n                summary: Purchase order export task\\n                value:\\n                  taskCode: purchase-order-export\\n                  subsystemCode: purchase\\n                  fileFormat: XLSX\\n                  clientRequestId: req-20260513-0001\\n                  queryParams:\\n                    createdAtFrom: \\\"2026-05-01T00:00:00+08:00\\\"\\n                    createdAtTo: \\\"2026-05-13T23:59:59+08:00\\\"\\n                    orderStatus: APPROVED\\n                    supplierId: SUP-001\\n                    purchaseOrgId: ORG-001\\n                    keyword: PO-2026\\n      x-contract-errorResponses:\\n        - TASK_DISABLED\\n        - EXPORT_LIMIT_EXCEEDED\\n        - QUERY_TEMPLATE_INVALID\\n        - DATASOURCE_UNAVAILABLE\\n        - FIELD_MAPPING_INVALID\\n        - MASKING_RULE_ERROR\\n        - INTERNAL_ERROR\\n      responses:\\n        \\\"201\\\":\\n          description: Task created.\\n          content:\\n            application/json:\\n              schema:\\n                $ref: \\\"#/components/schemas/CreateExportTaskResponseEnvelope\\\"\\n              examples:\\n           