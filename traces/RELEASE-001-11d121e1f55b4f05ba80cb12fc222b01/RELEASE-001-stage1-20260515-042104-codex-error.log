components/schemas/BatchCheckpoint\\\"\\n        recentEvents:\\n          type: array\\n          items:\\n            $ref: \\\"#/components/schemas/TaskEvent\\\"\\n        auditEvents:\\n          type: array\\n          items:\\n            $ref: \\\"#/components/schemas/AuditEvent\\\"\\n    ExportTaskPageEnvelope:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\n        - type: object\\n          required: [data]\\n          properties:\\n            data:\\n              $ref: \\\"#/components/schemas/ExportTaskPage\\\"\\n    ExportTaskPage:\\n      type: object\\n      required: [items, page, pageSize, total]\\n      properties:\\n        items:\\n          type: array\\n          items:\\n            $ref: \\\"#/components/schemas/ExportTaskDetail\\\"\\n        page:\\n          type: integer\\n        pageSize:\\n          type: integer\\n        total:\\n          type: integer\\n          format: int64\\n    DownloadResponseEnvelope:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\n        - type: object\\n          required: [data]\\n          properties:\\n            data:\\n              $ref: \\\"#/components/schemas/DownloadResponse\\\"\\n    DownloadResponse:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/FileMetadata\\\"\\n        - type: object\\n          required: [deliveryMode, expiresAt]\\n          properties:\\n            deliveryMode:\\n              $ref: \\\"#/components/schemas/DeliveryMode\\\"\\n            downloadUrl:\\n              type: string\\n              format: uri\\n            expiresAt:\\n              type: string\\n              format: date-time\\n    FileMetadata:\\n      type: object\\n      required:\\n        - fileName\\n        - fileSize\\n        - contentType\\n        - checksum\\n        - checksumAlgorithm\\n        - storageKey\\n        - expiresAt\\n        - attemptNo\\n      properties:\\n        fileName:\\n          type: string\\n        fileSize:\\n          type: integer\\n          format: int64\\n        contentType:\\n          type: string\\n        tempStorageKey:\\n          type: string\\n        publishedStorageKey:\\n          type: string\\n        storageKey:\\n          type: string\\n        expiresAt:\\n          type: string\\n          format: date-time\\n          description: Published file retention expiry time. Signed URL responses also use expiresAt for URL expiry.\\n        checksum:\\n          type: string\\n        checksumAlgorithm:\\n          type: string\\n          enum: [SHA-256]\\n        checksumVerifiedAt:\\n          type: string\\n          format: date-time\\n        publishedAt:\\n          type: string\\n          format: date-time\\n        deliveryReadyAt:\\n          type: string\\n          format: date-time\\n        attemptNo:\\n          type: integer\\n          minimum: 1\\n    TaskActionRequest:\\n      type: object\\n      properties:\\n        reason:\\n          type: string\\n          maxLength: 500\\n    TaskActionResponseEnvelope:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\n        - type: object\\n          required: [data]\\n          properties:\\n            data:\\n              $ref: \\\"#/components/schemas/TaskActionResponse\\\"\\n    TaskActionResponse:\\n      type: object\\n      required: [taskId, status, attemptNo, acceptedAt]\\n      properties:\\n        taskId:\\n          type: string\\n        status:\\n          $ref: \\\"#/components/schemas/TaskStatus\\\"\\n        attemptNo:\\n          type: integer\\n        cancelAccepted:\\n          type: boolean\\n          description: True means an EXECUTING task will stop at a batch boundary; this is not a task status.\\n        retryAccepted:\\n          type: boolean\\n        configSnapshotDigest:\\n          type: string\\n        acceptedAt:\\n          type: string\\n          format: date-time\\n    ExportRegistryUpsertRequest:\\n      type: object\\n      required:\\n        - taskCode\\n        - subsystemCode\\n        - displayName\\n        - enabled\\n        - concurrencyLimit\\n        - fileRetentionDays\\n        - taskHistoryRetentionDays\\n        - singleFileMaxRows\\n        - exportMaxRows\\n        - supportedFormats\\n        - datasourceCode\\n        - parameterSchema\\n        - queryTemplate\\n        - fieldMappings\\n        - maskingPolicy\\n        - dataScopeTemplate\\n        - cursorField\\n        - orderBy\\n        - batchSize\\n      properties:\\n        taskCode:\\n          type: string\\n        subsystemCode:\\n          type: string\\n        displayName:\\n          type: string\\n        enabled:\\n          type: boolean\\n        concurrencyLimit:\\n          type: integer\\n          minimum: 1\\n        fileRetentionDays:\\n          type: integer\\n          minimum: 1\\n          default: 15\\n        taskHistoryRetentionDays:\\n          type: integer\\n          minimum: 1\\n          default: 30\\n        singleFileMaxRows:\\n          type: integer\\n          minimum: 1\\n          default: 20000\\n        exportMaxRows:\\n          type: integer\\n          minimum: 1\\n          default: 100000\\n        supportedFormats:\\n          type: array\\n          minItems: 1\\n          items:\\n            $ref: \\\"#/components/schemas/FileFormat\\\"\\n        datasourceCode:\\n          type: string\\n          description: Must reference a registered read-only datasource or data platform dataset.\\n        parameterSchema:\\n          type: object\\n          additionalProperties: true\\n        queryTemplate:\\n          $ref: \\\"#/components/schemas/QueryTemplateContract\\\"\\n        fieldMappings:\\n          type: array\\n          minItems: 1\\n          items:\\n            $ref: \\\"#/components/schemas/FieldMapping\\\"\\n        maskingPolicy:\\n          type: object\\n          additionalProperties: true\\n          description: Required masking policy. Any fieldMappings item with sensitive=true must reference a maskingRuleCode covered by this policy.\\n        dataScopeTemplate:\\n          type: string\\n          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.\\n        cursorField:\\n          type: string\\n        orderBy:\\n          type: array\\n          minItems: 1\\n          items:\\n            $ref: \\\"#/components/schemas/OrderBy\\\"\\n        batchSize:\\n          type: integer\\n          minimum: 1\\n    ExportRegistryEnvelope:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\n        - type: object\\n          required: [data]\\n          properties:\\n            data:\\n              $ref: \\\"#/components/schemas/ExportRegistry\\\"\\n    ExportRegistryPageEnvelope:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\n        - type: object\\n          required: [data]\\n          properties:\\n            data:\\n              type: object\\n              required: [items, page, pageSize, total]\\n              properties:\\n                items:\\n                  type: array\\n                  items:\\n                    $ref: \\\"#/components/schemas/ExportRegistry\\\"\\n                page:\\n                  type: integer\\n                pageSize:\\n                  type: integer\\n                total:\\n                  type: integer\\n                  format: int64\\n    ExportRegistry:\\n      allOf:\\n        - $ref: \\\"#/components/schemas/ExportRegistryUpsertRequest\\\"\\n        - type: object\\n          required:\\n            - configSnapshotDigest\\n            - parameterSchemaDigest\\n            - fieldMappingDigest\\n            - maskingPolicyDigest\\n            - updatedAt\\n            - updatedBy\\n          properties:\\n            configSnapshotDigest:\\n              type: string\\n            parameterSchemaDigest:\\n              type: string\\n           