port/tasks/cancel-export-task.handler.ts\r\n      service: src/task-api/service.ts\r\n      repository: [src/repositories/export-task.repository.ts, src/repositories/export-task-event.repository.ts, src/repositories/export-audit.repository.ts]\r\n      adapter: [src/audit-log/auth-context.ts]\r\n      db: [export_tasks, export_task_events, export_audit_logs]\r\n      worker: [EXECUTING cancel closes at a persisted batch boundary]\r\n      audit: [CANCEL_REQUEST, CANCEL_DONE]\r\n      file: [none]\r\n      tests:\r\n        - tests/contract/openapi-route-mapping.contract.test.mjs\r\n        - tests/api/export-http-api.test.mjs\r\n    retryExportTask:\r\n      http: POST /api/export/tasks/{taskId}/retry\r\n      requirements: [FR-012, FR-013, FR-010]\r\n      acceptanceExamples: [AE-012, AE-013]\r\n      handler: src/routes/export/tasks/retry-export-task.handler.ts\r\n      service: src/task-api/service.ts\r\n      repository: [src/repositories/export-task.repository.ts, src/repositories/export-task-event.repository.ts, src/repositories/export-audit.repository.ts]\r\n      adapter: [src/audit-log/auth-context.ts]\r\n      db: [export_tasks, export_task_events, export_audit_logs]\r\n      worker: [retry enqueues a new attempt only for FAILED tasks]\r\n      audit: [RETRY_REQUEST]\r\n      file: [none]\r\n      tests:\r\n        - tests/contract/openapi-route-mapping.contract.test.mjs\r\n        - tests/api/export-http-api.test.mjs\r\n    createExportRegistry:\r\n      http: POST /api/export/registries\r\n      requirements: [FR-007, FR-008, FR-009]\r\n      acceptanceExamples: [AE-007, AE-008, AE-016]\r\n      handler: src/routes/export/registries/create-export-registry.handler.ts\r\n      service: src/registry-config/service.ts\r\n      repository: [src/repositories/export-registry.repository.ts, src/repositories/export-audit.repository.ts]\r\n      adapter: [src/audit-log/auth-context.ts]\r\n      db: [export_registries, export_registry_versions, export_audit_logs]\r