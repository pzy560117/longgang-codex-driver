y for download\\r\\n                data:\\r\\n                  status: EXECUTING\\r\\n    FileVerifyError:\\r\\n      description: File upload, metadata or checksum verification failed before publish.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            verifyFailed:\\r\\n              value:\\r\\n                code: FILE_VERIFY_ERROR\\r\\n                message: file verification failed\\r\\n                data:\\r\\n                  checksumAlgorithm: SHA-256\\r\\n    DatasourceUnavailable:\\r\\n      description: Datasource or datasource credential is unavailable.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            datasourceUnavailable:\\r\\n              value:\\r\\n                code: DATASOURCE_UNAVAILABLE\\r\\n                message: datasource unavailable\\r\\n                data:\\r\\n                  datasourceCode: purchase_ro\\r\\n    QueryExecutionError:\\r\\n      description: Query execution failed, batch retries exhausted or cursor contract violated.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            queryFailed:\\r\\n              value:\\r\\n                code: QUERY_EXECUTION_ERROR\\r\\n                message: query execution failed\\r\\n                data:\\r\\n                  cursorField: orderId\\r\\n    RegistryBadRequest:\\r\\n      description: Registry request is invalid, exceeds limits, or contains invalid field/masking configuration.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            validation:\\r\\n              value:\\r\\n                code: VALIDATION_ERROR\\r\\n                message: validation failed\\r\\n                data: null\\r\\n            exportLimitExceeded:\\r\\n              value:\\r\\n                code: EXPORT_LIMIT_EXCEEDED\\r\\n                message: export limit exceeded\\r\\n                data:\\r\\n                  exportMaxRows: 100000\\r\\n            fieldMappingInvalid:\\r\\n              value:\\r\\n                code: FIELD_MAPPING_INVALID\\r\\n                message: field mapping invalid\\r\\n                data:\\r\\n                  fieldCode: contactPhone\\r\\n            maskingRuleError:\\r\\n              value:\\r\\n                code: MASKING_RULE_ERROR\\r\\n                message: masking rule error\\r\\n                data:\\r\\n                  maskingRuleCode: phone_mask\\r\\n    RegistryServerError:\\r\\n      description: Registry contract references an invalid query template, datasource, field mapping or masking backend.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            queryTemplateInvalid:\\r\\n              value:\\r\\n                code: QUERY_TEMPLATE_INVALID\\r\\n                message: query template invalid\\r\\n                data:\\r\\n                  taskCode: purchase-order-export\\r\\n            datasourceUnavailable:\\r\\n              value:\\r\\n                code: DATASOURCE_UNAVAILABLE\\r\\n                message: datasource unavailable\\r\\n                data:\\r\\n                  datasourceCode: purchase_ro\\r\\n            fieldMappingInvalid:\\r\\n              value:\\r\\n                code: FIELD_MAPPING_INVALID\\r\\n                message: field mapping invalid\\r\\n                data:\\r\\n                  fieldCode: contactPhone\\r\\n            maskingRuleError:\\r\\n              value:\\r\\n                code: MASKING_RULE_ERROR\\r\\n                message: masking rule error\\r\\n                data:\\r\\n                  maskingRuleCode: phone_mask\\r\\n    ExportRenderError:\\r\\n      description: XLSX or ZIP render failed.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            renderFailed:\\r\\n              value:\\r\\n                code: EXPORT_RENDER_ERROR\\r\\n                message: export render error\\r\\n                data:\\r\\n                  fileFormat: ZIP\\r\\n    RegistryConflict:\\r\\n      description: Registry taskCode already exists or conflicts with immutable fields.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            duplicate:\\r\\n              value:\\r\\n                code: REGISTRY_CONFLICT\\r\\n                message: taskCode already exists\\r\\n                data: null\\r\\n    InternalError:\\r\\n      description: Unclassified server-side error. Specific platform errors should use a more precise response when known.\\r\\n      content:\\r\\n        application/json:\\r\\n          schema:\\r\\n            $ref: \\\"#/components/schemas/ErrorEnvelope\\\"\\r\\n          examples:\\r\\n            internalError:\\r\\n              value:\\r\\n                code: INTERNAL_ERROR\\r\\n                message: internal error\\r\\n                data: null\\r\\n  schemas:\\r\\n    ResponseCode:\\r\\n      type: string\\r\\n      enum:\\r\\n        - SUCCESS\\r\\n        - VALIDATION_ERROR\\r\\n        - AUTH_CONTEXT_MISSING\\r\\n        - PERMISSION_DENIED\\r\\n        - TASK_NOT_FOUND\\r\\n        - TASK_NOT_REGISTERED\\r\\n        - TASK_DISABLED\\r\\n        - QUERY_PARAMS_TOO_LARGE\\r\\n        - IDEMPOTENCY_CONFLICT\\r\\n        - INVALID_TASK_STATE\\r\\n        - FILE_EXPIRED\\r\\n        - FILE_NOT_READY\\r\\n        - FILE_VERIFY_ERROR\\r\\n        - QUERY_TEMPLATE_INVALID\\r\\n        - DATASOURCE_UNAVAILABLE\\r\\n        - QUERY_EXECUTION_ERROR\\r\\n        - FIELD_MAPPING_INVALID\\r\\n        - MASKING_RULE_ERROR\\r\\n        - EXPORT_RENDER_ERROR\\r\\n        - EXPORT_LIMIT_EXCEEDED\\r\\n        - REGISTRY_CONFLICT\\r\\n        - ACTIVE_ATTEMPT_CONFLICT\\r\\n        - INTERNAL_ERROR\\r\\n    TaskStatus:\\r\\n      type: string\\r\\n      description: Official public task status. Internal cancel flags are not valid values.\\r\\n      enum: [PENDING, EXECUTING, COMPLETED, FAILED, CANCELED, EXPIRED]\\r\\n    FileFormat:\\r\\n      type: string\\r\\n      enum: [XLSX, ZIP]\\r\\n    DeliveryMode:\\r\\n      type: string\\r\\n      enum: [SIGNED_URL, STREAM]\\r\\n    Envelope:\\r\\n      type: object\\r\\n      required: [code, message]\\r\\n      properties:\\r\\n        code:\\r\\n          $ref: \\\"#/components/schemas/ResponseCode\\\"\\r\\n        message:\\r\\n          type: string\\r\\n    ErrorEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          properties:\\r\\n            data:\\r\\n              type: object\\r\\n              nullable: true\\r\\n              additionalProperties: true\\r\\n            errors:\\r\\n              type: array\\r\\n              items:\\r\\n                $ref: \\\"#/components/schemas/FieldError\\\"\\r\\n    FieldError:\\r\\n      type: object\\r\\n      required: [field, reason]\\r\\n      properties:\\r\\n        field:\\r\\n          type: string\\r\\n        reason:\\r\\n          type: string\\r\\n    CreateExportTaskRequest:\\r\\n      type: object\\r\\n      required: [taskCode, subsystemCode, fileFormat, queryParams]\\r\\n      properties:\\r\\n        taskCode:\\r\\n          type: string\\r\\n        subsystemCode:\\r\\n          type: string\\r\\n        fileFormat:\\r\\n          $ref: \\\"#/components/schemas/FileFormat\\\"\\r\\n        clientRequestId:\\r\\n          type: string\\r\\n          maxLength: 128\\r\\n          description: Optional idempotency key scoped by tenantId/operatorId/taskCode.\\r\\n        queryParams:\\r\\n          type: object\\r\\n          additionalProperties: true\\r\\n          description: Must match registry parameter schema and must not exceed 32768 bytes after canonical JSON serialization.\\r\\n        deliveryPreference:\\r\\n          $ref: \\\"#/components/schemas/DeliveryMode\\\"\\r\\n    CreateExportTaskResponseEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/CreateExportTaskResponse\\\"\\r\\n    CreateExportTaskResponse:\\r\\n      type: object\\r\\n      required:\\r\\n        - taskId\\r\\n        - taskCode\\r\\n        - subsystemCode\\r\\n        - status\\r\\n        - idempotencyScope\\r\\n        - requestDigest\\r\\n        - configSnapshotDigest\\r\\n        - attemptNo\\r\\n        - createdAt\\r\\n      properties:\\r\\n        taskId:\\r\\n          type: string\\r\\n        taskCode:\\r\\n          type: string\\r\\n        subsystemCode:\\r\\n          type: string\\r\\n        status:\\r\\n          type: string\\r\\n          enum: [PENDING]\\r\\n        clientRequestId:\\r\\n          type: string\\r\\n        idempotencyHit:\\r\\n          type: boolean\\r\\n        idempotencyScope:\\r\\n          type: string\\r\\n          description: Stable success-response evidence for the tenantId + operatorId + taskCode + clientRequestId idempotency scope.\\r\\n        requestDigest:\\r\\n          type: string\\r\\n        configSnapshotDigest:\\r\\n          type: string\\r\\n        attemptNo:\\r\\n          type: integer\\r\\n          minimum: 0\\r\\n        createdAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n    ExportTaskDetailEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/ExportTaskDetail\\\"\\r\\n    ExportTaskDetail:\\r\\n      type: object\\r\\n      required:\\r\\n        - taskId\\r\\n        - taskCode\\r\\n        - subsystemCode\\r\\n        - status\\r\\n        - totalCount\\r\\n        - processedCount\\r\\n        - progressPercent\\r\\n        - attemptNo\\r\\n        - requestId\\r\\n        - requestDigest\\r\\n        - configSnapshotDigest\\r\\n        - createdBy\\r\\n        - createdAt\\r\\n        - updatedAt\\r\\n      properties:\\r\\n        taskId:\\r\\n          type: string\\r\\n        taskCode:\\r\\n          type: string\\r\\n        subsystemCode:\\r\\n          type: string\\r\\n        status:\\r\\n          $ref: \\\"#/components/schemas/TaskStatus\\\"\\r\\n        totalCount:\\r\\n          type: integer\\r\\n          format: int64\\r\\n          minimum: 0\\r\\n        processedCount:\\r\\n          type: integer\\r\\n          format: int64\\r\\n          minimum: 0\\r\\n        progressPercent:\\r\\n          type: number\\r\\n          minimum: 0\\r\\n          maximum: 100\\r\\n        fileFormat:\\r\\n          $ref: \\\"#/components/schemas/FileFormat\\\"\\r\\n        attemptNo:\\r\\n          type: integer\\r\\n          minimum: 0\\r\\n        errorCode:\\r\\n          $ref: \\\"#/components/schemas/ResponseCode\\\"\\r\\n        errorMessage:\\r\\n          type: string\\r\\n        failureStage:\\r\\n          type: string\\r\\n        lastSuccessStage:\\r\\n          type: string\\r\\n        requestId:\\r\\n          type: string\\r\\n        requestDigest:\\r\\n          type: string\\r\\n        configSnapshotDigest:\\r\\n          type: string\\r\\n        createdBy:\\r\\n          type: string\\r\\n        createdAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n        updatedAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n        file:\\r\\n          $ref: \\\"#/components/schemas/FileMetadata\\\"\\r\\n        batchCheckpoint:\\r\\n          $ref: \\\"#/components/schemas/BatchCheckpoint\\\"\\r\\n        recentEvents:\\r\\n          type: array\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/TaskEvent\\\"\\r\\n        auditEvents:\\r\\n          type: array\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/AuditEvent\\\"\\r\\n    ExportTaskPageEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/ExportTaskPage\\\"\\r\\n    ExportTaskPage:\\r\\n      type: object\\r\\n      required: [items, page, pageSize, total]\\r\\n      properties:\\r\\n        items:\\r\\n          type: array\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/ExportTaskDetail\\\"\\r\\n        page:\\r\\n          type: integer\\r\\n        pageSize:\\r\\n          type: integer\\r\\n        total:\\r\\n          type: integer\\r\\n          format: int64\\r\\n    DownloadResponseEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/DownloadResponse\\\"\\r\\n    DownloadResponse:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/FileMetadata\\\"\\r\\n        - type: object\\r\\n          required: [deliveryMode, expiresAt]\\r\\n          properties:\\r\\n            deliveryMode:\\r\\n              $ref: \\\"#/components/schemas/DeliveryMode\\\"\\r\\n            downloadUrl:\\r\\n              type: string\\r\\n              format: uri\\r\\n            expiresAt:\\r\\n              type: string\\r\\n              format: date-time\\r\\n    FileMetadata:\\r\\n      type: object\\r\\n      required:\\r\\n        - fileName\\r\\n        - fileSize\\r\\n        - contentType\\r\\n        - checksum\\r\\n        - checksumAlgorithm\\r\\n        - storageKey\\r\\n        - expiresAt\\r\\n        - attemptNo\\r\\n      properties:\\r\\n        fileName:\\r\\n          type: string\\r\\n        fileSize:\\r\\n          type: integer\\r\\n          format: int64\\r\\n        contentType:\\r\\n          type: string\\r\\n        tempStorageKey:\\r\\n          type: string\\r\\n        publishedStorageKey:\\r\\n          type: string\\r\\n        storageKey:\\r\\n          type: string\\r\\n        expiresAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n          description: Published file retention expiry time. Signed URL responses also use expiresAt for URL expiry.\\r\\n        checksum:\\r\\n          type: string\\r\\n        checksumAlgorithm:\\r\\n          type: string\\r\\n          enum: [SHA-256]\\r\\n        checksumVerifiedAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n        publishedAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n        deliveryReadyAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n        attemptNo:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n    TaskActionRequest:\\r\\n      type: object\\r\\n      properties:\\r\\n        reason:\\r\\n          type: string\\r\\n          maxLength: 500\\r\\n    TaskActionResponseEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/TaskActionResponse\\\"\\r\\n    TaskActionResponse:\\r\\n      type: object\\r\\n      required: [taskId, status, attemptNo, acceptedAt]\\r\\n      properties:\\r\\n        taskId:\\r\\n          type: string\\r\\n        status:\\r\\n          $ref: \\\"#/components/schemas/TaskStatus\\\"\\r\\n        attemptNo:\\r\\n          type: integer\\r\\n        cancelAccepted:\\r\\n          type: boolean\\r\\n          description: True means an EXECUTING task will stop at a batch boundary; this is not a task status.\\r\\n        retryAccepted:\\r\\n          type: boolean\\r\\n        configSnapshotDigest:\\r\\n          type: string\\r\\n        acceptedAt:\\r\\n          type: string\\r\\n          format: date-time\\r\\n    ExportRegistryUpsertRequest:\\r\\n      type: object\\r\\n      required:\\r\\n        - taskCode\\r\\n        - subsystemCode\\r\\n        - displayName\\r\\n        - enabled\\r\\n        - concurrencyLimit\\r\\n        - fileRetentionDays\\r\\n        - taskHistoryRetentionDays\\r\\n        - singleFileMaxRows\\r\\n        - exportMaxRows\\r\\n        - supportedFormats\\r\\n        - datasourceCode\\r\\n        - parameterSchema\\r\\n        - queryTemplate\\r\\n        - fieldMappings\\r\\n        - maskingPolicy\\r\\n        - dataScopeTemplate\\r\\n        - cursorField\\r\\n        - orderBy\\r\\n        - batchSize\\r\\n      properties:\\r\\n        taskCode:\\r\\n          type: string\\r\\n        subsystemCode:\\r\\n          type: string\\r\\n        displayName:\\r\\n          type: string\\r\\n        enabled:\\r\\n          type: boolean\\r\\n        concurrencyLimit:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n        fileRetentionDays:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n          default: 15\\r\\n        taskHistoryRetentionDays:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n          default: 30\\r\\n        singleFileMaxRows:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n          default: 20000\\r\\n        exportMaxRows:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n          default: 100000\\r\\n        supportedFormats:\\r\\n          type: array\\r\\n          minItems: 1\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/FileFormat\\\"\\r\\n        datasourceCode:\\r\\n          type: string\\r\\n          description: Must reference a registered read-only datasource or data platform dataset.\\r\\n        parameterSchema:\\r\\n          type: object\\r\\n          additionalProperties: true\\r\\n        queryTemplate:\\r\\n          $ref: \\\"#/components/schemas/QueryTemplateContract\\\"\\r\\n        fieldMappings:\\r\\n          type: array\\r\\n          minItems: 1\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/FieldMapping\\\"\\r\\n        maskingPolicy:\\r\\n          type: object\\r\\n          additionalProperties: true\\r\\n          description: Required masking policy. Any fieldMappings item with sensitive=true must reference a maskingRuleCode covered by this policy.\\r\\n        dataScopeTemplate:\\r\\n          type: string\\r\\n          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.\\r\\n        cursorField:\\r\\n          type: string\\r\\n        orderBy:\\r\\n          type: array\\r\\n          minItems: 1\\r\\n          items:\\r\\n            $ref: \\\"#/components/schemas/OrderBy\\\"\\r\\n        batchSize:\\r\\n          type: integer\\r\\n          minimum: 1\\r\\n    ExportRegistryEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n              $ref: \\\"#/components/schemas/ExportRegistry\\\"\\r\\n    ExportRegistryPageEnvelope:\\r\\n      allOf:\\r\\n        - $ref: \\\"#/components/schemas/Envelope\\\"\\r\\n        - type: object\\r\\n          required: [data]\\r\\n          properties:\\r\\n            data:\\r\\n