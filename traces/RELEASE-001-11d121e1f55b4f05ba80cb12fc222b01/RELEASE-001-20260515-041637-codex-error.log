    getExportTask:
      http: GET /api/export/tasks/{taskId}
      requirements: [FR-002, FR-010, FR-013]
      acceptanceExamples: [AE-002, AE-010, AE-013]
      handler: src/routes/export/tasks/get-export-task.handler.ts
      service: src/task-api/service.ts
      repository: [src/repositories/export-task.repository.ts, src/repositories/export-task-event.repository.ts, src/repositories/export-checkpoint.repository.ts, src/repositories/export-file.repository.ts, src/repositories/export-audit.repository.ts]
      adapter: [src/audit-log/auth-context.ts]
      db: [export_tasks, export_task_events, export_task_checkpoints, export_task_files]
