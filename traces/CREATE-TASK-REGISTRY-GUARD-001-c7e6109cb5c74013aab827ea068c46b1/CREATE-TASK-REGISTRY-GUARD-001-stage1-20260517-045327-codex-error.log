 105: function assertQueryParamsSize(value: unknown): void {
 106:   const bytes = Buffer.byteLength(canonicalJson(value), "utf8");
 107:   if (bytes > QUERY_PARAMS_MAX_BYTES) {
 108:     throw new ApiError(400, "QUERY_PARAMS_TOO_LARGE", "queryParams exceeds 32768 bytes", {
 109:       queryParamsBytes: bytes,
 110:       queryParamsMaxBytes: QUERY_PARAMS_MAX_BYTES
 111:     });
 112:   }
 113: }
