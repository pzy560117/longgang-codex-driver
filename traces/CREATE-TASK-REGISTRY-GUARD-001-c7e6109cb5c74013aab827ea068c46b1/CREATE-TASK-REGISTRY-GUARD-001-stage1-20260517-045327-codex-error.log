  const unauthorizedRegistryUpdateResponse = await app.inject({
    method: "PUT",
    url: `/api/export/registries/${taskCode}`,
    headers: createHeaders(`req-registry-update-denied-${runId}`, {
      roleCodes: "EXPORT_USER"
    }),
    payload: {
      ...createRegistryPayload(taskCode),
      concurrencyLimit: 9
