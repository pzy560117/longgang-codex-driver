 115: function parseRegistryJson<T>(value: string | null, label: string): T {
 116:   if (!value) {
 117:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `${label} is missing`);
 118:   }
 119: 
 120:   try {
 121:     return JSON.parse(value) as T;
 122:   } catch {
 123:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", `${label} is invalid`);
 124:   }
 125: }
 126: 
 127: function assertRegistryFileFormat(registrySupportedFormats: string | null, fileFormat: string): void {
 128:   const supportedFormats = parseRegistryJson<unknown>(registrySupportedFormats, "supportedFormats");
 129:   if (
 130:     !Array.isArray(supportedFormats) ||
 131:     supportedFormats.length === 0 ||
 132:     !supportedFormats.every((format) => typeof format === "string")
 133:   ) {
 134:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "registry supportedFormats is invalid");
 135:   }
 136: 
 137:   if (!supportedFormats.includes(fileFormat)) {
 138:     throw new ApiError(400, "QUERY_TEMPLATE_INVALID", "fileFormat is not supported by registry");
 139:   }
 140: }
