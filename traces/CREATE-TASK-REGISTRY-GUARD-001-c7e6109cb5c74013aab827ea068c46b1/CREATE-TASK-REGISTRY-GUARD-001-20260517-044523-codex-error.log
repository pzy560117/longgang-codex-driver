+    {
+      label: "wrong-query-param-type",
+      clientRequestId: "client-registry-guard-wrong-type",
+      requestId: `req-registry-guard-wrong-type-${runId}`,
+      payload: {
+        ...createTaskPayload(taskCode, "client-registry-guard-wrong-type"),
+        queryParams: {
