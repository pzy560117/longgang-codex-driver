export type DownloadDeliveryMode = "SIGNED_URL" | "STREAM";

type DownloadSignedUrlResponse = {
  deliveryMode: "SIGNED_URL";
  downloadUrl: string;
  storageKey: string;
  expiresAt: string;
  fileName: string;
  contentType: string;
