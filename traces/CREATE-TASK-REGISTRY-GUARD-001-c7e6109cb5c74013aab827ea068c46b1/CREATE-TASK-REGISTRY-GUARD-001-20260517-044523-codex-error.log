+    assert.equal(response.json().data?.status, undefined, rejectionCase.label);
+
+    const rows = await db
+      .selectFrom("export_tasks")
+      .select("task_id")
+      .where("task_code", "=", taskCode)
+      .where("client_request_id", "=", rejectionCase.clientRequestId)
