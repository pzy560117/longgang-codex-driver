+  assert.match(taskServiceSource, /assertCreateTaskRegistryGuards/);
+  assert.match(taskServiceSource, /assertRegistryFileFormat/);
+  assert.match(taskServiceSource, /assertRegistryParameterSchema/);
+  assert.ok(
+    taskServiceSource.indexOf("assertCreateTaskRegistryGuards") <
+      taskServiceSource.indexOf("createPendingTask"),
+    "registry guard must run before createPendingTask"
+  );
+});
