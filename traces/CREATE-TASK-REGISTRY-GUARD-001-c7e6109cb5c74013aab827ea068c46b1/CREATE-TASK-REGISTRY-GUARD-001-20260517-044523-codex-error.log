+  fileFormat: string;
+  queryParams: unknown;
+}): void {
+  assertRegistryFileFormat(input.registry.supportedFormats, input.fileFormat);
+  assertRegistryParameterSchema(input.registry.parameterSchema, input.queryParams);
+}
