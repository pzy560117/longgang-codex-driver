import { requireAuthContext } from "../../../audit-log/auth-context.ts";
import { getExportRegistry } from "../../../registry-config/service.ts";
import { sendError, sendSuccess } from "../../respond.ts";
import type { RouteHandler } from "../../types.ts";

export const handler: RouteHandler = async (context, response) => {
  try {
    const auth = await requireAuthContext(context.request, "REGISTRY_DETAIL");
    const data = await getExportRegistry(auth, context.params.taskCode);
    sendSuccess(response, 200, data);
  } catch (error) {
    await sendError(response, error);
  }
};

import { requireAuthContext } from "../../../audit-log/auth-context.ts";
import { listExportRegistries } from "../../../registry-config/service.ts";
import { sendError, sendSuccess } from "../../respond.ts";
import type { RouteHandler } from "../../types.ts";

export const handler: RouteHandler = async (context, response) => {
  try {
    const auth = await requireAuthContext(context.request, "REGISTRY_QUERY");
    const data = await listExportRegistries(
      auth,
      context.request.query as Record<string, unknown>
    );
    sendSuccess(response, 200, data);
  } catch (error) {
    await sendError(response, error);
  }
};

import { requireAuthContext } from "../../../audit-log/auth-context.ts";
import { createExportTask } from "../../../task-api/service.ts";
import { sendError, sendSuccess } from "../../respond.ts";
import type { RouteHandler } from "../../types.ts";

export const handler: RouteHandler = async (context, response) => {
  try {
    const auth = await requireAuthContext(context.request, "CREATE");
    const result = await createExportTask(auth, context.request.body ?? {});
    sendSuccess(response, result.statusCode, result.data);
  } catch (error) {
    await sendError(response, error);
  }
};


