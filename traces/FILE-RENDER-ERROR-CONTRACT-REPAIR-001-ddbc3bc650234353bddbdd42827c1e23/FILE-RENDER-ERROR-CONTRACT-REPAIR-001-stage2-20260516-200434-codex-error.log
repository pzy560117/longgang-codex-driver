  441:           processedCount: checkpoint?.processedCount ?? 0,
  442:           filePartNo: checkpoint?.filePartNo ?? 1,
  443:           retryCount,
  444:           batchSize: checkpoint?.batchSize ?? null,
  445:           batchRowCount: checkpoint?.batchRowCount ?? 0,
  446:           backoffMs,
  447:           now
  448:         });
  449:         const renewed = await renewLeaseAtBatchBoundary({
  450:           db: input.db,
  451:           taskId: input.task.taskId,
  452:           attemptNo: input.lease.attemptNo,
  453:           lockOwner: input.lease.lockOwner,
  454:           leaseDurationSeconds: input.leaseDurationSeconds
