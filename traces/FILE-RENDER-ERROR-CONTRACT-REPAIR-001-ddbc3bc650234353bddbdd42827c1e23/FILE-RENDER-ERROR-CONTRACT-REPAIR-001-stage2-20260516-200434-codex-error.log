  219: async function acquireNextLease(input: {
  220:   db: Kysely<ExportPlatformDatabase>;
  221:   workerId: string;
  222:   leaseDurationSeconds: number;
  223: }): Promise<{ task: ExportTaskRecord; lease: ExportTaskLeaseRecord } | undefined> {
  224:   return input.db.transaction().execute(async (trx) => {
  225:     const databaseTime = await queryDatabaseTime(trx);
  226:     const candidates = await trx
  227:       .selectFrom("export_tasks as t")
  228:       .leftJoin("export_task_checkpoints as cp", (join) =>
  229:         join
  230:           .onRef("cp.task_id", "=", "t.task_id")
  231:           .onRef("cp.attempt_no", "=", "t.attempt_no")
  232:       )
  233:       .select([
  234:         "t.task_id",
  235:         "t.task_code",
  236:         "t.subsystem_code",
  237:         "t.tenant_id",
  238:         "t.created_by",
  239:         "t.file_format",
  240:         "t.status",
  241:         "t.client_request_id",
  242:         "t.idempotency_scope",
  243:         "t.request_digest",
  244:         "t.config_snapshot_digest",
  245:         "t.request_payload",
  246:         "t.auth_context_payload",
  247:         "t.attempt_no",
  248:         "t.lock_owner",
  249:         "t.lock_expire_at",
  250:         "t.lease_renewed_at",
  251:         "t.created_at",
  252:         "t.updated_at"
  253:       ])
  254:       .where((eb) =>
  255:         eb.or([
  256:           eb("t.status", "=", "PENDING"),
  257:           eb.and([
  258:             eb("t.status", "=", "EXECUTING"),
  259:             eb("t.lock_owner", "=", input.workerId),
  260:             eb("t.lock_expire_at", ">", databaseTime)
  261:           ]),
  262:           eb.and([
  263:             eb("t.status", "=", "EXECUTING"),
  264:             eb("t.lock_expire_at", "<", databaseTime)
  265:           ])
  266:         ])
  267:       )
  268:       .where((eb) =>
  269:         eb.or([
  270:           eb("cp.task_id", "is", null),
  271:           eb("cp.backoff_ms", "is", null),
  272:           eb("cp.backoff_ms", "<=", 0),
  273:           eb(
  274:             sql`TIMESTAMPADD(MICROSECOND, COALESCE(cp.backoff_ms, 0) * 1000, cp.updated_at)`,
  275:             "<=",
  276:             sql`CURRENT_TIMESTAMP(3)`
  277:           )
  278:         ])
  279:       )
  280:       .orderBy("t.created_at", "asc")
  281:       .orderBy("t.task_id", "asc")
  282:       .limit(25)
  283:       .forUpdate()
  284:       .execute();
  285: 
  286:     for (const candidate of candidates) {
  287:       const isOwnActiveLeaseResume =
  288:         candidate.status === "EXECUTING" &&
  289:         candidate.lock_owner === input.workerId &&
  290:         candidate.lock_expire_at instanceof Date &&
  291:         candidate.lock_expire_at > databaseTime;
  292: 
  293:       await trx
  294:         .selectFrom("export_registries")
  295:         .select("task_code")
  296:         .where("subsystem_code", "=", candidate.subsystem_code)
  297:         .orderBy("task_code", "asc")
  298:         .forUpdate()
  299:         .execute();
  300: 
  301:       const activeTasks = await trx
  302:         .selectFrom("export_tasks")
  303:         .select("task_id")
  304:         .where("subsystem_code", "=", candidate.subsystem_code)
  305:         .where("status", "=", "EXECUTING")
  306:         .where("lock_expire_at", ">", databaseTime)
  307:         .forUpdate()
  308:         .execute();
  309: 
  310:       const concurrencyLimit = resolveTaskConcurrencyLimit(toTaskRecord(candidate));
  311:       const activeCount = activeTasks.length;
  312:       if (!isOwnActiveLeaseResume && activeCount >= concurrencyLimit) {
  313:         continue;
  314:       }
  315: 
  316:       const lockExpireAt = new Date(
  317:         databaseTime.getTime() + input.leaseDurationSeconds * 1000
  318:       );
  319:       const takeoverRule =
  320:         isOwnActiveLeaseResume
  321:           ? "ACTIVE_LEASE_RESUME_SAME_OWNER"
  322:           : candidate.status === "EXECUTING"
  323:           ? "EXPIRED_LEASE_TAKEOVER_KEEP_ATTEMPT"
  324:           : "PENDING_OR_EXPIRED_KEEP_ATTEMPT";
  325:       const previousLockOwner =
  326:         takeoverRule === "EXPIRED_LEASE_TAKEOVER_KEEP_ATTEMPT"
  327:           ? candidate.lock_owner
  328:           : null;
  329: 
  330:       await trx
  331:         .updateTable("export_tasks")
  332:         .set({
  333:           status: "EXECUTING",
  334:           lock_owner: input.workerId,
  335:           lock_expire_at: lockExpireAt,
  336:           lease_renewed_at: databaseTime,
  337:           updated_at: databaseTime
  338:         })
  339:         .where("task_id", "=", candidate.task_id)
  340:         .where("attempt_no", "=", candidate.attempt_no)
  341:         .execute();
  342: 
  343:       await trx
  344:         .insertInto("export_task_leases")
  345:         .values({
  346:           task_id: candidate.task_id,
  347:           attempt_no: candidate.attempt_no,
  348:           lock_owner: input.workerId,
  349:           previous_lock_owner: previousLockOwner,
  350:           lock_expire_at: lockExpireAt,
  351:           lease_renewed_at: databaseTime,
  352:           database_time: databaseTime,
  353:           takeover_rule: takeoverRule,
  354:           created_at: databaseTime,
  355:           updated_at: databaseTime
  356:         })
  357:         .onDuplicateKeyUpdate({
  358:           lock_owner: input.workerId,
  359:           previous_lock_owner: previousLockOwner,
  360:           lock_expire_at: lockExpireAt,
  361:           lease_renewed_at: databaseTime,
  362:           database_time: databaseTime,
  363:           takeover_rule: takeoverRule,
  364:           updated_at: databaseTime
  365:         })
  366:         .execute();
  367: 
  368:       const task = toTaskRecord({
  369:         ...candidate,
  370:         status: "EXECUTING",
  371:         lock_owner: input.workerId,
  372:         lock_expire_at: lockExpireAt,
  373:         lease_renewed_at: databaseTime,
  374:         updated_at: databaseTime
  375:       });
  376: 
  377:       return {
  378:         task,
  379:         lease: {
  380:           taskId: candidate.task_id,
  381:           attemptNo: candidate.attempt_no,
  382:           lockOwner: input.workerId,
  383:           previousLockOwner,
  384:           lockExpireAt,
  385:           leaseRenewedAt: databaseTime,
  386:           databaseTime,
  387:           takeoverRule
  388:         }
  389:       };
  390:     }
  391: 
  392:     return undefined;
  393:   });
  394: }
