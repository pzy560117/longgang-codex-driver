  101: function buildWorksheetXml(part: FilePart): string {
  102:   const rowValues = [part.headers, ...part.rows.map((row) => part.headers.map((header) => formatCellValue(row[header])))];
  103:   const lastColumn = Math.max(part.headers.length, 1);
  104:   const lastRow = Math.max(rowValues.length, 1);
  105:   const dimension = `A1:${buildCellReference(lastColumn - 1, lastRow)}`;
  106:   const rowsXml = rowValues
  107:     .map((row, rowIndex) => buildWorksheetRowXml(row, rowIndex + 1))
  108:     .join("");
  109: 
  110:   return [
  111:     '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>',
  112:     '<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">',
  113:     `<dimension ref="${dimension}"/>`,
  114:     "<sheetData>",
  115:     rowsXml,
  116:     "</sheetData>",
  117:     "</worksheet>"
  118:   ].join("");
  119: }
  120: 
  121: function buildWorksheetRowXml(values: string[], rowNumber: number): string {
  122:   const cellsXml = values
  123:     .map((value, columnIndex) => {
  124:       const cellReference = buildCellReference(columnIndex, rowNumber);
  125:       return [
  126:         `<c r="${cellReference}" t="inlineStr">`,
  127:         "<is>",
  128:         `<t xml:space="preserve">${escapeXml(value)}</t>`,
  129:         "</is>",
  130:         "</c>"
  131:       ].join("");
  132:     })
  133:     .join("");
  134:   return `<row r="${rowNumber}">${cellsXml}</row>`;
  135: }
  136: 
  137: function buildCellReference(columnIndex: number, rowNumber: number): string {
  138:   let current = columnIndex + 1;
  139:   let letters = "";
  140:   while (current > 0) {
  141:     const remainder = (current - 1) % 26;
  142:     letters = String.fromCharCode(65 + remainder) + letters;
  143:     current = Math.floor((current - 1) / 26);
  144:   }
  145:   return `${letters}${rowNumber}`;
  146: }
  147: 
  148: function formatCellValue(value: unknown): string {
  149:   if (value === null || value === undefined) {
  150:     return "";
  151:   }
  152:   if (value instanceof Date) {
  153:     return value.toISOString();
  154:   }
  155:   if (typeof value === "string") {
  156:     return value;
  157:   }
  158:   if (typeof value === "number" || typeof value === "boolean" || typeof value === "bigint") {
  159:     return String(value);
  160:   }
  161:   return JSON.stringify(value);
  162: }
  163: 
  164: function escapeXml(value: string): string {
  165:   return value
