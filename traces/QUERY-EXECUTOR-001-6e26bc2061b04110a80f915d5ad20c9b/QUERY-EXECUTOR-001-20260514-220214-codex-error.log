+    }
+    return output;
+  });
+}
+
+function maskValue(
+  value: unknown,
+  mapping: FieldMapping,
+  maskingPolicy: MaskingPolicy
+): unknown {
+  const ruleCode = mapping.maskingRuleCode;
+  const rule = ruleCode ? maskingPolicy.rules?.[ruleCode] : undefined;
