    }): Promise<ExportRegistryRecord | undefined> {
      await db
        .updateTable("export_registries")
        .set({
          enabled: input.enabled,
          updated_at: input.now
        })
        .where("task_code", "=", input.taskCode)
        .execute();

      return this.findRegistryByTaskCode(input.taskCode);
    }
  };
}


