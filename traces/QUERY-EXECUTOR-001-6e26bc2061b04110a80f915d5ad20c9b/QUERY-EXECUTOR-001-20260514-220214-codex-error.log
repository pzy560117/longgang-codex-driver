+  const template = parseJson<QueryTemplate>(value, "QUERY_TEMPLATE_INVALID");
+  if (!template.templateText || typeof template.templateText !== "string") {
+    throw queryError("QUERY_TEMPLATE_INVALID", "query template text is required");
