+async function appendQueryEvent(input: {
+  context: SchedulerBatchContext;
+  eventType: string;
+  datasourceCode: string;
+  queryTemplateVersion: string;
+  batchCheckpoint: unknown;
+  now: Date;
+}): Promise<void> {
