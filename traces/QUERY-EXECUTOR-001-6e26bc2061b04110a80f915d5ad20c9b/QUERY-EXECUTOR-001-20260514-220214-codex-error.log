+  for (const [key, definition] of Object.entries(schema.properties ?? {})) {
+    const value = queryParams[key];
+    if (value === undefined || value === null || !definition.type) {
+      continue;
+    }
+    if (definition.type === "string" && typeof value !== "string") {
