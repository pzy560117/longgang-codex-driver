version: "1.0"
feature_id: "FEAT-EXPORT-PLATFORM-001"
frontend_scope: "none"
required_backend_states:
  - default
  - empty
  - processing
  - error
  - permission_denied
  - disabled
  - expired
  - canceled
  - long_content
  - conflict
official_task_statuses:
  - PENDING
  - EXECUTING
  - COMPLETED
  - FAILED
  - CANCELED
  - EXPIRED
internal_controls:
  cancel_requested: "仅作为执行中取消的内部控制标记；API 不返回该状态，最终收口为 CANCELED 或 INVALID_TASK_STATE"
defaults:
  query_params_max_bytes: 32768
  single_file_max_rows: 20000
  default_export_max_rows: 100000
  lock_lease_minutes: 5
  query_timeout_seconds: 30
  query_batch_max_retries: 3
  supported_formats: ["XLSX", "ZIP"]
  signature_url_ttl_minutes: 10
  checksum_algorithm: "SHA-256"
  file_retention_days: 15
  task_history_retention_days: 30
execution_events:
  - QUERY_READY
  - QUERY_BATCH_DONE
  - FILE_PART_WRITTEN
  - PACKAGE_DONE
  - FILE_VERIFIED
  - DELIVERY_READY
