        leaseRenewedAt:
          type: string
          format: date-time
          description: Last successful lease renewal time based on database time.
        databaseTime:
          type: string
          format: date-time
          description: Database clock snapshot used for lock acquisition, renewal and takeover decisions.
        takeoverRule:
          type: string
          description: Workers may take over only after database time is later than lockExpireAt; takeover keeps the same attemptNo.
