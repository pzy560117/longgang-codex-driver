        return buildSampleBoundaryResult(rowCount, "SINGLE_FILE");
      }
      if (rowCount === 20001) {
        return buildSampleBoundaryResult(rowCount, "SPLIT_AND_ZIP");
      }
      if (rowCount === 100000) {
        return buildSampleBoundaryResult(rowCount, "THROTTLED_BUT_ALLOWED");
