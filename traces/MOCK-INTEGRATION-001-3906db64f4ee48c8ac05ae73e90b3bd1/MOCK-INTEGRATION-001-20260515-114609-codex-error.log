+
+  assert.match(verifyMatrix, /本地集成验收归档 \| FR-001 - FR-014 \| accepted \/ local-dev-only/u);
+  assert.match(verifyMatrix, /`MOCK-INTEGRATION-001` 已执行/u);
+});
+
