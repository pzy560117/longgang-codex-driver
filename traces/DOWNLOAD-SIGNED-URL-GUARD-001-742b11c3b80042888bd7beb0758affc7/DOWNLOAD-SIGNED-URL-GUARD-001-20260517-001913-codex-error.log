+    expectedBuffer.length !== signatureBuffer.length ||
+    !timingSafeEqual(expectedBuffer, signatureBuffer)
+  ) {
+    return { valid: false, reason: "SIGNATURE_INVALID" };
+  }
+  return { valid: true, reason: "OK" };
