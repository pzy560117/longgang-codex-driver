diff --git a/migrations/001_initial_export_platform_schema.sql b/migrations/001_initial_export_platform_schema.sql
new file mode 100644
index 0000000000000000000000000000000000000000..3f6bbc6d08477b51ea842ff35596701d33a52da4
--- /dev/null
+++ b/migrations/001_initial_export_platform_schema.sql
@@ -0,0 +1,97 @@
+CREATE TABLE export_tasks (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_id VARCHAR(64) NOT NULL UNIQUE,
+  task_code VARCHAR(128) NOT NULL,
+  subsystem_code VARCHAR(128) NOT NULL,
+  status VARCHAR(32) NOT NULL,
+  created_by VARCHAR(128) NOT NULL,
+  request_id VARCHAR(128) NOT NULL,
+  request_digest VARCHAR(128) NOT NULL,
+  config_snapshot_digest VARCHAR(128) NOT NULL,
+  created_at DATETIME(3) NOT NULL,
+  updated_at DATETIME(3) NOT NULL
+);
+
+CREATE TABLE export_task_idempotency (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  idempotency_scope VARCHAR(512) NOT NULL UNIQUE,
+  task_id VARCHAR(64) NOT NULL,
+  request_digest VARCHAR(128) NOT NULL,
+  created_at DATETIME(3) NOT NULL
+);
+
+CREATE TABLE export_registries (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_code VARCHAR(128) NOT NULL UNIQUE,
+  subsystem_code VARCHAR(128) NOT NULL,
+  enabled BOOLEAN NOT NULL,
+  concurrency_limit INT NOT NULL,
+  file_retention_days INT NOT NULL,
+  task_history_retention_days INT NOT NULL,
+  single_file_max_rows INT NOT NULL,
+  export_max_rows INT NOT NULL,
+  updated_at DATETIME(3) NOT NULL,
+  updated_by VARCHAR(128) NOT NULL
+);
+
+CREATE TABLE export_registry_versions (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_code VARCHAR(128) NOT NULL,
+  config_snapshot_digest VARCHAR(128) NOT NULL,
+  parameter_schema_digest VARCHAR(128) NOT NULL,
+  field_mapping_digest VARCHAR(128) NOT NULL,
+  masking_policy_digest VARCHAR(128) NOT NULL,
+  created_at DATETIME(3) NOT NULL,
+  UNIQUE KEY uq_export_registry_versions_snapshot (task_code, config_snapshot_digest)
+);
+
+CREATE TABLE export_task_attempts (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_id VARCHAR(64) NOT NULL,
+  attempt_no INT NOT NULL,
+  lock_owner VARCHAR(128),
+  lock_expire_at DATETIME(3),
+  lease_renewed_at DATETIME(3),
+  started_at DATETIME(3),
+  finished_at DATETIME(3),
+  UNIQUE KEY uq_export_task_attempts_attempt (task_id, attempt_no)
+);
+
+CREATE TABLE export_task_batch_checkpoints (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_id VARCHAR(64) NOT NULL,
+  attempt_no INT NOT NULL,
+  last_cursor VARCHAR(512),
+  processed_count BIGINT NOT NULL,
+  file_part_no INT NOT NULL,
+  database_time DATETIME(3) NOT NULL,
+  updated_at DATETIME(3) NOT NULL
+);
+
+CREATE TABLE export_task_files (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_id VARCHAR(64) NOT NULL,
+  attempt_no INT NOT NULL,
+  file_name VARCHAR(255) NOT NULL,
+  file_size BIGINT NOT NULL,
+  checksum VARCHAR(128) NOT NULL,
+  temp_storage_key VARCHAR(512),
+  published_storage_key VARCHAR(512),
+  storage_key VARCHAR(512) NOT NULL,
+  published_at DATETIME(3),
+  expires_at DATETIME(3) NOT NULL,
+  downloadable BOOLEAN NOT NULL DEFAULT TRUE
+);
+
+CREATE TABLE export_audit_logs (
+  id BIGINT PRIMARY KEY AUTO_INCREMENT,
+  task_id VARCHAR(64),
+  task_code VARCHAR(128) NOT NULL,
+  subsystem_code VARCHAR(128) NOT NULL,
+  operator_id VARCHAR(128) NOT NULL,
+  action VARCHAR(64) NOT NULL,
+  result VARCHAR(32) NOT NULL,
+  error_code VARCHAR(64),
+  request_id VARCHAR(128) NOT NULL,
+  occurred_at DATETIME(3) NOT NULL
+);
