    }

    Start-Sleep -Milliseconds 200
  }

  Stop-Process -Id $process.Id -Force -ErrorAction SilentlyContinue
  throw "LOCAL-RELEASE-REHEARSAL-001 object storage mock did not become ready within 15 seconds."
}

