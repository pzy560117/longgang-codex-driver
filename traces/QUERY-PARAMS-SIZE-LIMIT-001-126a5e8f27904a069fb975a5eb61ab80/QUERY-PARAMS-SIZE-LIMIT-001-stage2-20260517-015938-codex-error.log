+
+  const oversizedQueryParams = createQueryParamsWithCanonicalSize(32769);
+  assert.equal(Buffer.byteLength(canonicalJson(oversizedQueryParams), "utf8"), 32769);
+  const oversizedResponse = await app.inject({
