  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "jszip": "^3.10.1",
    "kysely": "^0.29.0",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "worker:scheduler": "tsx src/workers/scheduler-worker.ts",
    "job:cleanup": "tsx src/jobs/cleanup-job.ts",
    "arch:check": "tsx scripts/arch-check.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.mjs tests/contract/*.test.mjs",
    "test:contract": "node --test tests/contract/*.test.mjs",
    "test:api": "node --import tsx --test --test-concurrency=1 tests/api/*.test.mjs",
    "test:db": "node --import tsx --test --test-concurrency=1 tests/db/*.test.mjs",
    "test:worker": "node --import tsx --test --test-concurrency=1 tests/worker/*.test.mjs",
    "test:query": "node -e \"if (!process.env.EXPORT_PLATFORM_TEST_DATABASE_URL) { console.error('BLOCKED - 需要人工介入: tests/query requires a real MySQL URL in EXPORT_PLATFORM_TEST_DATABASE_URL.'); process.exit(1); }\" && node --import tsx --test --test-concurrency=1 tests/query/*.test.mjs",
    "test:file": "node -e \"if (!process.env.EXPORT_PLATFORM_TEST_DATABASE_URL) { console.error('BLOCKED - 需要人工介入: tests/file requires a real MySQL URL in EXPORT_PLATFORM_TEST_DATABASE_URL.'); process.exit(1); }\" && node --import tsx --test --test-concurrency=1 tests/file/*.test.mjs",
    "test:sample": "node -e \"if (!process.env.EXPORT_PLATFORM_TEST_DATABASE_URL) { console.error('BLOCKED - 需要人工介入: tests/sample requires a real MySQL URL in EXPORT_PLATFORM_TEST_DATABASE_URL.'); process.exit(1); }\" && node --import tsx --test --test-concurrency=1 tests/sample/*.test.mjs",
    "test:object-storage-live": "node --import tsx scripts/object-storage-live-smoke.mjs"
  }
}


