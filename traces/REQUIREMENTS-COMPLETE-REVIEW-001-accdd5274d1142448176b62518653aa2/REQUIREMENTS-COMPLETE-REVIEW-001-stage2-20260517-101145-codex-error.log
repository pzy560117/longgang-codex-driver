      `${reopenedId} must not reappear in Remaining Risks`
    );
  }

  const jsonRemainingRiskText = report.remainingRisks.join("\n");
  for (const findingId of jsonFindingIds) {
    assert.match(jsonRemainingRiskText, new RegExp(`\\b${findingId}\\b`));
  }
});


