  }
  if ($null -ne $ObjectStorageErrorLog -and (Test-Path -LiteralPath $ObjectStorageErrorLog)) {
    Remove-Item -LiteralPath $ObjectStorageErrorLog -Force -ErrorAction SilentlyContinue
  }
}


