+
+function readCursorField(
+  token: CursorToken,
+  field: string
+): string | number | boolean | null {
+  if (!(field in token.values)) {
+    throw queryExecutionError(`cursor field ${field} is missing from checkpoint`);
+  }
+  return token.values[field] ?? null;
+}
