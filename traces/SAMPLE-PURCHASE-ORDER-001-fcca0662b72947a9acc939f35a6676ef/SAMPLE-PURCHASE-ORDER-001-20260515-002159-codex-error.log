import assert from "node:assert/strict";
import test from "node:test";
import mysql from "mysql2";
import { Kysely, MysqlDialect } from "kysely";
import { runMigrations } from "../../src/db/migrator.ts";
import {
  createExportAuditRepository,
  createExportFileRepository,
  createExportRegistryRepository,
  createExportTaskEventRepository,
  createExportTaskRepository,
  getDatabaseTime
} from "../../src/repositories/index.ts";
import { createSchedulerWorker } from "../../src/scheduler/worker.ts";
import { createExportFileService } from "../../src/file-service/index.ts";

function getTestDatabaseUrl() {
  const databaseUrl = process.env.EXPORT_PLATFORM_TEST_DATABASE_URL;

  if (!databaseUrl) {
    throw new Error(
      "BLOCKED - 需要人工介入: tests/sample requires a real MySQL URL in EXPORT_PLATFORM_TEST_DATABASE_URL."
    );
  }

  return databaseUrl;
}

async function createTestDatabase(t) {
  const pool = mysql.createPool(getTestDatabaseUrl());
  const db = new Kysely({
    dialect: new MysqlDialect({ pool })
  });

  t.after(async () => {
    await db.destroy();
  });

  await runMigrations(db);
  await db.deleteFrom("export_task_events").execute();
  await db.deleteFrom("export_task_checkpoints").execute();
  await db.deleteFrom("export_task_files").execute();
  await db.deleteFrom("export_task_leases").execute();
  await db.deleteFrom("export_audit_logs").execute();
  await db.deleteFrom("export_task_idempotency").execute();
  await db.deleteFrom("export_tasks").execute();
  await db.deleteFrom("export_registry_versions").execute();
  await db.deleteFrom("export_registries").execute();
  await db.schema.dropTable("purchase_orders_sample").ifExists().execute();

  await db.schema
    .createTable("purchase_orders_sample")
    .ifNotExists()
    .addColumn("order_id", "varchar(64)", (column) => column.primaryKey())
    .addColumn("tenant_id", "varchar(128)", (column) => column.notNull())
    .addColumn("org_id", "varchar(128)", (column) => column.notNull())
    .addColumn("order_no", "varchar(128)", (column) => column.notNull())
    .addColumn("order_status", "varchar(64)", (column) => column.notNull())
    .addColumn("supplier_id", "varchar(128)", (column) => column.notNull())
    .addColumn("purchase_org_id", "varchar(128)", (column) => column.notNull())
    .addColumn("buyer_name", "varchar(128)", (column) => column.notNull())
    .addColumn("contact_name", "varchar(128)", (column) => column.notNull())
    .addColumn("contact_phone", "varchar(64)", (column) => column.notNull())
    .addColumn("keyword_text", "varchar(255)", (column) => column.notNull())
    .addColumn("order_amount", "varchar(32)", (column) => column.notNull())
    .addColumn("currency_code", "varchar(16)", (column) => column.notNull())
    .addColumn("created_at", "datetime(3)", (column) => column.notNull())
    .execute();

  return db;
}

function createRecordingStorage() {
  const objects = new Map();
  return {
    objects,
    async putObject(input) {
      objects.set(input.storageKey, Buffer.from(input.body));
    },
    async readObject(storageKey) {
      const object = objects.get(storageKey);
      if (!object) {
        throw new Error(`missing object ${storageKey}`);
      }
      return Buffer.from(object);
    },
    async publishObject(input) {
      const object = objects.get(input.tempStorageKey);
      if (!object) {
        throw new Error(`missing temp object ${input.tempStorageKey}`);
      }
      objects.set(input.publishedStorageKey, Buffer.from(object));
    },
    async createDownloadUrl(storageKey) {
      return `signed://download/${storageKey}`;
    }
  };
}

async function seedRegistry(db, overrides = {}) {
  const now = await getDatabaseTime(db);

  await createExportRegistryRepository(db).upsertRegistry({
    taskCode: "purchase-order-export",
    subsystemCode: "purchase",
    displayName: "Purchase Order Export",
    enabled: true,
    concurrencyLimit: 1,
    fileRetentionDays: 7,
    taskHistoryRetentionDays: 30,
    singleFileMaxRows: overrides.singleFileMaxRows ?? 20000,
    exportMaxRows: overrides.exportMaxRows ?? 100000,
    datasourceCode: "purchase-ro",
    supportedFormats: JSON.stringify(["XLSX", "ZIP"]),
    parameterSchema: JSON.stringify({
      type: "object",
      properties: {
        createdAtFrom: { type: "string" },
        createdAtTo: { type: "string" },
        orderStatus: { type: "string" },
        supplierId: { type: "string" },
        purchaseOrgId: { type: "string" },
        keyword: { type: "string" }
      },
      required: ["createdAtFrom", "createdAtTo"]
    }),
    queryTemplate: JSON.stringify({
      queryTemplateVersion: "sample-v1",
      templateText:
        "SELECT order_id AS orderId, tenant_id AS tenantId, org_id AS orgId, order_no AS orderNo, order_status AS orderStatus, supplier_id AS supplierId, purchase_org_id AS purchaseOrgId, buyer_name AS buyerName, contact_name AS contactName, contact_phone AS contactPhone, keyword_text AS keywordText, order_amount AS orderAmount, currency_code AS currencyCode FROM purchase_orders_sample WHERE created_at >= :createdAtFrom AND created_at <= :createdAtTo AND (:orderStatus IS NULL OR order_status = :orderStatus) AND (:supplierId IS NULL OR supplier_id = :supplierId) AND (:purchaseOrgId IS NULL OR purchase_org_id = :purchaseOrgId) AND (:keyword IS NULL OR keyword_text LIKE :keyword)",
      allowedParameters: [
        "createdAtFrom",
        "createdAtTo",
        "orderStatus",
        "supplierId",
        "purchaseOrgId",
        "keyword"
      ]
    }),
    fieldMappings: JSON.stringify([
      {
        fieldCode: "orderId",
        headerName: "Order ID",
        fieldType: "STRING",
        orderNo: 1,
        sensitive: false,
        exportable: true
      },
      {
        fieldCode: "orderNo",
        headerName: "Order No",
        fieldType: "STRING",
        orderNo: 2,
        sensitive: false,
        exportable: true
      },
      {
        fieldCode: "orderStatus",
        headerName: "Order Status",
        fieldType: "STRING",
        orderNo: 3,
        sensitive: false,
        exportable: true
      },
      {
        fieldCode: "supplierId",
        headerName: "Supplier ID",
        fieldType: "STRING",
        orderNo: 4,
        sensitive: false,
        exportable: true
      },
      {
        fieldCode: "purchaseOrgId",
        headerName: "Purchase Org ID",
        fieldType: "STRING",
        orderNo: 5,
        sensitive: false,
        exportable: true
      },
      {
        fieldCode: "contactName",
        headerName: "Contact Name",
        fieldType: "STRING",
        orderNo: 6,
        sensitive: true,
        exportable: true,
        maskingRuleCode: "name_mask"
      },
      {
        fieldCode: "contactPhone",
        headerName: "Contact Phone",
        fieldType: "STRING",
        orderNo: 7,
        sensitive: true,
        exportable: true,
        maskingRuleCode: "phone_mask"
      }
    ]),
    maskingPolicy: JSON.stringify({
      rules: {
        name_mask: {
          type: "PHONE",
          preservePrefix: 0,
          preserveSuffix: 0
        },
        phone_mask: {
          type: "PHONE",
          preservePrefix: 3,
          preserveSuffix: 4
        }
      }
    }),
    dataScopeTemplate: "tenantId = :tenantId and orgId in (:orgScope)",
    cursorField: "orderId",
    orderBy: JSON.stringify([{ field: "orderId", direction: "ASC" }]),
    batchSize: overrides.batchSize ?? 500,
    configSnapshotDigest: "sha256:sample-config-v1",
    parameterSchemaDigest: "sha256:sample-params-v1",
    fieldMappingDigest: "sha256:sample-fields-v1",
    maskingPolicyDigest: "sha256:sample-mask-v1",
    now
  });
}

async function seedTask(db, overrides = {}) {
  const now = await getDatabaseTime(db);
  return createExportTaskRepository(db).createPendingTask({
    taskId: overrides.taskId ?? `sample-${Date.now()}-${process.pid}`,
    taskCode: "purchase-order-export",
    subsystemCode: "purchase",
    tenantId: "tenant-001",
    createdBy: "u001",
    fileFormat: "XLSX",
    clientRequestId: null,
    idempotencyScope: null,
    requestDigest: `sha256:${overrides.taskId ?? Date.now()}`,
    configSnapshotDigest: "sha256:sample-config-v1",
    requestPayload: JSON.stringify({
      queryParams: {
        createdAtFrom: "2026-05-01T00:00:00+08:00",
        createdAtTo: "2026-05-31T23:59:59+08:00",
        orderStatus: "APPROVED",
        supplierId: "SUP-001",
        purchaseOrgId: "PO-001",
        keyword: "PO-2026"
      }
    }),
    authContextPayload: JSON.stringify({
      operatorId: "u001",
      tenantId: "tenant-001",
      roleCodes: ["EXPORT_USER"],
      orgScope: "ORG-001,ORG-002",
      requestId: overrides.requestId ?? "req-sample-001"
    }),
    now
  });
}

async function seedRows(db, count, now) {
  const rows = [];
  for (let index = 0; index < count; index += 1) {
    const sequence = String(index + 1).padStart(6, "0");
    rows.push({
      order_id: `order-${sequence}`,
      tenant_id: "tenant-001",
      org_id: index % 2 === 0 ? "ORG-001" : "ORG-002",
      order_no: `PO-2026-${sequence}`,
      order_status: index % 3 === 0 ? "APPROVED" : "PENDING",
      supplier_id: "SUP-001",
      purchase_org_id: "PO-001",
      buyer_name: `Buyer ${sequence}`,
      contact_name: `Contact ${sequence}`,
      contact_phone: `138${String(10000000 + index).slice(-8)}`,
      keyword_text: index % 2 === 0 ? `PO-2026 ${sequence}` : `PO-2026 other ${sequence}`,
      order_amount: String(100 + index),
      currency_code: "CNY",
      created_at: now
    });
  }

  const chunkSize = 2000;
  for (let index = 0; index < rows.length; index += chunkSize) {
    await db.insertInto("purchase_orders_sample").values(rows.slice(index, index + chunkSize)).execute();
  }
}

async function runSampleExport(db, rowCount, overrides = {}) {
  const now = await getDatabaseTime(db);
  await seedRegistry(db, overrides);
  await seedRows(db, rowCount, now);
  const task = await seedTask(db, overrides);
  const storage = createRecordingStorage();
  const worker = createSchedulerWorker({
    db,
    workerId: "worker-sample",
    leaseDurationSeconds: 300,
    maxTasksPerPoll: 1,
    fileService: createExportFileService({ db, storage })
  });

  const pollResult = await worker.pollAndProcessOnce();
  const fileMetadata = await createExportFileRepository(db).findFileMetadata(task.taskId, 0);
  const events = await createExportTaskEventRepository(db).listRecentTaskEvents(task.taskId);
  const audits = await createExportAuditRepository(db).listAuditLogsForTask(task.taskId);

  return { pollResult, fileMetadata, events, audits, storage, task };
}

test("sample purchase-order registry contract is registered on the production path", async (t) => {
  const db = await createTestDatabase(t);
  await seedRegistry(db);
  const registry = await createExportRegistryRepository(db).findRegistryByTaskCode(
    "purchase-order-export"
  );

  assert.equal(registry?.taskCode, "purchase-order-export");
  assert.equal(registry?.subsystemCode, "purchase");
  assert.equal(registry?.enabled, true);
  assert.equal(registry?.cursorField, "orderId");
  assert.equal(registry?.singleFileMaxRows, 20000);
  assert.equal(registry?.exportMaxRows, 100000);
});

test("sample boundary 0 rows produces a completed export chain", async (t) => {
  const db = await createTestDatabase(t);
  const { pollResult, fileMetadata, events, audits } = await runSampleExport(db, 0);

  assert.equal(pollResult.completed, 1);
  assert.equal(fileMetadata?.fileName.endsWith(".xlsx"), true);
  assert.ok(events.some((event) => event.eventType === "QUERY_READY"));
  assert.ok(events.some((event) => event.eventType === "FILE_VERIFIED"));
  assert.ok(audits.some((audit) => audit.action === "EXECUTE_SUCCESS"));
});

test("sample boundary 1 row keeps sensitive fields masked and cursor stable", async (t) => {
  const db = await createTestDatabase(t);
  const { events, fileMetadata } = await runSampleExport(db, 1);

  assert.ok(events.some((event) => event.eventType === "QUERY_BATCH_DONE"));
  assert.equal(fileMetadata?.fileName.endsWith(".xlsx"), true);
});

test("sample boundary 20000 rows completes with single-file production evidence", async (t) => {
  const db = await createTestDatabase(t);
  const { fileMetadata, events } = await runSampleExport(db, 20000, {
    batchSize: 20000
  });

  assert.equal(fileMetadata?.fileName.endsWith(".xlsx"), true);
  assert.ok(events.filter((event) => event.eventType === "FILE_PART_WRITTEN").length >= 1);
});

test("sample boundary 20001 rows packages ZIP and keeps batch evidence", async (t) => {
  const db = await createTestDatabase(t);
  const { fileMetadata, events } = await runSampleExport(db, 20001, {
    batchSize: 20001
  });

  assert.equal(fileMetadata?.fileName.endsWith(".zip"), true);
  assert.ok(events.filter((event) => event.eventType === "FILE_PART_WRITTEN").length >= 2);
});

test("sample boundary 100000 rows stays within default export limit", async (t) => {
  const db = await createTestDatabase(t);
  const { pollResult, fileMetadata, events } = await runSampleExport(db, 100000, {
    batchSize: 100000
  });

  assert.equal(pollResult.completed, 1);
  assert.equal(fileMetadata?.fileName.endsWith(".zip"), true);
  assert.ok(events.filter((event) => event.eventType === "FILE_PART_WRITTEN").length >= 5);
});

test("sample boundary 100001 rows must be rejected under the default export limit", async (t) => {
  const db = await createTestDatabase(t);
  await seedRegistry(db, { exportMaxRows: 100000 });
  const now = await getDatabaseTime(db);
  await seedRows(db, 100001, now);
  const task = await seedTask(db);
  const worker = createSchedulerWorker({
    db,
    workerId: "worker-sample",
    leaseDurationSeconds: 300,
    maxTasksPerPoll: 1
  });

  await assert.rejects(
    () => worker.pollAndProcessOnce(),
    /EXPORT_LIMIT_EXCEEDED|QUERY_EXECUTION_ERROR/
  );

  const audits = await createExportAuditRepository(db).listAuditLogsForTask(task.taskId);
  assert.ok(audits.some((audit) => audit.action === "EXECUTE_FAILED"));
});

test("sample audit and event chain can be traced through create/query/file/worker records", async (t) => {
  const db = await createTestDatabase(t);
  const now = await getDatabaseTime(db);
  await seedRegistry(db);
  const task = await seedTask(db, { requestId: "req-sample-chain" });
  await createExportAuditRepository(db).appendAuditLog({
    auditId: `audit-${Date.now()}-${process.pid}`,
    taskId: task.taskId,
    attemptNo: task.attemptNo,
    taskCode: task.taskCode,
    subsystemCode: task.subsystemCode,
    operatorId: "u001",
    action: "CREATE",
    result: "SUCCESS",
    errorCode: "SUCCESS",
    requestId: "req-sample-chain",
    occurredAt: now,
    now
  });

  const worker = createSchedulerWorker({
    db,
    workerId: "worker-sample",
    leaseDurationSeconds: 300,
    maxTasksPerPoll: 1,
    batchProcessor: async () => ({
      rows: [],
      checkpoint: {
        lastCursor: null,
        processedCount: 0,
        filePartNo: 1,
        retryCount: 0,
        batchSize: 500,
        batchRowCount: 0,
        backoffMs: 0
      },
      outcome: "completed"
    }),
    fileService: {
      async publishRows() {
        return undefined;
      }
    }
  });

  const pollResult = await worker.pollAndProcessOnce();
  const audits = await createExportAuditRepository(db).listAuditLogsForTask(task.taskId);
  const events = await createExportTaskEventRepository(db).listRecentTaskEvents(task.taskId);

  assert.equal(pollResult.dispatched, 1);
  assert.ok(audits.some((audit) => audit.action === "DISPATCH"));
  assert.ok(audits.some((audit) => audit.action === "EXECUTE_START"));
  assert.ok(events.some((event) => event.eventType === "QUERY_READY"));
});


