];

const forbiddenProductionPattern = /\b(InMemory\w*|mock\w*|fixture\w*)\b/i;
const productionScanRoots = [
  "src/server.ts",
  "src/routes/",
  "src/task-api/",
  "src/registry-config/",
  "src/scheduler/",
  "src/workers/",
