        "404":
          $ref: "#/components/responses/TaskNotFound"
  /export/tasks/{taskId}/retry:
    post:
      tags: [ExportTasks]
      summary: Retry failed export task
      description: |
        Only FAILED tasks are retryable. Retry keeps the original taskId,
        reuses the original config snapshot, increments attemptNo and creates no
        second active execution attempt.
      operationId: retryExportTask
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - $ref: "#/components/parameters/TaskId"
      requestBody:
        required: false
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/TaskActionRequest"
      responses:
        "200":
          description: Retry accepted.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/TaskActionResponseEnvelope"
        "400":
          $ref: "#/components/responses/InvalidTaskState"
        "409":
          $ref: "#/components/responses/ActiveAttemptConflict"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "404":
          $ref: "#/components/responses/TaskNotFound"
  /export/registries:
    post:
      tags: [ExportRegistries]
      summary: Create export registry
      operationId: createExportRegistry
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/ExportRegistryUpsertRequest"
            examples:
              purchaseOrderRegistry:
                value:
                  taskCode: purchase-order-export
                  subsystemCode: purchase
                  displayName: Purchase order export
                  enabled: true
                  concurrencyLimit: 3
                  fileRetentionDays: 15
                  taskHistoryRetentionDays: 30
                  singleFileMaxRows: 20000
                  exportMaxRows: 100000
                  supportedFormats: [XLSX, ZIP]
                  datasourceCode: purchase_ro
                  parameterSchema:
                    required: [createdAtRange]
                    properties:
                      createdAtRange:
                        type: object
                      orderStatus:
                        type: string
                      supplierId:
                        type: string
                      purchaseOrgId:
                        type: string
                      keyword:
                        type: string
                  queryTemplate:
                    queryTemplateVersion: v1
                    templateText: "select ... where created_at between :createdAtFrom and :createdAtTo order by order_id asc"
                    allowedParameters: [createdAtFrom, createdAtTo, orderStatus, supplierId, purchaseOrgId, keyword]
                  fieldMappings:
                    - fieldCode: orderNo
                      headerName: Order No
                      fieldType: STRING
                      orderNo: 1
                      sensitive: false
                      exportable: true
                    - fieldCode: contactPhone
                      headerName: Contact Phone
                      fieldType: STRING
                      orderNo: 10
                      sensitive: true
                      exportable: true
                      maskingRuleCode: phone_mask
                  dataScopeTemplate: "tenant_id = :tenantId and org_id in (:orgScope)"
                  cursorField: orderId
                  orderBy:
                    - field: orderId
                      direction: ASC
                  batchSize: 1000
      responses:
        "201":
          description: Registry created.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryEnvelope"
        "400":
          $ref: "#/components/responses/ValidationError"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "409":
          $ref: "#/components/responses/RegistryConflict"
    get:
      tags: [ExportRegistries]
      summary: List export registries
      operationId: listExportRegistries
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - name: taskCode
          in: query
          schema:
            type: string
        - name: subsystemCode
          in: query
          schema:
            type: string
        - name: enabled
          in: query
          schema:
            type: boolean
        - name: page
          in: query
          schema:
            type: integer
            minimum: 1
            default: 1
        - name: pageSize
          in: query
          schema:
            type: integer
            minimum: 1
            maximum: 100
            default: 20
      responses:
        "200":
          description: Paged registry list.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryPageEnvelope"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
  /export/registries/{taskCode}:
    get:
      tags: [ExportRegistries]
      summary: Get export registry
      operationId: getExportRegistry
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - $ref: "#/components/parameters/TaskCode"
      responses:
        "200":
          description: Registry detail.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryEnvelope"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "404":
          $ref: "#/components/responses/TaskNotRegistered"
    put:
      tags: [ExportRegistries]
      summary: Update export registry
      description: Registry updates only affect tasks created after the update.
      operationId: updateExportRegistry
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - $ref: "#/components/parameters/TaskCode"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/ExportRegistryUpsertRequest"
      responses:
        "200":
          description: Registry updated.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryEnvelope"
        "400":
          $ref: "#/components/responses/ValidationError"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "404":
          $ref: "#/components/responses/TaskNotRegistered"
  /export/registries/{taskCode}/enable:
    post:
      tags: [ExportRegistries]
      summary: Enable export registry
      operationId: enableExportRegistry
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - $ref: "#/components/parameters/TaskCode"
      responses:
        "200":
          description: Registry enabled.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryEnvelope"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "404":
          $ref: "#/components/responses/TaskNotRegistered"
  /export/registries/{taskCode}/disable:
    post:
      tags: [ExportRegistries]
      summary: Disable export registry
      operationId: disableExportRegistry
      parameters:
        - $ref: "#/components/parameters/XOperatorId"
        - $ref: "#/components/parameters/XTenantId"
        - $ref: "#/components/parameters/XRoleCodes"
        - $ref: "#/components/parameters/XOrgScope"
        - $ref: "#/components/parameters/XRequestId"
        - $ref: "#/components/parameters/TaskCode"
      responses:
        "200":
          description: Registry disabled.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ExportRegistryEnvelope"
        "401":
          $ref: "#/components/responses/AuthContextMissing"
        "403":
          $ref: "#/components/responses/PermissionDenied"
        "404":
          $ref: "#/components/responses/TaskNotRegistered"
components:
  securitySchemes:
    AuthContext:
      type: apiKey
      in: header
      name: X-Request-Id
      description: |
        The gateway or caller must forward the full auth context headers defined
        by X-Operator-Id, X-Tenant-Id, X-Role-Codes, X-Org-Scope and X-Request-Id.
  parameters:
    XOperatorId:
      name: X-Operator-Id
      in: header
      required: true
      schema:
        type: string
      description: Authenticated operator id.
    XTenantId:
      name: X-Tenant-Id
      in: header
      required: true
      schema:
        type: string
      description: Tenant id for task visibility and data scope.
    XRoleCodes:
      name: X-Role-Codes
      in: header
      required: true
      schema:
        type: string
      description: Comma-separated role codes.
    XOrgScope:
      name: X-Org-Scope
      in: header
      required: true
      schema:
        type: string
      description: Organization scope expression or encoded scope list.
    XRequestId:
      name: X-Request-Id
      in: header
      required: true
      schema:
        type: string
      description: Upstream request id used by audit logs and task events.
    TaskId:
      name: taskId
      in: path
      required: true
      schema:
        type: string
    TaskCode:
      name: taskCode
      in: path
      required: true
      schema:
        type: string
  responses:
    ValidationError:
      description: Validation failed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            validation:
              value:
                code: VALIDATION_ERROR
                message: validation failed
                data: null
                errors:
                  - field: taskCode
                    reason: required
    AuthContextMissing:
      description: Required auth context is missing or malformed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            authMissing:
              value:
                code: AUTH_CONTEXT_MISSING
                message: auth context missing
                data: null
    PermissionDenied:
      description: Operator has no permission for the task, registry or file.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            denied:
              value:
                code: PERMISSION_DENIED
                message: permission denied
                data: null
    TaskNotFound:
      description: Task not found or invisible to current operator.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notFound:
              value:
                code: TASK_NOT_FOUND
                message: task not found
                data: null
    TaskNotRegistered:
      description: taskCode is not registered.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notRegistered:
              value:
                code: TASK_NOT_REGISTERED
                message: task code not registered
                data: null
    QueryParamsTooLarge:
      description: queryParams exceeds the 32KB default limit.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            tooLarge:
              value:
                code: QUERY_PARAMS_TOO_LARGE
                message: queryParams exceeds 32768 bytes
                data: null
    IdempotencyConflict:
      description: Same idempotency scope with different request digest.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            conflict:
              value:
                code: IDEMPOTENCY_CONFLICT
                message: clientRequestId conflicts with a different request digest
                data:
                  idempotencyScope: tenant-001:u001:purchase-order-export:req-20260513-0001
    InvalidTaskState:
      description: Operation is not allowed for current official task status.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            invalidRetry:
              value:
                code: INVALID_TASK_STATE
                message: current task status does not allow this operation
                data:
                  status: EXECUTING
    ActiveAttemptConflict:
      description: Another active execution attempt already exists.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            activeAttempt:
              value:
                code: ACTIVE_ATTEMPT_CONFLICT
                message: active execution attempt already exists
                data:
                  taskId: exp_20260513_000001
                  attemptNo: 1
    FileExpired:
      description: File is expired or marked as not downloadable.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            expired:
              value:
                code: FILE_EXPIRED
                message: file expired
                data: null
    RegistryConflict:
      description: Registry taskCode already exists or conflicts with immutable fields.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            duplicate:
              value:
                code: REGISTRY_CONFLICT
                message: taskCode already exists
                data: null
  schemas:
    ResponseCode:
      type: string
      enum:
        - SUCCESS
        - VALIDATION_ERROR
        - AUTH_CONTEXT_MISSING
        - PERMISSION_DENIED
        - TASK_NOT_FOUND
        - TASK_NOT_REGISTERED
        - TASK_DISABLED
        - QUERY_PARAMS_TOO_LARGE
        - IDEMPOTENCY_CONFLICT
        - INVALID_TASK_STATE
        - FILE_EXPIRED
        - FILE_NOT_READY
        - FILE_VERIFY_ERROR
        - QUERY_TEMPLATE_INVALID
        - DATASOURCE_UNAVAILABLE
        - QUERY_EXECUTION_ERROR
        - FIELD_MAPPING_INVALID
        - MASKING_RULE_ERROR
        - EXPORT_RENDER_ERROR
        - EXPORT_LIMIT_EXCEEDED
        - REGISTRY_CONFLICT
        - ACTIVE_ATTEMPT_CONFLICT
        - INTERNAL_ERROR
    TaskStatus:
      type: string
      description: Official public task status. Internal cancel flags are not valid values.
      enum: [PENDING, EXECUTING, COMPLETED, FAILED, CANCELED, EXPIRED]
    FileFormat:
      type: string
      enum: [XLSX, ZIP]
    DeliveryMode:
      type: string
      enum: [SIGNED_URL, STREAM]
    Envelope:
      type: object
      required: [code, message]
      properties:
        code:
          $ref: "#/components/schemas/ResponseCode"
        message:
          type: string
    ErrorEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          properties:
            data:
              type: object
              nullable: true
              additionalProperties: true
            errors:
              type: array
              items:
                $ref: "#/components/schemas/FieldError"
    FieldError:
      type: object
      required: [field, reason]
      properties:
        field:
          type: string
        reason:
          type: string
    CreateExportTaskRequest:
      type: object
      required: [taskCode, subsystemCode, fileFormat, queryParams]
      properties:
        taskCode:
          type: string
        subsystemCode:
          type: string
        fileFormat:
          $ref: "#/components/schemas/FileFormat"
        clientRequestId:
          type: string
          maxLength: 128
          description: Optional idempotency key scoped by tenantId/operatorId/taskCode.
        queryParams:
          type: object
          additionalProperties: true
          description: Must match registry parameter schema and must not exceed 32768 bytes after canonical JSON serialization.
        deliveryPreference:
          $ref: "#/components/schemas/DeliveryMode"
    CreateExportTaskResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/CreateExportTaskResponse"
    CreateExportTaskResponse:
      type: object
      required:
        - taskId
        - taskCode
        - subsystemCode
        - status
        - requestDigest
        - configSnapshotDigest
        - attemptNo
        - createdAt
      properties:
        taskId:
          type: string
        taskCode:
          type: string
        subsystemCode:
          type: string
        status:
          type: string
          enum: [PENDING]
        clientRequestId:
          type: string
        idempotencyHit:
          type: boolean
        requestDigest:
          type: string
        configSnapshotDigest:
          type: string
        attemptNo:
          type: integer
          minimum: 0
        createdAt:
          type: string
          format: date-time
    ExportTaskDetailEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportTaskDetail"
    ExportTaskDetail:
      type: object
      required:
        - taskId
        - taskCode
        - subsystemCode
        - status
        - totalCount
        - processedCount
        - progressPercent
        - attemptNo
        - requestId
        - requestDigest
        - configSnapshotDigest
        - createdBy
        - createdAt
        - updatedAt
      properties:
        taskId:
          type: string
        taskCode:
          type: string
        subsystemCode:
          type: string
        status:
          $ref: "#/components/schemas/TaskStatus"
        totalCount:
          type: integer
          format: int64
          minimum: 0
        processedCount:
          type: integer
          format: int64
          minimum: 0
        progressPercent:
          type: number
          minimum: 0
          maximum: 100
        fileFormat:
          $ref: "#/components/schemas/FileFormat"
        attemptNo:
          type: integer
          minimum: 0
        errorCode:
          $ref: "#/components/schemas/ResponseCode"
        errorMessage:
          type: string
        failureStage:
          type: string
        lastSuccessStage:
          type: string
        requestId:
          type: string
        requestDigest:
          type: string
        configSnapshotDigest:
          type: string
        createdBy:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        file:
          $ref: "#/components/schemas/FileMetadata"
        batchCheckpoint:
          $ref: "#/components/schemas/BatchCheckpoint"
        recentEvents:
          type: array
          items:
            $ref: "#/components/schemas/TaskEvent"
        auditEvents:
          type: array
          items:
            $ref: "#/components/schemas/AuditEvent"
    ExportTaskPageEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportTaskPage"
    ExportTaskPage:
      type: object
      required: [items, page, pageSize, total]
      properties:
        items:
          type: array
          items:
            $ref: "#/components/schemas/ExportTaskDetail"
        page:
          type: integer
        pageSize:
          type: integer
        total:
          type: integer
          format: int64
    DownloadResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/DownloadResponse"
    DownloadResponse:
      allOf:
        - $ref: "#/components/schemas/FileMetadata"
        - type: object
          required: [deliveryMode]
          properties:
            deliveryMode:
              $ref: "#/components/schemas/DeliveryMode"
            downloadUrl:
              type: string
              format: uri
            expiresAt:
              type: string
              format: date-time
    FileMetadata:
      type: object
      required:
        - fileName
        - fileSize
        - contentType
        - checksum
        - checksumAlgorithm
        - storageKey
        - attemptNo
      properties:
        fileName:
          type: string
        fileSize:
          type: integer
          format: int64
        contentType:
          type: string
        tempStorageKey:
          type: string
        publishedStorageKey:
          type: string
        storageKey:
          type: string
        checksum:
          type: string
        checksumAlgorithm:
          type: string
          enum: [SHA-256]
        checksumVerifiedAt:
          type: string
          format: date-time
        publishedAt:
          type: string
          format: date-time
        deliveryReadyAt:
          type: string
          format: date-time
        attemptNo:
          type: integer
          minimum: 1
    TaskActionRequest:
      type: object
      properties:
        reason:
          type: string
          maxLength: 500
    TaskActionResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/TaskActionResponse"
    TaskActionResponse:
      type: object
      required: [taskId, status, attemptNo, acceptedAt]
      properties:
        taskId:
          type: string
        status:
          $ref: "#/components/schemas/TaskStatus"
        attemptNo:
          type: integer
        cancelAccepted:
          type: boolean
          description: True means an EXECUTING task will stop at a batch boundary; this is not a task status.
        retryAccepted:
          type: boolean
        configSnapshotDigest:
          type: string
        acceptedAt:
          type: string
          format: date-time
    ExportRegistryUpsertRequest:
      type: object
      required:
        - taskCode
        - subsystemCode
        - displayName
        - enabled
        - concurrencyLimit
        - fileRetentionDays
        - taskHistoryRetentionDays
        - singleFileMaxRows
        - exportMaxRows
        - supportedFormats
        - datasourceCode
        - parameterSchema
        - queryTemplate
        - fieldMappings
        - dataScopeTemplate
        - cursorField
        - orderBy
        - batchSize
      properties:
        taskCode:
          type: string
        subsystemCode:
          type: string
        displayName:
          type: string
        enabled:
          type: boolean
        concurrencyLimit:
          type: integer
          minimum: 1
        fileRetentionDays:
          type: integer
          minimum: 1
          default: 15
        taskHistoryRetentionDays:
          type: integer
          minimum: 1
          default: 30
        singleFileMaxRows:
          type: integer
          minimum: 1
          default: 20000
        exportMaxRows:
          type: integer
          minimum: 1
          default: 100000
        supportedFormats:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FileFormat"
        datasourceCode:
          type: string
          description: Must reference a registered read-only datasource or data platform dataset.
        parameterSchema:
          type: object
          additionalProperties: true
        queryTemplate:
          $ref: "#/components/schemas/QueryTemplateContract"
        fieldMappings:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FieldMapping"
        maskingPolicy:
          type: object
          additionalProperties: true
        dataScopeTemplate:
          type: string
          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.
        cursorField:
          type: string
        orderBy:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/OrderBy"
        batchSize:
          type: integer
          minimum: 1
    ExportRegistryEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportRegistry"
    ExportRegistryPageEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              type: object
              required: [items, page, pageSize, total]
              properties:
                items:
                  type: array
                  items:
                    $ref: "#/components/schemas/ExportRegistry"
                page:
                  type: integer
                pageSize:
                  type: integer
                total:
                  type: integer
                  format: int64
    ExportRegistry:
      allOf:
        - $ref: "#/components/schemas/ExportRegistryUpsertRequest"
        - type: object
          required: [configSnapshotDigest, updatedAt, updatedBy]
          properties:
            configSnapshotDigest:
              type: string
            updatedAt:
              type: string
              format: date-time
            updatedBy:
              type: string
    QueryTemplateContract:
      type: object
      required: [queryTemplateVersion, templateText, allowedParameters]
      properties:
        queryTemplateVersion:
          type: string
        templateText:
          type: string
          description: Parameterized query template. Raw SQL from callers is forbidden.
        allowedParameters:
          type: array
          items:
            type: string
    FieldMapping:
      type: object
      required: [fieldCode, headerName, fieldType, orderNo, sensitive, exportable]
      properties:
        fieldCode:
          type: string
        headerName:
          type: string
        fieldType:
          type: string
          enum: [STRING, NUMBER, DECIMAL, DATETIME, DATE, BOOLEAN]
        orderNo:
          type: integer
          minimum: 1
        sensitive:
          type: boolean
        exportable:
          type: boolean
        maskingRuleCode:
          type: string
    OrderBy:
      type: object
      required: [field, direction]
      properties:
        field:
          type: string
        direction:
          type: string
          enum: [ASC, DESC]
    BatchCheckpoint:
      type: object
      properties:
        lastCursor:
          type: string
        processedCount:
          type: integer
          format: int64
        filePartNo:
          type: integer
        attemptNo:
          type: integer
        batchSize:
          type: integer
