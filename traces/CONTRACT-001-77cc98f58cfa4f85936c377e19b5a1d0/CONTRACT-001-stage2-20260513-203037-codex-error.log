  parameters:
    XOperatorId:
      name: X-Operator-Id
      in: header
      required: true
      schema:
        type: string
      description: Authenticated operator id.
    XTenantId:
      name: X-Tenant-Id
      in: header
      required: true
      schema:
        type: string
      description: Tenant id for task visibility and data scope.
    XRoleCodes:
      name: X-Role-Codes
      in: header
      required: true
      schema:
        type: string
      description: Comma-separated role codes.
    XOrgScope:
      name: X-Org-Scope
      in: header
      required: true
      schema:
        type: string
      description: Organization scope expression or encoded scope list.
    XRequestId:
      name: X-Request-Id
      in: header
      required: true
      schema:
        type: string
      description: Upstream request id used by audit logs and task events.
    TaskId:
      name: taskId
      in: path
      required: true
      schema:
        type: string
    TaskCode:
      name: taskCode
      in: path
      required: true
      schema:
        type: string
  responses:
    ValidationError:
      description: Validation failed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            validation:
              value:
                code: VALIDATION_ERROR
                message: validation failed
                data: null
                errors:
                  - field: taskCode
                    reason: required
    AuthContextMissing:
      description: Required auth context is missing or malformed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            authMissing:
              value:
                code: AUTH_CONTEXT_MISSING
                message: auth context missing
                data: null
    PermissionDenied:
      description: Operator has no permission for the task, registry or file.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            denied:
              value:
                code: PERMISSION_DENIED
                message: permission denied
                data: null
    TaskNotFound:
      description: Task not found or invisible to current operator.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notFound:
