const fs = require('fs');
const yaml = require('yaml');
const doc = yaml.parse(fs.readFileSync('contracts/openapi.yaml', 'utf8'));
const methods = new Set(['get','put','post','delete','patch','options','head','trace']);
const operations = [];
for (const [path, item] of Object.entries(doc.paths || {})) {
  for (const [method, op] of Object.entries(item || {})) {
    if ("'!methods.has(method)) continue;
    operations.push({ path, method: method.toUpperCase(), operationId: op.operationId, responses: Object.keys(op.responses || {}) });
  }
}
const trace = doc['"'x-contract-implementation-trace']?.operations || {};
const issues = [];
for (const op of operations) {
  if ("'!op.operationId) issues.push(`${op.method} ${op.path} missing operationId`);
  const entry = trace[op.operationId];
  if (!entry) {
    issues.push(`${op.operationId} missing x-contract-implementation-trace entry`);
    continue;
  }
  for (const key of ['"'http','requirements','acceptanceExamples','handler','db','worker','audit','file','tests']) {
    if ("'!(key in entry)) issues.push(`${op.operationId} missing trace.${key}`);
  }
  if (!Array.isArray(entry.tests) || entry.tests.length === 0) issues.push(`${op.operationId} has no tests mapping`);
  if (!entry.handler || !String(entry.handler).startsWith('"'src/routes/')) issues.push("'`${op.operationId} handler target is not src/routes/*`);
}
const auditEnum = doc.components?.schemas?.AuditEvent?.properties?.action?.enum || [];
for (const [operationId, entry] of Object.entries(trace)) {
  for (const action of entry.audit || []) {
    if (!auditEnum.includes(action)) issues.push(`${operationId} audit action ${action} missing from AuditEvent enum`);
  }
}
console.log(JSON.stringify({ operationCount: operations.length, operationIds: operations.map(o => o.operationId), issues }, null, 2));
process.exit(issues.length ? 1 : 0);
