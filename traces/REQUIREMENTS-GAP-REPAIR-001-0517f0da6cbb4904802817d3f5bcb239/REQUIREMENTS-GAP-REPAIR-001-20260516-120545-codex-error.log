    fileName: "cleanup.xlsx",
    contentType: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
    fileSize: 1024,
    checksum: "sha256:cleanup",
    checksumAlgorithm: "SHA-256",
    tempStorageKey: "exports/tmp/cleanup.xlsx",
