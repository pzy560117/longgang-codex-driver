    taskCode: firstTaskCode,
    subsystemCode,
    concurrencyLimit: 1
  });
  await seedRegistry(db, {
    runId,
    taskCode: secondTaskCode,
    subsystemCode,
    concurrencyLimit: 1
  });
  await seedTask(db, {
    taskId: `exp-worker-${runId}-cross-a`,
    taskCode: firstTaskCode,
    subsystemCode
  });
  await seedTask(db, {
    taskId: `exp-worker-${runId}-cross-b`,
    taskCode: secondTaskCode,
    subsystemCode
  });

  const workerA = createSchedulerWorker({
    db,
