      const error = new Error("query still unavailable");
      error.name = "QUERY_EXECUTION_ERROR";
      throw error;
    }
  });

  const firstPoll = await worker.pollAndProcessOnce();
  const secondPoll = await worker.pollAndProcessOnce();
