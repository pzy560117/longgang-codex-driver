 420: function resolveHeaders(
 421:   registry: ExportRegistryRecord,
 422:   rows: Record<string, unknown>[]
 423: ): string[] {
 424:   const headers = parseFieldHeaders(registry);
 425:   if (headers.length === 0 && rows.length > 0) {
 426:     return Object.keys(rows[0]);
 427:   }
 428:   for (const row of rows) {
 429:     const rowHeaders = Object.keys(row);
 430:     if (
 431:       rowHeaders.length !== headers.length ||
 432:       rowHeaders.some((header, index) => header !== headers[index])
 433:     ) {
 434:       throw fileError("FIELD_MAPPING_INVALID", "row headers do not match registry field order");
 435:     }
 436:   }
 437:   return headers;
 438: }
 439: 
 440: function parseFieldHeaders(registry: ExportRegistryRecord): string[] {
 441:   if (!registry.fieldMappings) {
 442:     return [];
 443:   }
 444:   let fieldMappings: Array<{
 445:     headerName?: unknown;
 446:     orderNo?: unknown;
 447:     exportable?: boolean;
 448:   }>;
 449:   try {
 450:     fieldMappings = JSON.parse(registry.fieldMappings) as Array<{
 451:       headerName?: unknown;
 452:       orderNo?: unknown;
 453:       exportable?: boolean;
 454:     }>;
 455:   } catch {
 456:     throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings must be valid JSON");
 457:   }
 458:   if (!Array.isArray(fieldMappings)) {
 459:     throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings must be an array");
 460:   }
 461:   return fieldMappings
 462:     .filter((mapping) => mapping.exportable !== false)
 463:     .sort((left, right) => Number(left.orderNo ?? 0) - Number(right.orderNo ?? 0))
 464:     .map((mapping) => {
 465:       if (typeof mapping.headerName !== "string" || mapping.headerName.length === 0) {
 466:         throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings contain empty headers");
 467:       }
 468:       return mapping.headerName;
 469:     });
 470: }
