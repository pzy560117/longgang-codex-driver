    const rows =
      outcome === "completed" && (context.checkpoint?.processedCount ?? 0) > 0
        ? await collectCompletedRows({
            db: context.db,
            datasourceAdapter,
            template,
            queryParams,
            dataScope,
            orderBy,
            batchSize,
