      context,
      eventType: "QUERY_READY",
      datasourceCode: registry.datasourceCode,
      queryTemplateVersion: template.queryTemplateVersion ?? context.task.configSnapshotDigest,
      batchCheckpoint: {
        taskId: context.task.taskId,
