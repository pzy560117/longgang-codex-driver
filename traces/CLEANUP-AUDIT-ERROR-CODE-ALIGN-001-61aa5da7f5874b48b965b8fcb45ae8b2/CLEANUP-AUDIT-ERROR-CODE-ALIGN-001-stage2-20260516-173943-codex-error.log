 132: export function createCleanupObjectStorageFromEnv(): CleanupObjectStorage {
 133:   const endpoint = process.env.EXPORT_PLATFORM_OBJECT_STORAGE_ENDPOINT;
 134:   const bucket = process.env.EXPORT_PLATFORM_OBJECT_STORAGE_BUCKET;
 135: 
 136:   if (!endpoint || !bucket) {
 137:     throw new Error(
 138:       "BLOCKED - 需要人工介入: object storage endpoint and bucket must be configured for cleanup."
 139:     );
 140:   }
 141: 
 142:   const normalizedEndpoint = endpoint.replace(/\/+$/, "");
 143: 
 144:   return {
 145:     async deleteObject(storageKey) {
 146:       const response = await fetch(
 147:         `${normalizedEndpoint}/${encodeURIComponent(bucket)}/${encodeStorageKey(storageKey)}`,
 148:         {
 149:           method: "DELETE"
 150:         }
 151:       );
 152:       if (!response.ok && response.status !== 404) {
 153:         const error = new Error(`object storage delete failed: ${response.status}`);
 154:         error.name = "FILE_CLEANUP_DELETE_ERROR";
 155:         throw error;
 156:       }
 157:     }
 158:   };
 159: }
