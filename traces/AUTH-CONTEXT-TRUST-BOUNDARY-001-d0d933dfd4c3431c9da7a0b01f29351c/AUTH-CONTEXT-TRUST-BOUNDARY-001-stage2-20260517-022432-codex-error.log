+      headers["x-operator-id"],
+      headers["x-tenant-id"],
+      headers["x-role-codes"],
+      headers["x-org-scope"],
+      headers["x-request-id"],
+      headers["x-auth-context-issued-at"]
+    ].join("\n"))
+    .digest("hex");
