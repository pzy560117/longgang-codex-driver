  assert.equal(duplicateRegistryAudits[0].error_code, "REGISTRY_CONFLICT");

  const concurrentTaskCode = `${taskCode}-concurrent`;
  const [concurrentFirstResponse, concurrentSecondResponse] = await Promise.all([
