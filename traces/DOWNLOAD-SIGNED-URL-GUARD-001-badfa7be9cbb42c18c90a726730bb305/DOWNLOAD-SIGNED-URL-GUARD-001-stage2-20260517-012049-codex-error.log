 978: export async function downloadSignedExportTask(
 979:   taskId: string,
 980:   query: SignedDownloadQuery
 981: ): Promise<DownloadStreamResponse> {
 982:   return withDatabase(async (db) => {
 983:     const now = await getDatabaseTime(db);
 984:     const expiresAt = readSignedQueryText(query.expiresAt);
 985:     const signature = readSignedQueryText(query.signature);
 986:     const untrustedOperatorId = readSignedQueryText(query.operatorId);
 987:     const untrustedTenantId = readSignedQueryText(query.tenantId);
 988:     const untrustedRoleCodes = readSignedQueryText(query.roleCodes) ?? "";
 989:     const untrustedOrgScope = readSignedQueryText(query.orgScope);
 990:     const untrustedRequestId = readSignedQueryText(query.requestId);
 991:     const systemAuth: AuthContext = {
 992:       operatorId: "signed-download",
 993:       tenantId: "",
 994:       roleCodes: [],
 995:       orgScope: "",
 996:       requestId: `signed-download-${randomUUID()}`
 997:     };
 998:     const task = await createExportTaskRepository(db).findTaskById(taskId);
 999:     const file = task
1000:       ? await createExportFileRepository(db).findFileMetadata(taskId, task.attemptNo)
1001:       : null;
1002: 
1003:     const unverifiedAuditBase = {
1004:       db,
1005:       auth: systemAuth,
1006:       action: "DOWNLOAD",
1007:       now,
1008:       taskId,
1009:       attemptNo: task?.attemptNo ?? null,
1010:       taskCode: task?.taskCode ?? null,
1011:       subsystemCode: task?.subsystemCode ?? null
1012:     };
1013: 
1014:     if (
1015:       query.signatureAlgorithm !== "HMAC-SHA256" ||
1016:       !expiresAt ||
1017:       !signature ||
1018:       !untrustedOperatorId ||
1019:       !untrustedTenantId ||
1020:       !untrustedRequestId
1021:     ) {
1022:       return rejectWithAudit({
1023:         ...unverifiedAuditBase,
1024:         error: new ApiError(403, "SIGNATURE_INVALID", "download signature is invalid")
