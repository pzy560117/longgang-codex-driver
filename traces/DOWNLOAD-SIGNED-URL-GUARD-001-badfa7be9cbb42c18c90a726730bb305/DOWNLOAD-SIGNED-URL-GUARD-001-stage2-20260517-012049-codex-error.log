1029:       return rejectWithAudit({
1030:         ...unverifiedAuditBase,
1031:         error: new ApiError(403, "SIGNATURE_INVALID", "download signature expiry is invalid")
1032:       });
1033:     }
1034:     if (expiresAtTime <= now.getTime()) {
1035:       return rejectWithAudit({
1036:         ...unverifiedAuditBase,
1037:         error: new ApiError(403, "SIGNATURE_EXPIRED", "download signature expired")
1038:       });
1039:     }
1040:     if (!task || !file?.publishedStorageKey) {
1041:       return rejectWithAudit({
1042:         ...unverifiedAuditBase,
1043:         error: new ApiError(403, "SIGNATURE_INVALID", "download signature is invalid")
1044:       });
1045:     }
1046: 
1047:     const expectedSignature = createSignedDownloadSignature({
1048:       taskId,
1049:       storageKey: file.publishedStorageKey,
1050:       expiresAt,
1051:       operatorId: untrustedOperatorId,
1052:       tenantId: untrustedTenantId,
1053:       roleCodes: untrustedRoleCodes,
1054:       orgScope: untrustedOrgScope ?? "",
1055:       requestId: untrustedRequestId,
1056:       secret: requireDownloadSigningSecret()
1057:     });
1058:     if (!isValidSignature(signature, expectedSignature)) {
1059:       return rejectWithAudit({
1060:         ...unverifiedAuditBase,
1061:         error: new ApiError(403, "SIGNATURE_INVALID", "download signature is invalid")
1062:       });
1063:     }
1064: 
1065:     const auth: AuthContext = {
1066:       operatorId: untrustedOperatorId,
1067:       tenantId: untrustedTenantId,
1068:       roleCodes: untrustedRoleCodes.split(",").map((role) => role.trim()).filter(Boolean),
1069:       orgScope: untrustedOrgScope ?? "",
1070:       requestId: untrustedRequestId
1071:     };
1072:     const verifiedAuditBase = {
1073:       ...unverifiedAuditBase,
1074:       auth
1075:     };
1076:     if (task.status !== "COMPLETED" || !file.deliveryReadyAt) {
