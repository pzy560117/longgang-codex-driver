  70: async function createLocalObjectStorageServer(t, options = {}) {
  71:   const bucket = options.bucket ?? "export-platform-local-dev";
  72:   const objects = new Map();
  73:   const requests = [];
  74:   const server = http.createServer(async (request, response) => {
  75:     const url = new URL(request.url ?? "/", `http://${request.headers.host ?? "127.0.0.1"}`);
  76:     const pathSegments = url.pathname.split("/").filter(Boolean);
  77:     const requestBucket = pathSegments.shift();
  78:     const storageKey = decodeStorageKey(pathSegments);
  79: 
  80:     if (requestBucket !== bucket || !storageKey) {
  81:       response.statusCode = 404;
  82:       response.end("not found");
  83:       return;
  84:     }
  85: 
  86:     const copySource = request.headers["x-export-copy-source"];
  87:     requests.push({
  88:       method: request.method ?? "GET",
  89:       storageKey,
  90:       copySource: typeof copySource === "string" ? copySource : null
  91:     });
  92: 
  93:     if (request.method === "PUT") {
  94:       if (typeof copySource === "string") {
  95:         const [sourceBucket, ...sourceKeySegments] = copySource.split("/");
  96:         const sourceStorageKey = sourceKeySegments.join("/");
  97:         if (sourceBucket !== bucket || !objects.has(sourceStorageKey)) {
  98:           response.statusCode = 404;
  99:           response.end("missing source object");
 100:           return;
 101:         }
 102:         objects.set(storageKey, Buffer.from(objects.get(sourceStorageKey)));
 103:         response.statusCode = 201;
 104:         response.end("copied");
 105:         return;
 106:       }
 107: 
 108:       objects.set(storageKey, await readRequestBody(request));
 109:       response.statusCode = 201;
 110:       response.end("stored");
 111:       return;
 112:     }
 113: 
 114:     if (request.method === "GET") {
 115:       const body = objects.get(storageKey);
 116:       if (!body) {
 117:         response.statusCode = 404;
 118:         response.end("missing object");
 119:         return;
 120:       }
 121: 
 122:       response.statusCode = 200;
 123:       response.setHeader("content-type", "application/octet-stream");
 124:       response.end(body);
 125:       return;
 126:     }
 127: 
 128:     response.statusCode = 405;
 129:     response.end("method not allowed");
 130:   });
 131: 
 132:   server.listen(0, "127.0.0.1");
 133:   await once(server, "listening");
 134: 
 135:   t.after(
