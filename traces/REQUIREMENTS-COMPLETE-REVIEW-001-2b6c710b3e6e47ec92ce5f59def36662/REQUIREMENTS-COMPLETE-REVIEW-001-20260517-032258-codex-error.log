components:
  securitySchemes:
    OperatorId:
      type: apiKey
      in: header
      name: X-Operator-Id
      description: Authenticated operator id forwarded by gateway or caller.
    TenantId:
      type: apiKey
      in: header
      name: X-Tenant-Id
      description: Tenant id forwarded by gateway or caller.
    RoleCodes:
      type: apiKey
      in: header
      name: X-Role-Codes
      description: Comma-separated role codes forwarded by gateway or caller.
    OrgScope:
      type: apiKey
      in: header
      name: X-Org-Scope
      description: Organization scope forwarded by gateway or caller.
    RequestId:
      type: apiKey
      in: header
      name: X-Request-Id
      description: Request id used by audit logs and task events.
    AuthContextSignature:
      type: apiKey
      in: header
      name: X-Auth-Context-Signature
      description: HMAC-SHA256 proof that the ingress authenticated the auth context headers.
    AuthContextIssuedAt:
      type: apiKey
      in: header
      name: X-Auth-Context-Issued-At
      description: Timestamp included in the auth context HMAC proof.
    AuthContextSignatureAlgorithm:
      type: apiKey
      in: header
      name: X-Auth-Context-Signature-Algorithm
      description: Auth context signature algorithm. Current value must be HMAC-SHA256.
  parameters:
    XOperatorId:
      name: X-Operator-Id
      in: header
      required: true
      schema:
        type: string
      description: Authenticated operator id.
    XTenantId:
      name: X-Tenant-Id
      in: header
      required: true
      schema:
        type: string
      description: Tenant id for task visibility and data scope.
    XRoleCodes:
      name: X-Role-Codes
      in: header
      required: true
      schema:
        type: string
      description: Comma-separated role codes.
    XOrgScope:
      name: X-Org-Scope
      in: header
      required: true
      schema:
        type: string
      description: Organization scope expression or encoded scope list.
    XRequestId:
      name: X-Request-Id
      in: header
      required: true
      schema:
        type: string
      description: Upstream request id used by audit logs and task events.
    XAuthContextSignature:
      name: X-Auth-Context-Signature
      in: header
      required: true
      schema:
        type: string
      description: HMAC-SHA256 proof that the ingress authenticated the auth context headers. No nonce or replay-deduplication store is part of this contract; identical signed headers may be replayed within the accepted freshness window.
    XAuthContextIssuedAt:
      name: X-Auth-Context-Issued-At
      in: header
      required: true
      schema:
        type: string
        format: date-time
      description: Timestamp included in the auth context HMAC proof. freshness boundary only: issuedAt must be no more than 5 minutes in the future and no older than 10 minutes relative to server time.
    XAuthContextSignatureAlgorithm:
      name: X-Auth-Context-Signature-Algorithm
      in: header
      required: true
      schema:
        type: string
        enum: [HMAC-SHA256]
      description: Auth context signature algorithm.
    TaskId:
      name: taskId
      in: path
      required: true
      schema:
        type: string
    TaskCode:
      name: taskCode
      in: path
      required: true
      schema:
        type: string
  responses:
    AuthContextMissing:
      description: Required auth context is missing, malformed, outside the trusted freshness boundary, or lacks trusted ingress proof.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            authMissing:
              value:
                code: AUTH_CONTEXT_MISSING
                message: auth context missing
                data: null
    PermissionDenied:
      description: Operator has no permission for the task, registry or file.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            denied:
              value:
                code: PERMISSION_DENIED
                message: permission denied
                data: null
    SignatureRejected:
      description: Download is denied because permission or signed URL verification failed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            denied:
              value:
                code: PERMISSION_DENIED
                message: permission denied
                data: null
            invalidSignature:
              value:
                code: SIGNATURE_INVALID
                message: download signature is invalid
                data: null
            expiredSignature:
              value:
                code: SIGNATURE_EXPIRED
                message: download signature expired
                data: null
    TaskNotFound:
      description: Task not found or invisible to current operator.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notFound:
              value:
                code: TASK_NOT_FOUND
                message: task not found
                data: null
    TaskNotRegistered:
      description: taskCode is not registered.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notRegistered:
              value:
                code: TASK_NOT_REGISTERED
                message: task code not registered
                data: null
    CreateTaskBadRequest:
      description: Create task request is invalid, disabled or exceeds configured limits.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            validation:
              value:
                code: VALIDATION_ERROR
                message: validation failed
                data: null
                errors:
                  - field: taskCode
                    reason: required
            taskDisabled:
              value:
                code: TASK_DISABLED
                message: task code is disabled
                data:
                  taskCode: purchase-order-export
            queryParamsTooLarge:
              value:
                code: QUERY_PARAMS_TOO_LARGE
                message: queryParams exceeds 32768 bytes
                data: null
            exportLimitExceeded:
              value:
                code: EXPORT_LIMIT_EXCEEDED
                message: export limit exceeded
                data:
                  exportMaxRows: 100000
    IdempotencyConflict:
      description: Same idempotency scope with different request digest.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            conflict:
              value:
                code: IDEMPOTENCY_CONFLICT
                message: clientRequestId conflicts with a different request digest
                data:
                  idempotencyScope: tenant-001:u001:purchase-order-export:req-20260513-0001
    InvalidTaskState:
      description: Operation is not allowed for current official task status.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            invalidRetry:
              value:
                code: INVALID_TASK_STATE
                message: current task status does not allow this operation
                data:
                  status: EXECUTING
    ActiveAttemptConflict:
      description: Another active execution attempt already exists.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            activeAttempt:
              value:
                code: ACTIVE_ATTEMPT_CONFLICT
                message: active execution attempt already exists
                data:
                  taskId: exp_20260513_000001
                  attemptNo: 1
    FileExpired:
      description: File is expired or marked as not downloadable.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            expired:
              value:
                code: FILE_EXPIRED
                message: file expired
                data: null
    FileNotReady:
      description: File is not published or the task is not completed yet.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            notReady:
              value:
                code: FILE_NOT_READY
                message: file is not ready for download
                data:
                  status: EXECUTING
    FileVerifyError:
      description: File upload, metadata or checksum verification failed before publish.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            verifyFailed:
              value:
                code: FILE_VERIFY_ERROR
                message: file verification failed
                data:
                  checksumAlgorithm: SHA-256
    DatasourceUnavailable:
      description: Datasource or datasource credential is unavailable.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            datasourceUnavailable:
              value:
                code: DATASOURCE_UNAVAILABLE
                message: datasource unavailable
                data:
                  datasourceCode: purchase_ro
    QueryExecutionError:
      description: Query execution failed, batch retries exhausted or cursor contract violated.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            queryFailed:
              value:
                code: QUERY_EXECUTION_ERROR
                message: query execution failed
                data:
                  cursorField: orderId
    RegistryBadRequest:
      description: Registry request is invalid, exceeds limits, or contains invalid field/masking configuration.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            validation:
              value:
                code: VALIDATION_ERROR
                message: validation failed
                data: null
            exportLimitExceeded:
              value:
                code: EXPORT_LIMIT_EXCEEDED
                message: export limit exceeded
                data:
                  exportMaxRows: 100000
            fieldMappingInvalid:
              value:
                code: FIELD_MAPPING_INVALID
                message: field mapping invalid
                data:
                  fieldCode: contactPhone
            maskingRuleError:
              value:
                code: MASKING_RULE_ERROR
                message: masking rule error
                data:
                  maskingRuleCode: phone_mask
    RegistryServerError:
      description: Registry contract references an invalid query template, datasource, field mapping or masking backend.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            queryTemplateInvalid:
              value:
                code: QUERY_TEMPLATE_INVALID
                message: query template invalid
                data:
                  taskCode: purchase-order-export
            datasourceUnavailable:
              value:
                code: DATASOURCE_UNAVAILABLE
                message: datasource unavailable
                data:
                  datasourceCode: purchase_ro
            fieldMappingInvalid:
              value:
                code: FIELD_MAPPING_INVALID
                message: field mapping invalid
                data:
                  fieldCode: contactPhone
            maskingRuleError:
              value:
                code: MASKING_RULE_ERROR
                message: masking rule error
                data:
                  maskingRuleCode: phone_mask
    ExportRenderError:
      description: XLSX or ZIP render failed.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            renderFailed:
              value:
                code: EXPORT_RENDER_ERROR
                message: export render error
                data:
                  fileFormat: ZIP
    RegistryConflict:
      description: Registry taskCode already exists or conflicts with immutable fields.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            duplicate:
              value:
                code: REGISTRY_CONFLICT
                message: taskCode already exists
                data: null
    InternalError:
      description: Unclassified server-side error. Specific platform errors should use a more precise response when known.
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/ErrorEnvelope"
          examples:
            internalError:
              value:
                code: INTERNAL_ERROR
                message: internal error
                data: null
  schemas:
    ResponseCode:
      type: string
      enum:
        - SUCCESS
        - VALIDATION_ERROR
        - AUTH_CONTEXT_MISSING
        - PERMISSION_DENIED
        - TASK_NOT_FOUND
        - TASK_NOT_REGISTERED
        - TASK_DISABLED
        - QUERY_PARAMS_TOO_LARGE
        - IDEMPOTENCY_CONFLICT
        - INVALID_TASK_STATE
        - FILE_EXPIRED
        - SIGNATURE_INVALID
        - SIGNATURE_EXPIRED
        - FILE_NOT_READY
        - FILE_VERIFY_ERROR
        - FILE_CLEANUP_DELETE_ERROR
        - QUERY_TEMPLATE_INVALID
        - DATASOURCE_UNAVAILABLE
        - QUERY_EXECUTION_ERROR
        - FIELD_MAPPING_INVALID
        - MASKING_RULE_ERROR
        - EXPORT_RENDER_ERROR
        - EXPORT_LIMIT_EXCEEDED
        - REGISTRY_CONFLICT
        - ACTIVE_ATTEMPT_CONFLICT
        - INTERNAL_ERROR
    NullableResponseCode:
      type: string
      nullable: true
      enum:
        - SUCCESS
        - VALIDATION_ERROR
        - AUTH_CONTEXT_MISSING
        - PERMISSION_DENIED
        - TASK_NOT_FOUND
        - TASK_NOT_REGISTERED
        - TASK_DISABLED
        - QUERY_PARAMS_TOO_LARGE
        - IDEMPOTENCY_CONFLICT
        - INVALID_TASK_STATE
        - FILE_EXPIRED
        - SIGNATURE_INVALID
        - SIGNATURE_EXPIRED
        - FILE_NOT_READY
        - FILE_VERIFY_ERROR
        - FILE_CLEANUP_DELETE_ERROR
        - QUERY_TEMPLATE_INVALID
        - DATASOURCE_UNAVAILABLE
        - QUERY_EXECUTION_ERROR
        - FIELD_MAPPING_INVALID
        - MASKING_RULE_ERROR
        - EXPORT_RENDER_ERROR
        - EXPORT_LIMIT_EXCEEDED
        - REGISTRY_CONFLICT
        - ACTIVE_ATTEMPT_CONFLICT
        - INTERNAL_ERROR
        - null
    TaskStatus:
      type: string
      description: Official public task status. Internal cancel flags are not valid values.
      enum: [PENDING, EXECUTING, COMPLETED, FAILED, CANCELED, EXPIRED]
    FileFormat:
      type: string
      enum: [XLSX, ZIP]
    DeliveryMode:
      type: string
      enum: [SIGNED_URL, STREAM]
    Envelope:
      type: object
      required: [code, message]
      properties:
        code:
          $ref: "#/components/schemas/ResponseCode"
        message:
          type: string
    ErrorEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          properties:
            data:
              type: object
              nullable: true
              additionalProperties: true
            errors:
              type: array
              items:
                $ref: "#/components/schemas/FieldError"
    FieldError:
      type: object
      required: [field, reason]
      properties:
        field:
          type: string
        reason:
          type: string
    CreateExportTaskRequest:
      type: object
      required: [taskCode, subsystemCode, fileFormat, queryParams]
      properties:
        taskCode:
          type: string
        subsystemCode:
          type: string
        fileFormat:
          $ref: "#/components/schemas/FileFormat"
        clientRequestId:
          type: string
          maxLength: 128
          description: Optional idempotency key scoped by tenantId/operatorId/taskCode.
        queryParams:
          type: object
          additionalProperties: true
          description: Must match registry parameter schema and must not exceed 32768 bytes after canonical JSON serialization.
        deliveryPreference:
          $ref: "#/components/schemas/DeliveryMode"
    CreateExportTaskResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/CreateExportTaskResponse"
    CreateExportTaskResponse:
      type: object
      required:
        - taskId
        - taskCode
        - subsystemCode
        - status
        - idempotencyScope
        - requestDigest
        - configSnapshotDigest
        - attemptNo
        - createdAt
      properties:
        taskId:
          type: string
        taskCode:
          type: string
        subsystemCode:
          type: string
        status:
          type: string
          enum: [PENDING]
        clientRequestId:
          type: string
        idempotencyHit:
          type: boolean
        idempotencyScope:
          type: string
          description: Stable success-response evidence for the tenantId + operatorId + taskCode + clientRequestId idempotency scope.
        requestDigest:
          type: string
        configSnapshotDigest:
          type: string
        attemptNo:
          type: integer
          minimum: 0
        createdAt:
          type: string
          format: date-time
    ExportTaskDetailEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportTaskDetail"
    ExportTaskDetail:
      type: object
      required:
        - taskId
        - taskCode
        - subsystemCode
        - status
        - totalCount
        - processedCount
        - progressPercent
        - errorCode
        - errorMessage
        - recentEvents
        - attemptNo
        - requestId
        - requestDigest
        - configSnapshotDigest
        - createdBy
        - createdAt
        - updatedAt
      properties:
        taskId:
          type: string
        taskCode:
          type: string
        subsystemCode:
          type: string
        status:
          $ref: "#/components/schemas/TaskStatus"
        totalCount:
          type: integer
          format: int64
          minimum: 0
        processedCount:
          type: integer
          format: int64
          minimum: 0
        progressPercent:
          type: number
          minimum: 0
          maximum: 100
        fileFormat:
          $ref: "#/components/schemas/FileFormat"
        attemptNo:
          type: integer
          minimum: 0
        errorCode:
          $ref: "#/components/schemas/NullableResponseCode"
        errorMessage:
          type: string
          nullable: true
        failureStage:
          type: string
        lastSuccessStage:
          type: string
        requestId:
          type: string
        requestDigest:
          type: string
        configSnapshotDigest:
          type: string
        createdBy:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        file:
          $ref: "#/components/schemas/FileMetadata"
        batchCheckpoint:
          $ref: "#/components/schemas/BatchCheckpoint"
        recentEvents:
          type: array
          items:
            $ref: "#/components/schemas/TaskEvent"
        auditEvents:
          type: array
          items:
            $ref: "#/components/schemas/AuditEvent"
    ExportTaskPageEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportTaskPage"
    ExportTaskPage:
      type: object
      required: [items, page, pageSize, total]
      properties:
        items:
          type: array
          items:
            $ref: "#/components/schemas/ExportTaskDetail"
        page:
          type: integer
        pageSize:
          type: integer
        total:
          type: integer
          format: int64
    DownloadResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/DownloadResponse"
    DownloadResponse:
      allOf:
        - $ref: "#/components/schemas/FileMetadata"
        - type: object
          required: [deliveryMode, expiresAt]
          properties:
            deliveryMode:
              $ref: "#/components/schemas/DeliveryMode"
            downloadUrl:
              type: string
              format: uri
            expiresAt:
              type: string
              format: date-time
    FileMetadata:
      type: object
      required:
        - fileName
        - fileSize
        - contentType
        - checksum
        - checksumAlgorithm
        - storageKey
        - expiresAt
        - attemptNo
      properties:
        fileName:
          type: string
        fileSize:
          type: integer
          format: int64
        contentType:
          type: string
        tempStorageKey:
          type: string
        publishedStorageKey:
          type: string
        storageKey:
          type: string
        expiresAt:
          type: string
          format: date-time
          description: Published file retention expiry time. Signed URL responses also use expiresAt for URL expiry.
        checksum:
          type: string
        checksumAlgorithm:
          type: string
          enum: [SHA-256]
        checksumVerifiedAt:
          type: string
          format: date-time
        publishedAt:
          type: string
          format: date-time
        deliveryReadyAt:
          type: string
          format: date-time
        attemptNo:
          type: integer
          minimum: 1
    TaskActionRequest:
      type: object
      properties:
        reason:
          type: string
          maxLength: 500
    TaskActionResponseEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/TaskActionResponse"
    TaskActionResponse:
      type: object
      required: [taskId, status, attemptNo, acceptedAt]
      properties:
        taskId:
          type: string
        status:
          $ref: "#/components/schemas/TaskStatus"
        attemptNo:
          type: integer
        cancelAccepted:
          type: boolean
          description: True means an EXECUTING task will stop at a batch boundary; this is not a task status.
        retryAccepted:
          type: boolean
        configSnapshotDigest:
          type: string
        acceptedAt:
          type: string
          format: date-time
    ExportRegistryUpsertRequest:
      type: object
      required:
        - taskCode
        - subsystemCode
        - displayName
        - enabled
        - concurrencyLimit
        - fileRetentionDays
        - taskHistoryRetentionDays
        - singleFileMaxRows
        - exportMaxRows
        - supportedFormats
        - datasourceCode
        - parameterSchema
        - queryTemplate
        - fieldMappings
        - maskingPolicy
        - dataScopeTemplate
        - cursorField
        - orderBy
        - batchSize
      properties:
        taskCode:
          type: string
        subsystemCode:
          type: string
        displayName:
          type: string
        enabled:
          type: boolean
        concurrencyLimit:
          type: integer
          minimum: 1
        fileRetentionDays:
          type: integer
          minimum: 1
          default: 15
        taskHistoryRetentionDays:
          type: integer
          minimum: 1
          default: 30
        singleFileMaxRows:
          type: integer
          minimum: 1
          default: 20000
        exportMaxRows:
          type: integer
          minimum: 1
          default: 100000
        supportedFormats:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FileFormat"
        datasourceCode:
          type: string
          description: Must reference a registered read-only datasource or data platform dataset.
        parameterSchema:
          type: object
          additionalProperties: true
        queryTemplate:
          $ref: "#/components/schemas/QueryTemplateContract"
        fieldMappings:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/FieldMapping"
        maskingPolicy:
          type: object
          additionalProperties: true
          description: Required masking policy. Any fieldMappings item with sensitive=true must reference a maskingRuleCode covered by this policy.
        dataScopeTemplate:
          type: string
          description: Data scope expression using tenantId, operatorId, roleCodes and orgScope.
        cursorField:
          type: string
        orderBy:
          type: array
          minItems: 1
          items:
            $ref: "#/components/schemas/OrderBy"
        batchSize:
          type: integer
          minimum: 1
    ExportRegistryEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              $ref: "#/components/schemas/ExportRegistry"
    ExportRegistryPageEnvelope:
      allOf:
        - $ref: "#/components/schemas/Envelope"
        - type: object
          required: [data]
          properties:
            data:
              type: object
              required: [items, page, pageSize, total]
              properties:
                items:
                  type: array
                  items:
                    $ref: "#/components/schemas/ExportRegistry"
                page:
                  type: integer
                pageSize:
                  type: integer
                total:
                  type: integer
                  format: int64
    ExportRegistry:
      allOf:
        - $ref: "#/components/schemas/ExportRegistryUpsertRequest"
        - type: object
          required:
            - configSnapshotDigest
            - parameterSchemaDigest
            - fieldMappingDigest
            - maskingPolicyDigest
            - updatedAt
            - updatedBy
          properties:
            configSnapshotDigest:
              type: string
            parameterSchemaDigest:
              type: string
              description: Digest of the effective parameter schema used by future config snapshots.
            fieldMappingDigest:
              type: string
              description: Digest of ordered field mappings and exportable whitelist.
            maskingPolicyDigest:
              type: string
              description: Digest of masking policy and sensitive field rules.
            updatedAt:
              type: string
              format: date-time
            updatedBy:
              type: string
    QueryTemplateContract:
      type: object
      required: [queryTemplateVersion, templateText, allowedParameters]
      properties:
        queryTemplateVersion:
          type: string
        templateText:
          type: string
          description: Parameterized query template. Raw SQL from callers is forbidden.
        allowedParameters:
          type: array
          items:
            type: string
    FieldMapping:
      type: object
      required: [fieldCode, headerName, fieldType, orderNo, sensitive, exportable]
      properties:
        fieldCode:
          type: string
        headerName:
          type: string
        fieldType:
          type: string
          enum: [STRING, NUMBER, DECIMAL, DATETIME, DATE, BOOLEAN]
        orderNo:
          type: integer
          minimum: 1
        sensitive:
          type: boolean
        exportable:
          type: boolean
        maskingRuleCode:
          type: string
    OrderBy:
      type: object
      required: [field, direction]
      properties:
        field:
          type: string
        direction:
          type: string
          enum: [ASC, DESC]
    BatchCheckpoint:
      type: object
      properties:
        lastCursor:
          type: string
        processedCount:
          type: integer
          format: int64
        totalCount:
          type: integer
          format: int64
          minimum: 0
        filePartNo:
          type: integer
        attemptNo:
          type: integer
        batchSize:
          type: integer
        batchRowCount:
          type: integer
        retryCount:
          type: integer
        backoffMs:
          type: integer
        failureReason:
          type: string
          description: Sanitized failure reason for failed file rendering or package generation.
        renderInputSummary:
          type: object
          description: Render input summary captured when XLSX/ZIP rendering fails.
          properties:
            taskId:
              type: string
            taskCode:
              type: string
            attemptNo:
              type: integer
            fileName:
              type: string
            format:
              type: string
            totalRowCount:
              type: integer
              format: int64
            partCount:
              type: integer
            singleFileMaxRows:
              type: integer
        lockOwner:
          type: string
          description: Worker identity that owns the database lease for the current attempt.
        lockExpireAt:
          type: string
          format: date-time
          description: Lease expiry based on database time; default lease is five minutes unless registry config overrides it.
        leaseRenewedAt:
          type: string
          format: date-time
          description: Last successful lease renewal time based on database time.
        databaseTime:
          type: string
          format: date-time
          description: Database clock snapshot used for lock acquisition, renewal and takeover decisions.
        takeoverRule:
          type: string
          description: Workers may take over only after database time is later than lockExpireAt; takeover keeps the same attemptNo.
    AuditEvent:
      type: object
      required:
        - taskId
        - taskCode
        - subsystemCode
        - operatorId
        - action
        - result
        - errorCode
        - requestId
        - occurredAt
      properties:
        taskId:
          type: string
        taskCode:
          type: string
        subsystemCode:
          type: string
        operatorId:
          type: string
        action:
          type: string
          enum:
            - CREATE
            - QUERY_HISTORY
            - DETAIL_VIEW
            - DISPATCH
            - EXECUTE_START
            - EXECUTE_SUCCESS
            - EXECUTE_FAILED
            - CANCEL_REQUEST
            - CANCEL_DONE
            - RETRY_REQUEST
            - DOWNLOAD
            - EXPIRE_MARK
            - CLEANUP_FAILED
            - REGISTRY_CREATE
            - REGISTRY_QUERY
            - REGISTRY_DETAIL
            - REGISTRY_UPDATE
            - REGISTRY_ENABLE
            - REGISTRY_DISABLE
        result:
          type: string
          enum: [SUCCESS, FAILED, ACCEPTED]
        errorCode:
          $ref: "#/components/schemas/ResponseCode"
        requestId:
          type: string
        occurredAt:
          type: string
          format: date-time
    TaskEvent:
      type: object
      required: [taskId, attemptNo, eventType, requestId, occurredAt]
      properties:
        taskId:
          type: string
        attemptNo:
          type: integer
        eventType:
          type: string
          enum:
            - QUERY_READY
            - QUERY_BATCH_DONE
            - FILE_PART_WRITTEN
            - PACKAGE_DONE
            - PACKAGE_FAILED
            - FILE_VERIFIED
            - DELIVERY_READY
