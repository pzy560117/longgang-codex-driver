          - "记录 attemptNo、lockOwner、lockExpireAt、leaseRenewedAt"
          - "按数据库时间判断锁租约"
          - "按批次边界续租"
          - "锁接管延续当前 attemptNo，并从 lastCursor、processedCount、filePartNo 检查点继续"
          - "更新 processedCount"
        acceptance_refs: ["AC-005", "AC-006", "AC-015", "AC-E004", "AC-E008", "AC-E019"]
      error:
        required: true
        description: "执行失败"
        expected_system_behavior:
