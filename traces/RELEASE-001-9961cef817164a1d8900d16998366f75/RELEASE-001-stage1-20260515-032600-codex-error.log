 190:         requestId,
 191:         leaseDurationSeconds,
 192:         batchProcessor,
 193:         fileService: options.fileService
 194:       });
 195: 
 196:       result.renewed += processed.renewed;
 197:       result.canceled += processed.canceled;
 198:       result.completed += processed.completed;
 199:       result.failed += processed.failed;
 200:     }
 201: 
 202:     return result;
 203:   }
