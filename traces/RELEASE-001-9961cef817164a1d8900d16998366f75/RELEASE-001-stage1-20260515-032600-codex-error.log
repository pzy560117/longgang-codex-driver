 370: async function processAcquiredLease(input: {
 371:   db: Kysely<ExportPlatformDatabase>;
 372:   task: ExportTaskRecord;
 373:   lease: ExportTaskLeaseRecord;
 374:   requestId: string;
 375:   leaseDurationSeconds: number;
 376:   batchProcessor: SchedulerBatchProcessor;
 377:   fileService?: SchedulerWorkerOptions["fileService"];
 378: }): Promise<Omit<SchedulerPollResult, "dispatched">> {
 379:   const result = {
 380:     renewed: 0,
 381:     canceled: 0,
 382:     completed: 0,
 383:     failed: 0
 384:   };
 385: 
 386:   try {
 387:     const checkpoint = await createCheckpointRepository(input.db).findLatestCheckpoint(
 388:       input.task.taskId,
 389:       input.lease.attemptNo
 390:     );
 391:     const batch = await input.batchProcessor({
 392:       db: input.db,
 393:       task: input.task,
 394:       lease: input.lease,
 395:       checkpoint,
 396:       requestId: input.requestId
 397:     });
 398:     const now = await getDatabaseTime(input.db);
 399: 
 400:     if (batch.checkpoint) {
 401:       await createCheckpointRepository(input.db).saveCheckpoint({
 402:         taskId: input.task.taskId,
 403:         attemptNo: input.lease.attemptNo,
 404:         ...batch.checkpoint,
 405:         now
 406:       });
 407:     }
 408: 
 409:     if (await hasAcceptedCancelRequest(input.db, input.task.taskId, input.lease.attemptNo)) {
 410:       const canceledAt = await markTaskTerminal({
 411:         db: input.db,
 412:         task: input.task,
 413:         attemptNo: input.lease.attemptNo,
 414:         lockOwner: input.lease.lockOwner,
 415:         status: "CANCELED"
 416:       });
 417:       await appendWorkerAudit({
 418:         db: input.db,
 419:         task: input.task,
 420:         attemptNo: input.lease.attemptNo,
 421:         action: "CANCEL_DONE",
 422:         result: "SUCCESS",
 423:         requestId: input.requestId,
 424:         now: canceledAt
 425:       });
 426:       result.canceled = 1;
 427:       return result;
 428:     }
 429: 
 430:     if (batch.outcome === "completed") {
 431:       if (Array.isArray(batch.rows)) {
 432:         const registry = await createExportRegistryRepository(input.db).findRegistryByTaskCode(
 433:           input.task.taskCode
 434:         );
 435:         if (!registry) {
 436:           throw new Error("TASK_NOT_REGISTERED: registry snapshot is not available for file publish");
 437:         }
 438:         const fileService = input.fileService ?? createExportFileService({ db: input.db });
 439:         await ensureLeaseAtBatchBoundary({
 440:           db: input.db,
 441:           taskId: input.task.taskId,
 442:           attemptNo: input.lease.attemptNo,
 443:           lockOwner: input.lease.lockOwner,
 444:           leaseDurationSeconds: input.leaseDurationSeconds
 445:         });
 446:         await fileService.publishRows({
 447:           task: input.task,
 448:           registry,
 449:           attemptNo: input.lease.attemptNo,
 450:           requestId: input.requestId,
 451:           rows: batch.rows
 452:         });
 453:       }
 454:       const completedAt = await markTaskTerminal({
 455:         db: input.db,
 456:         task: input.task,
 457:         attemptNo: input.lease.attemptNo,
 458:         lockOwner: input.lease.lockOwner,
 459:         status: "COMPLETED"
 460:       });
 461:       await appendWorkerAudit({
 462:         db: input.db,
 463:         task: input.task,
 464:         attemptNo: input.lease.attemptNo,
 465:         action: "EXECUTE_SUCCESS",
 466:         result: "SUCCESS",
 467:         requestId: input.requestId,
 468:         now: completedAt
 469:       });
 470:       result.completed = 1;
 471:       return result;
 472:     }
 473: 
 474:     const renewed = await renewLeaseAtBatchBoundary({
 475:       db: input.db,
 476:       taskId: input.task.taskId,
 477:       attemptNo: input.lease.attemptNo,
 478:       lockOwner: input.lease.lockOwner,
 479:       leaseDurationSeconds: input.leaseDurationSeconds
 480:     });
 481: 
 482:     result.renewed = renewed ? 1 : 0;
 483:     return result;
 484:   } catch (error) {
 485:     if (isLeaseLostError(error)) {
 486:       return result;
 487:     }
 488: 
 489:     let failedAt: Date;
 490:     try {
 491:       failedAt = await markTaskTerminal({
 492:         db: input.db,
 493:         task: input.task,
 494:         attemptNo: input.lease.attemptNo,
 495:         lockOwner: input.lease.lockOwner,
 496:         status: "FAILED"
 497:       });
 498:     } catch (terminalError) {
 499:       if (isLeaseLostError(terminalError)) {
 500:         return result;
 501:       }
 502:       throw terminalError;
 503:     }
 504: 
 505:     await appendWorkerAudit({
 506:       db: input.db,
 507:       task: input.task,
 508:       attemptNo: input.lease.attemptNo,
 509:       action: "EXECUTE_FAILED",
 510:       result: "FAILED",
 511:       errorCode: error instanceof Error && error.name !== "Error" ? error.name : "QUERY_EXECUTION_ERROR",
 512:       requestId: input.requestId,
 513:       now: failedAt
 514:     });
 515:     result.failed = 1;
 516:     return result;
 517:   }
 518: }
 519: 
 520: async function ensureLeaseAtBatchBoundary(input: {
 521:   db: Kysely<ExportPlatformDatabase>;
 522:   taskId: string;
 523:   attemptNo: number;
 524:   lockOwner: string;
 525:   leaseDurationSeconds: number;
 526: }): Promise<void> {
 527:   const renewed = await renewLeaseAtBatchBoundary(input);
 528:   if (!renewed) {
 529:     throw leaseLostError(
 530:       `worker ${input.lockOwner} no longer owns an active lease for task ${input.taskId}`
 531:     );
 532:   }
 533: }
 534: 
 535: async function renewLeaseAtBatchBoundary(input: {
 536:   db: Kysely<ExportPlatformDatabase>;
 537:   taskId: string;
 538:   attemptNo: number;
 539:   lockOwner: string;
 540:   leaseDurationSeconds: number;
 541: }): Promise<boolean> {
 542:   return input.db.transaction().execute(async (trx) => {
 543:     const databaseTime = await queryDatabaseTime(trx);
 544:     const lockExpireAt = new Date(
 545:       databaseTime.getTime() + input.leaseDurationSeconds * 1000
 546:     );
 547:     const task = await trx
 548:       .selectFrom("export_tasks")
 549:       .select(["task_id"])
 550:       .where("task_id", "=", input.taskId)
 551:       .where("attempt_no", "=", input.attemptNo)
 552:       .where("lock_owner", "=", input.lockOwner)
 553:       .where("status", "=", "EXECUTING")
 554:       .where("lock_expire_at", ">", databaseTime)
 555:       .forUpdate()
 556:       .executeTakeFirst();
 557: 
 558:     if (!task) {
 559:       return false;
 560:     }
 561: 
 562:     await trx
 563:       .updateTable("export_tasks")
 564:       .set({
 565:         lock_expire_at: lockExpireAt,
 566:         lease_renewed_at: databaseTime,
 567:         updated_at: databaseTime
 568:       })
 569:       .where("task_id", "=", input.taskId)
 570:       .execute();
 571: 
 572:     await trx
 573:       .updateTable("export_task_leases")
 574:       .set({
 575:         lock_expire_at: lockExpireAt,
 576:         lease_renewed_at: databaseTime,
 577:         database_time: databaseTime,
 578:         updated_at: databaseTime
 579:       })
 580:       .where("task_id", "=", input.taskId)
 581:       .where("attempt_no", "=", input.attemptNo)
 582:       .where("lock_owner", "=", input.lockOwner)
 583:       .execute();
 584: 
 585:     return true;
 586:   });
 587: }
 588: 
 589: async function markTaskTerminal(input: {
 590:   db: Kysely<ExportPlatformDatabase>;
 591:   task: ExportTaskRecord;
 592:   attemptNo: number;
 593:   lockOwner: string;
 594:   status: TerminalTaskStatus;
 595: }): Promise<Date> {
 596:   return input.db.transaction().execute(async (trx) => {
 597:     const databaseTime = await queryDatabaseTime(trx);
 598:     const activeLease = await trx
 599:       .selectFrom("export_tasks")
 600:       .select("task_id")
 601:       .where("task_id", "=", input.task.taskId)
 602:       .where("attempt_no", "=", input.attemptNo)
 603:       .where("lock_owner", "=", input.lockOwner)
 604:       .where("status", "=", "EXECUTING")
 605:       .where("lock_expire_at", ">", databaseTime)
 606:       .forUpdate()
 607:       .executeTakeFirst();
 608: 
 609:     if (!activeLease) {
 610:       throw leaseLostError(
 611:         `worker ${input.lockOwner} cannot mark task ${input.task.taskId} as ${input.status}`
 612:       );
 613:     }
 614: 
 615:     const updateResult = await trx
 616:       .updateTable("export_tasks")
 617:       .set({
 618:         status: input.status,
 619:         lock_owner: null,
 620:         lock_expire_at: null,
 621:         lease_renewed_at: null,
 622:         updated_at: databaseTime
 623:       })
 624:       .where("task_id", "=", input.task.taskId)
 625:       .where("attempt_no", "=", input.attemptNo)
 626:       .where("lock_owner", "=", input.lockOwner)
 627:       .where("status", "=", "EXECUTING")
 628:       .where("lock_expire_at", ">", databaseTime)
 629:       .executeTakeFirst();
 630: 
 631:     if (toUpdatedRowCount(updateResult.numUpdatedRows) !== 1) {
 632:       throw leaseLostError(
 633:         `worker ${input.lockOwner} lost the lease before marking task ${input.task.taskId} terminal`
 634:       );
 635:     }
 636: 
 637:     return databaseTime;
 638:   });
 639: }
