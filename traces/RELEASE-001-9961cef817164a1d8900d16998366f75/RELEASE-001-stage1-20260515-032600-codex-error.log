 567: function decodeCursorToken(
 568:   lastCursor: string | null,
 569:   orderBy: OrderByDefinition[]
 570: ): CursorToken | null {
 571:   if (!lastCursor) {
 572:     return null;
 573:   }
 574:   try {
 575:     const parsed = JSON.parse(lastCursor) as CursorToken;
 576:     if (parsed?.version === 1 && parsed.values && typeof parsed.values === "object") {
 577:       return parsed;
 578:     }
 579:   } catch {
 580:     // Older checkpoints only persist the terminal cursor field value.
 581:   }
 582:   return {
 583:     version: 1,
 584:     values: {
 585:       [orderBy[orderBy.length - 1].field]: lastCursor
 586:     }
 587:   };
 588: }
 589: 
 590: function encodeCursorToken(token: CursorToken): string {
 591:   return JSON.stringify(token);
 592: }
 593: 
 594: function createCursorToken(row: Record<string, unknown>, orderBy: OrderByDefinition[]): CursorToken {
 595:   const values: CursorToken["values"] = {};
 596:   for (const item of orderBy) {
 597:     values[item.field] = normalizeCursorValue(row[item.field], item.field);
 598:   }
 599:   return { version: 1, values };
 600: }
 601: 
 602: function buildCursorPredicate(
 603:   orderBy: OrderByDefinition[],
 604:   lastCursor: CursorToken | null
 605: ): { sql: string; values: Array<string | number | boolean | null> } {
 606:   if (!lastCursor) {
 607:     return { sql: "", values: [] };
 608:   }
 609: 
 610:   const clauses: string[] = [];
 611:   const values: Array<string | number | boolean | null> = [];
 612:   for (let index = 0; index < orderBy.length; index += 1) {
 613:     const andParts: string[] = [];
 614:     for (let prefixIndex = 0; prefixIndex < index; prefixIndex += 1) {
 615:       const prefixField = orderBy[prefixIndex].field;
 616:       andParts.push(`${quoteIdentifier(prefixField)} = ?`);
 617:       values.push(readCursorField(lastCursor, prefixField));
 618:     }
 619:     const field = orderBy[index].field;
 620:     andParts.push(
 621:       `${quoteIdentifier(field)} ${orderBy[index].direction === "DESC" ? "<" : ">"} ?`
 622:     );
 623:     values.push(readCursorField(lastCursor, field));
 624:     clauses.push(`(${andParts.join(" AND ")})`);
 625:   }
 626: 
 627:   return {
 628:     sql: ` AND (${clauses.join(" OR ")})`,
 629:     values
 630:   };
 631: }
 632: 
 633: function readCursorField(
 634:   token: CursorToken,
 635:   field: string
 636: ): string | number | boolean | null {
 637:   if (!(field in token.values)) {
 638:     throw queryExecutionError(`cursor field ${field} is missing from checkpoint`);
 639:   }
 640:   return token.values[field] ?? null;
 641: }
 642: 
 643: function validateCursorRows(
 644:   rows: Record<string, unknown>[],
 645:   orderBy: OrderByDefinition[],
 646:   lastCursor: CursorToken | null
 647: ): void {
 648:   let previous = lastCursor;
 649:   for (const row of rows) {
 650:     const current = createCursorToken(row, orderBy);
 651:     if (previous && compareCursorTokens(previous, current, orderBy) >= 0) {
 652:       throw queryExecutionError("cursor values are duplicate or non-increasing");
 653:     }
 654:     previous = current;
 655:   }
 656: }
 657: 
 658: function compareCursorTokens(
 659:   left: CursorToken,
 660:   right: CursorToken,
 661:   orderBy: OrderByDefinition[]
 662: ): number {
 663:   for (const item of orderBy) {
 664:     const leftValue = readCursorField(left, item.field);
 665:     const rightValue = readCursorField(right, item.field);
 666:     const comparison = compareCursorValues(leftValue, rightValue);
 667:     if (comparison === 0) {
 668:       continue;
 669:     }
 670:     return item.direction === "DESC" ? comparison * -1 : comparison;
 671:   }
 672:   return 0;
 673: }
 674: 
 675: function compareCursorValues(
 676:   left: string | number | boolean | null,
 677:   right: string | number | boolean | null
 678: ): number {
 679:   if (left === right) {
 680:     return 0;
 681:   }
 682:   if (left === null || right === null) {
 683:     throw queryExecutionError("cursor field is missing or null");
 684:   }
 685:   if (typeof left === "number" && typeof right === "number") {
 686:     return left < right ? -1 : 1;
 687:   }
 688:   const leftText = String(left);
 689:   const rightText = String(right);
 690:   return leftText.localeCompare(rightText);
 691: }
 692: 
 693: function normalizeCursorValue(
 694:   value: unknown,
 695:   field: string
 696: ): string | number | boolean | null {
 697:   if (value === null || value === undefined) {
 698:     throw queryExecutionError(`cursor field ${field} is missing`);
 699:   }
 700:   if (value instanceof Date) {
 701:     return toDatabaseDateTimeLiteral(value);
 702:   }
 703:   if (
 704:     typeof value === "string" ||
 705:     typeof value === "number" ||
 706:     typeof value === "boolean"
 707:   ) {
 708:     return value;
 709:   }
 710:   return JSON.stringify(value);
 711: }
 712: 
 713: function toDatabaseDateTimeLiteral(value: Date): string {
 714:   const year = value.getFullYear();
 715:   const month = String(value.getMonth() + 1).padStart(2, "0");
 716:   const day = String(value.getDate()).padStart(2, "0");
 717:   const hours = String(value.getHours()).padStart(2, "0");
 718:   const minutes = String(value.getMinutes()).padStart(2, "0");
 719:   const seconds = String(value.getSeconds()).padStart(2, "0");
 720:   const milliseconds = String(value.getMilliseconds()).padStart(3, "0");
 721:   return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}.${milliseconds}`;
 722: }
 723: 
 724: function positiveInteger(value: number | null | undefined, fallback: number): number {
 725:   return Number.isInteger(value) && Number(value) > 0 ? Number(value) : fallback;
 726: }
 727: 
 728: function requireText(value: unknown, code: string): string {
 729:   if (typeof value !== "string" || value.length === 0) {
 730:     throw queryError(code, "required text value is missing");
 731:   }
 732:   return value;
 733: }
 734: 
 735: function quoteIdentifier(identifier: string): string {
 736:   if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {
 737:     throw queryError("QUERY_TEMPLATE_INVALID", `unsafe identifier ${identifier}`);
 738:   }
 739:   return `\`${identifier}\``;
 740: }
 741: 
 742: function parameterList(count: number): string {
 743:   return Array.from({ length: count }, () => "?").join(", ");
 744: }
 745: 
 746: function queryError(code: string, message: string): Error {
 747:   const error = new Error(`${code}: ${message}`);
 748:   error.name = code;
 749:   return error;
 750: }
 751: 
 752: function queryExecutionError(message: string): Error {
 753:   return queryError("QUERY_EXECUTION_ERROR", message);
 754: }

