 349: function compileQuery(input: {
 350:   template: QueryTemplate;
 351:   queryParams: Record<string, unknown>;
 352:   authSnapshot: AuthSnapshot;
 353:   scope: { tenantId: string; orgScope: string[] };
 354:   lastCursor: CursorToken | null;
 355:   orderBy: OrderByDefinition[];
 356:   limit: number;
 357: }): { sqlText: string; values: unknown[] } {
 358:   const values: unknown[] = [];
 359:   const sqlText = input.template.templateText.replace(
 360:     placeholderPattern,
 361:     (_match, name: string) => {
 362:       if (name === "orgScope") {
 363:         values.push(...input.scope.orgScope);
 364:         return parameterList(input.scope.orgScope.length);
 365:       }
 366:       if (name === "tenantId") {
 367:         values.push(input.scope.tenantId);
 368:         return "?";
 369:       }
 370:       const value = input.queryParams[name] ?? null;
 371:       values.push(name === "keyword" && typeof value === "string" ? `%${value}%` : value);
 372:       return "?";
