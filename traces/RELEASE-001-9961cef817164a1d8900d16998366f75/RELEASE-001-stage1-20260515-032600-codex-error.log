 658: async function findRequestIdForTask(
 659:   db: Kysely<ExportPlatformDatabase>,
 660:   taskId: string,
 661:   workerId: string
 662: ): Promise<string> {
 663:   const row = await db
 664:     .selectFrom("export_audit_logs")
 665:     .select("request_id")
 666:     .where("task_id", "=", taskId)
 667:     .where("action", "in", ["CREATE", "RETRY_REQUEST", "CANCEL_REQUEST"])
 668:     .orderBy("occurred_at", "asc")
 669:     .executeTakeFirst();
 670: 
 671:   return row?.request_id ?? `scheduler:${workerId}`;
 672: }
