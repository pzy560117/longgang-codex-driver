trix.md\"\n      ],\n      \"execution\": {\n        \"mode\": \"single\"\n      },\n      \"steps\": [\n        \"实现 create/detail/list/download/cancel/retry/registry 相关 route/handler 与 service\",\n        \"把 handler 串联到 DB repository、认证上下文、幂等、配置快照和审计写入\",\n        \"补齐 OpenAPI operation 到 handler 的契约测试和 API 集成测试\"\n      ],\n      \"test_command\": \"powershell -NoProfile -ExecutionPolicy Bypass -File .\\\\verify.ps1 -Commands @(\u0027npm run arch:check\u0027,\u0027npm run test:contract\u0027,\u0027npm run test:api\u0027,\u0027git diff --check\u0027)\",\n      \"acceptance\": [\n        \"FR-001/002/004/007/009/010/012/013 有 HTTP 层证据\",\n        \"handler 与 OpenAPI operation 可追踪\",\n        \"API 验收不依赖内存 repository\"\n      ]\n    },\n    {\n      \"id\": \"SCHEDULER-WORKER-001\",\n      \"description\": \"实现 DB polling 调度 worker、抢锁、续租、接管和取消/重试边界\",\n      \"task_kind\": \"feature_impl\",\n      \"phase\": \"scheduler\",\n      \"gate_profile\": \"spec_required\",\n      \"required_truth_sources\": [\n        \"product\",\n        \"architecture\",\n        \"contract\",\n        \"testing\"\n      ],\n      \"priority\": 50,\n      \"dependencies\": [\n        \"TASK-API-HTTP-001\"\n      ],\n      \"passes\": false,\n      \"architecture_constraints\": [\n        \"调度方式为 MySQL 轮询 + DB 抢锁\",\n        \"锁时间以数据库时间为准\",\n        \"租约过期接管延续当前 attemptNo，FAILED 重试才递增 attemptNo\"\n      ],\n      \"forbidden_implementations\": [\n        \"禁止用内存锁替代 DB 租约\",\n        \"禁止只有 scheduler class 而没有 worker entry\",\n        \"禁止没有并发抢锁测试就声明调度完成\"\n      ],\n      \"context_files\": [\n        \"docs/architecture/constraints.md\",\n        \"docs/context/architecture-brief.md\",\n        \"contracts/openapi.yaml\",\n        \"docs/testing/verify-matrix.md\"\n      ],\n      \"owned_paths\": [\n        \"src/workers/\",\n        \"src/scheduler/\",\n        \"src/repositories/\",\n        \"tests/worker/\",\n        \"tests/db/\",\n        \"docs/testing/verify-matrix.md\"\n    