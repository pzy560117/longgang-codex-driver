 261: async function processTaskUntilTerminal(db, taskId, storage) {
 262:   const worker = createSchedulerWorker({
 263:     db,
 264:     workerId: "worker-sample",
 265:     leaseDurationSeconds: 300,
 266:     maxTasksPerPoll: 1,
 267:     fileService: createExportFileService({ db, storage })
 268:   });
 269:   const totals = {
 270:     polls: 0,
 271:     dispatched: 0,
 272:     renewed: 0,
 273:     canceled: 0,
 274:     completed: 0,
 275:     failed: 0
 276:   };
 277:   const startedAt = Date.now();
 278: 
 279:   for (let index = 0; index < 1000; index += 1) {
 280:     const pollResult = await worker.pollAndProcessOnce();
 281:     totals.polls += 1;
 282:     totals.dispatched += pollResult.dispatched;
 283:     totals.renewed += pollResult.renewed;
 284:     totals.canceled += pollResult.canceled;
 285:     totals.completed += pollResult.completed;
 286:     totals.failed += pollResult.failed;
 287: 
 288:     const task = await createExportTaskRepository(db).findTaskById(taskId);
 289:     if (task && ["COMPLETED", "FAILED", "CANCELED"].includes(task.status)) {
 290:       return {
 291:         task,
 292:         totals: {
 293:           ...totals,
 294:           durationMs: Date.now() - startedAt
 295:         }
 296:       };
 297:     }
 298: 
 299:     if (
 300:       pollResult.dispatched === 0 &&
 301:       pollResult.renewed === 0 &&
 302:       pollResult.canceled === 0 &&
 303:       pollResult.completed === 0 &&
 304:       pollResult.failed === 0
 305:     ) {
 306:       break;
 307:     }
 308:   }
 309: 
 310:   throw new Error(`worker did not reach a terminal state for task ${taskId}`);
 311: }
