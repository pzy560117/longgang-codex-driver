          - "游标缺失、重复或非递增时任务置为 FAILED"
          - "错误码收口为 MASKING_RULE_ERROR 或 QUERY_EXECUTION_ERROR"
          - "保留批次检查点和失败原因"
        acceptance_refs: ["AC-E022", "AC-E023"]

