version: "1.0"
feature_id: "FEAT-EXPORT-PLATFORM-001"
frontend_scope: "none"
required_backend_states:
  - default
  - empty
  - processing
  - error
  - permission_denied
  - disabled
  - expired
  - canceled
  - long_content
  - conflict
official_task_statuses:
  - PENDING
  - EXECUTING
  - COMPLETED
  - FAILED
  - CANCELED
  - EXPIRED
internal_controls:
  cancel_requested: "仅作为执行中取消的内部控制标记；API 不返回该状态，最终收口为 CANCELED 或 INVALID_TASK_STATE"
defaults:
  query_params_max_bytes: 32768
  single_file_max_rows: 20000
  default_export_max_rows: 100000
  lock_lease_minutes: 5
  query_timeout_seconds: 30
  query_batch_max_retries: 3
  supported_formats: ["XLSX", "ZIP"]
  signature_url_ttl_minutes: 10
  checksum_algorithm: "SHA-256"
  file_retention_days: 15
  task_history_retention_days: 30
execution_events:
  - QUERY_READY
  - QUERY_BATCH_DONE
  - FILE_PART_WRITTEN
  - PACKAGE_DONE
  - FILE_VERIFIED
  - DELIVERY_READY
idempotency:
  scope_fields: ["tenantId", "operatorId", "taskCode", "clientRequestId"]
  digest_fields: ["taskCode", "fileFormat", "queryParams"]
  conflict_error_code: "IDEMPOTENCY_CONFLICT"
capabilities:
  - capability_id: "api-001"
    title: "创建导出任务"
    route: "POST /api/export/tasks"
    related_requirements: ["FR-001", "FR-009", "FR-013"]
    states:
      default:
        required: true
        description: "认证和注册校验通过，创建成功"
        expected_system_behavior:
          - "写入 export_task"
          - "status=PENDING"
          - "返回 taskId"
          - "调用方提供 clientRequestId 时按 tenantId、operatorId、taskCode、clientRequestId 做幂等"
          - "相同幂等范围和相同参数摘要时返回原 taskId"
          - "记录 requestDigest 和 configSnapshotDigest"
        acceptance_refs: ["AC-001", "AC-013", "AC-014"]
      conflict:
        required: true
        description: "相同幂等范围下参数摘要不同"
        expected_system_behavior:
          - "返回 IDEMPOTENCY_CONFLICT"
          - "不得创建新任务"
        acceptance_refs: ["AC-014", "AC-E018"]
      permission_denied:
        required: true
        description: "无创建权限"
        expected_system_behavior:
          - "返回 403"
          - "记录审计"
        acceptance_refs: ["AC-009", "AC-E006", "AC-E016"]
      not_registered:
        required: true
        description: "taskCode 未注册"
        expected_system_behavior:
          - "创建失败"
          - "不落无效任务"
        acceptance_refs: ["AC-E002"]
      disabled:
        required: true
        description: "taskCode 已禁用"
        expected_system_behavior:
          - "返回 TASK_DISABLED"
        acceptance_refs: ["AC-E003"]
      long_content:
        required: true
        description: "queryParams 超过限制"
        expected_system_behavior:
          - "超过 32KB 时返回参数过长错误"
        acceptance_refs: ["AC-E009"]
      error:
        required: true
        description: "预估或精确总量统计结果超过默认最大导出量且注册配置未放开"
        expected_system_behavior:
          - "拒绝创建或进入更严格控制流"
          - "记录审计"
        acceptance_refs: ["AC-E010", "AC-E021"]
  - capability_id: "api-002"
    title: "查询任务详情/进度"
    route: "GET /api/export/tasks/{taskId}"
    related_requirements: ["FR-002", "FR-010"]
    states:
      default:
        required: true
        description: "任务存在且有权限"
        expected_system_behavior:
          - "返回 status、totalCount、processedCount、progressPercent、errorMessage"
        acceptance_refs: ["AC-002"]
      empty:
        required: true
        description: "任务不存在"
        expected_system_behavior:
          - "返回 404"
        acceptance_refs: ["AC-E002"]
      processing:
        required: true
        description: "任务执行中"
        expected_system_behavior:
          - "返回执行中状态与进度"
        acceptance_refs: ["AC-002"]
      error:
        required: true
        description: "任务失败或查询异常"
        expected_system_behavior:
          - "返回错误信息"
        acceptance_refs: ["AC-E013"]
      permission_denied:
        required: true
        description: "无权查看任务"
        expected_system_behavior:
          - "返回 403"
        acceptance_refs: ["AC-009", "AC-E006"]
      canceled:
        required: true
        description: "任务已取消；内部取消标记不作为正式状态值"
        expected_system_behavior:
          - "返回 CANCELED"
          - "保留可追溯原因"
        acceptance_refs: ["AC-012"]
  - capability_id: "api-003"
    title: "下载导出文件"
    route: "GET /api/export/tasks/{taskId}/download"
    related_requirements: ["FR-003", "FR-009"]
    states:
      default:
        required: true
        description: "完成且未过期"
        expected_system_behavior:
          - "返回签名 URL 或文件流"
          - "签名 URL 模式返回 downloadUrl、expiresAt、fileName、fileSize"
          - "stream 模式返回文件流和等价文件元信息"
          - "文件记录包含 storageKey、checksum、checksumAlgorithm、contentType、attemptNo"
          - "记录下载日志"
        acceptance_refs: ["AC-003", "AC-010"]
      disabled:
        required: true
        description: "任务未完成或不可下载"
        expected_system_behavior:
          - "返回无效状态错误"
        acceptance_refs: ["AC-003"]
      expired:
        required: true
        description: "文件已过期"
        expected_system_behavior:
          - "返回 410"
        acceptance_refs: ["AC-E007"]
      permission_denied:
        required: true
        description: "无下载权限"
        expected_system_behavior:
          - "返回 403"
        acceptance_refs: ["AC-009", "AC-E006", "AC-E016"]
  - capability_id: "api-004"
    title: "查询任务历史"
    route: "GET /api/export/tasks"
    related_requirements: ["FR-004", "FR-009", "FR-010"]
    states:
      default:
        required: true
        description: "可按正式筛选维度返回历史任务"
        expected_system_behavior:
          - "返回分页结果"
          - "支持 taskCode、status、createdBy、createdAtRange、fileFormat、subsystemCode 筛选"
          - "普通用户仅见本人任务"
          - "管理员可见全局任务"
          - "权限判断依赖 operatorId、tenantId、roleCodes、orgScope、requestId"
        acceptance_refs: ["AC-004", "AC-009"]
      empty:
        required: true
        description: "无历史任务"
        expected_system_behavior:
          - "返回空分页"
        acceptance_refs: ["AC-004"]
      permission_denied:
