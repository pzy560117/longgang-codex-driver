 700: function leaseLostError(message: string): Error {
 701:   const error = new Error(message);
 702:   error.name = "WORKER_LEASE_LOST";
 703:   return error;
 704: }
 705: 
 706: function isLeaseLostError(error: unknown): boolean {
 707:   return error instanceof Error && error.name === "WORKER_LEASE_LOST";
 708: }
