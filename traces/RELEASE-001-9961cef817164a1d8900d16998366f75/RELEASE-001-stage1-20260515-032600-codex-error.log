        expected_system_behavior:
          - "返回 403"
        acceptance_refs: ["AC-009", "AC-E006", "AC-E016"]
  - capability_id: "api-005/api-006"
    title: "取消 / 重试"
    route: "POST /api/export/tasks/{taskId}/cancel and retry"
    related_requirements: ["FR-012", "FR-010"]
    states:
      default:
        required: true
        description: "PENDING 可取消，FAILED 可重试"
        expected_system_behavior:
          - "状态机按规则流转"
          - "FAILED 重试保留原 taskId 审计链路并递增执行尝试次数"
          - "PENDING/EXECUTING 重试返回非法状态错误且不得重复派发执行"
          - "失败重试沿用原任务配置快照"
          - "记录审计"
        acceptance_refs: ["AC-012", "AC-010", "AC-016"]
      canceled:
        required: true
        description: "取消成功"
        expected_system_behavior:
          - "status=CANCELED"
        acceptance_refs: ["AC-012"]
      error:
        required: true
        description: "非法状态重试或取消失败"
        expected_system_behavior:
          - "返回状态错误"
        acceptance_refs: ["AC-012", "AC-E015"]
  - id: "query_template_contract"
    capability_id: "api-008/api-009"
    title: "集中查询模板契约"
    route: "registry/config + datasource/query template"
    related_requirements: ["FR-008", "FR-009", "FR-010"]
    states:
      default:
        required: true
        description: "注册配置包含数据源、参数 schema、查询模板、字段映射、脱敏策略、数据范围约束和游标字段"
        expected_system_behavior:
          - "只允许访问注册配置声明的只读数据源或数据中台数据集"
          - "查询模板必须参数化"
          - "只能绑定参数 schema 允许的字段"
          - "不得执行调用方传入的原始 SQL"
          - "执行时叠加 tenantId、operatorId、roleCodes、orgScope 对应的数据范围约束"
        acceptance_refs: ["AC-008", "AC-009", "AC-019"]
      invalid_template:
        required: true
        description: "查询模板不存在或不合法"
        expected_status: "FAILED"
        error_code: "QUERY_TEMPLATE_INVALID"
        acceptance_refs: ["AC-E011"]
      datasource_unavailable:
        required: true
        description: "数据源不可用或凭证不可用"
        expected_status: "FAILED"
        error_code: "DATASOURCE_UNAVAILABLE"
        acceptance_refs: ["AC-E012"]
      query_execution_error:
        required: true
        description: "查询执行失败或批次重试耗尽"
        expected_status: "FAILED"
        error_code: "QUERY_EXECUTION_ERROR"
        acceptance_refs: ["AC-E013", "AC-E020"]
      field_mapping_invalid:
        required: true
        description: "字段映射不合法或批次字段校验失败"
        expected_status: "FAILED"
        error_code: "FIELD_MAPPING_INVALID"
        acceptance_refs: ["AC-E014", "AC-E025"]
      masking_rule_error:
        required: true
        description: "脱敏规则配置或执行失败"
        expected_status: "FAILED"
        error_code: "MASKING_RULE_ERROR"
        acceptance_refs: ["AC-E022", "AC-E025"]
      snapshot_contract_conflict:
        required: true
        description: "查询模板或字段映射与任务快照冲突"
        expected_status: "FAILED"
        error_codes: ["QUERY_TEMPLATE_INVALID", "FIELD_MAPPING_INVALID"]
        expected_system_behavior:
          - "不得静默放宽格式、阈值或字段范围"
          - "保留查询模板版本、字段映射摘要、任务快照摘要和冲突字段证据"
          - "查询模板冲突可按 QUERY_TEMPLATE_INVALID 收口，字段映射冲突按 FIELD_MAPPING_INVALID 收口"
        acceptance_refs: ["AC-E024"]
  - capability_id: "job-001"
