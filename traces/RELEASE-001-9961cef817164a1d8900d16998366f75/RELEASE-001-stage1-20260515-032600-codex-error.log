 554: function dedupeOrderBy(orderBy: OrderByDefinition[]): OrderByDefinition[] {
 555:   const seen = new Set<string>();
 556:   const normalized: OrderByDefinition[] = [];
 557:   for (const item of orderBy) {
 558:     if (seen.has(item.field)) {
 559:       continue;
 560:     }
 561:     seen.add(item.field);
 562:     normalized.push(item);
 563:   }
 564:   return normalized;
 565: }
