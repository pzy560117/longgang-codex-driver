1b[7m\u001b[0m    (Join-Path $Root \"agent\\docs\\codex-harness-engineering\\templates\\hooks\\hooks.json\")\u001b[0m\r\n\u001b[7m\u001b[0m  ) + $AdditionalPaths\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Resolve-HookScriptReference {\u001b[0m\r\n\u001b[7m\u001b[0m  param(\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Root,\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Command\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $expanded = $Command.Replace(\u0027$(git rev-parse --show-toplevel)\u0027, $Root.Replace(\u0027\\\u0027, \u0027/\u0027))\u001b[0m\r\n\u001b[7m\u001b[0m  $scriptPath = $null\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if ($expanded -match \"Join-Path[\\s\\S]*?[\u0027\"\"]([^\u0027\"\"]*hook-stop-verify\\.ps1)[\u0027\"\"]\") {\u001b[0m\r\n\u001b[7m\u001b[0m    $scriptPath = Join-Path $Root $Matches[1]\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m  elseif ($expanded -match \u0027\"([^\"]*hook-stop-verify\\.ps1)\"\u0027) {\u001b[0m\r\n\u001b[7m\u001b[0m    $scriptPath = $Matches[1]\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m  elseif ($expanded -match \u0027(\\S*hook-stop-verify\\.ps1)\u0027) {\u001b[0m\r\n\u001b[7m\u001b[0m    $scriptPath = $Matches[1]\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if ([string]::IsNullOrWhiteSpace($scriptPath)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $null\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $scriptPath = $scriptPath.Replace(\u0027/\u0027, \u0027\\\u0027)\u001b[0m\r\n\u001b[7m\u001b[0m  if ([System.IO.Path]::IsPathRooted($scriptPath)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $scriptPath\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  return (Join-Path $Root $scriptPath)\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Test-HookScriptInstallMapping {\u001b[0m\r\n\u001b[7m\u001b[0m  param(\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Root,\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$ResolvedScriptPath\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if (Test-Path -LiteralPath $ResolvedScriptPath) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $true\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $relativeExpectedPath = \"scripts\\harness\\hook-stop-verify.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m  $normalized = $ResolvedScriptPath.Replace(\"/\", \"\\\")\u001b[0m\r\n\u001b[7m\u001b[0m  if (-not $normalized.EndsWith($relativeExpectedPath, [System.StringComparison]::OrdinalIgno\u001b[0m\r\n\u001b[7m\u001b[0mreCase)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $false\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $templateScript = Join-Path $Root \"docs\\codex-harness-engineering\\templates\\hooks\\hook-stop\u001b[0m\r\n\u001b[7m\u001b[0m-verify.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m  $bootstrapScript = Join-Path $Root \"bootstrap-codex-harness.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m  if (-not ((Test-Path -LiteralPath $templateScript) -and (Test-Path -LiteralPath $bootstrapS\u001b[0m\r\n\u001b[7m\u001b[0mcript))) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $false\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $bootstrapText = Get-Content -LiteralPath $bootstrapScript -Raw\u001b[0m\r\n\u001b[7m\u001b[0m  return $bootstrapText.Contains(\u0027hooks\\hook-stop-verify.ps1\u0027) -and $bootstrapText.Contains(\u0027\u001b[0m\r\n\u001b[7m\u001b[0mscripts\\harness\\hook-stop-verify.ps1\u0027)\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Test-CodexHookCommandCompatibility {\u001b[0m\r\n\u001b[7m\u001b[0m  param(\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Root,\u001b[0m\r\n\u001b[7m\u001b[0m    [string[]]$AdditionalPaths\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $seen = @{}\u001b[0m\r\n\u001b[7m\u001b[0m  foreach ($path in Get-CandidateHookConfigPaths -Root $Root -AdditionalPaths $AdditionalPath\u001b[0m\r\n\u001b[7m\u001b[0ms) {\u001b[0m\r\n\u001b[7m\u001b[0m    if ([string]::IsNullOrWhiteSpace($path) -or $seen.ContainsKey($path)) {\u001b[0m\r\n\u001b[7m\u001b[0m      continue\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m    $seen[$path] = $true\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m    if (-not (Test-Path -LiteralPath $path)) {\u001b[0m\r\n\u001b[7m\u001b[0m      continue\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m    $hookConfig = Get-Content -LiteralPath $path -Raw | ConvertFrom-Json\u001b[0m\r\n\u001b[7m\u001b[0m    foreach ($entry in Get-CodexHookCommand -Node $hookConfig) {\u001b[0m\r\n\u001b[7m\u001b[0m      if ($entry.Command -match \u0027^\\s*\"[^\"]*\\\\PowerShell\\\\[^\"]*\\\\pwsh(?:\\.exe)?\"\\s+\u0027) {\u001b[0m\r\n\u001b[7m\u001b[0m        throw \"高风险 Codex hook command: $path $($entry.Path)。带空格的 quoted PowerShell ex\u001b[0m\r\n\u001b[7m\u001b[0mecutable 在 PowerShell 外层解释时会被当作字符串。请改用 pwsh、C:\\Progra~1\\PowerShell\\7\\pwsh.e\u001b[0m\r\n\u001b[7m\u001b[0mxe，或在确认外层是 PowerShell 时使用 \u0026 调用。\"\u001b[0m\r\n\u001b[7m\u001b[0m      }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m      $scriptReference = Resolve-HookScriptReference -Root $Root -Command $entry.Command\u001b[0m\r\n\u001b[7m\u001b[0m      if ($null -ne $scriptReference -and -not (Test-HookScriptInstallMapping -Root $Root -Re\u001b[0m\r\n\u001b[7m\u001b[0msolvedScriptPath $scriptReference)) {\u001b[0m\r\n\u001b[7m\u001b[0m        throw \"Codex hook command 指向的脚本不可解析或未被 bootstrap 安装: $path $($entry.Pat\u001b[0m\r\n\u001b[7m\u001b[0mh) -\u003e $scriptReference\"\u001b[0m\r\n\u001b[7m\u001b[0m      }\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Test-PowerShellSyntax {\u001b[0m\r\n\u001b[7m\u001b[0m  param([string]$Root)\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $paths = @(\u001b[0m\r\n\u001b[7m\u001b[0m    \"bootstrap-codex-harness.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"codex-loop.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"env-check.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"install-agent.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"install-agent-here.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"verify.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"docs\\codex-harness-engineering\\templates\\bootstrap-codex-harness.ps1\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"docs\\codex-harness-engineering\\templates\\hooks\\hook-stop-verify.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  foreach ($relativePath in $paths) {\u001b[0m\r\n\u001b[7m\u001b[0m    $path = Join-Path $Root $relativePath\u001b[0m\r\n\u001b[7m\u001b[0m    if (-not (Test-Path -LiteralPath $path)) {\u001b[0m\r\n\u001b[7m\u001b[0m      continue\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m    $tokens = $null\u001b[0m\r\n\u001b[7m\u001b[0m    $errors = $null\u001b[0m\r\n\u001b[7m\u001b[0m    [System.Management.Automation.Language.Parser]::ParseFile($path, [ref]$tokens, [ref]$erro\u001b[0m\r\n\u001b[7m\u001b[0mrs) | Out-Null\u001b[0m\r\n\u001b[7m\u001b[0m    if ($errors.Count -gt 0) {\u001b[0m\r\n\u001b[7m\u001b[0m      $messages = ($errors | ForEach-Object { $_.Message }) -join \"; \"\u001b[0m\r\n\u001b[7m\u001b[0m      throw \"PowerShell 语法检查失败: $relativePath - $messages\"\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Get-RelativePathCompat {\u001b[0m\r\n\u001b[7m\u001b[0m  param(\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Root,\u001b[0m\r\n\u001b[7m\u001b[0m    [string]$Path\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $rootFull = ([System.IO.Path]::GetFullPath($Root)).TrimEnd(\u0027\\\u0027, \u0027/\u0027) + \u0027\\\u0027\u001b[0m\r\n\u001b[7m\u001b[0m  $pathFull = [System.IO.Path]::GetFullPath($Path)\u001b[0m\r\n\u001b[7m\u001b[0m  if ($pathFull.StartsWith($rootFull, [System.StringComparison]::OrdinalIgnoreCase)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return $pathFull.Substring($rootFull.Length)\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  return $pathFull\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Test-NoStaleFeedbackMcpReferences {\u001b[0m\r\n\u001b[7m\u001b[0m  param([string]$Root)\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $scanRoots = @(\u001b[0m\r\n\u001b[7m\u001b[0m    \"docs\\harness\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"docs\\codex-harness-engineering\"\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $blockedPatterns = @(\u001b[0m\r\n\u001b[7m\u001b[0m    \"interactive_feedback\",\u001b[0m\r\n\u001b[7m\u001b[0m    \"mcp-feedback-enhanced\"\u001b[0m\r\n\u001b[7m\u001b[0m  )\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  foreach ($scanRoot in $scanRoots) {\u001b[0m\r\n\u001b[7m\u001b[0m    $fullScanRoot = Join-Path $Root $scanRoot\u001b[0m\r\n\u001b[7m\u001b[0m    if (-not (Test-Path -LiteralPath $fullScanRoot)) {\u001b[0m\r\n\u001b[7m\u001b[0m      continue\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m    foreach ($file in Get-ChildItem -LiteralPath $fullScanRoot -Recurse -File -Include *.md,*\u001b[0m\r\n\u001b[7m\u001b[0m.toml,*.json,*.ps1) {\u001b[0m\r\n\u001b[7m\u001b[0m      $relativePath = Get-RelativePathCompat -Root $Root -Path $file.FullName\u001b[0m\r\n\u001b[7m\u001b[0m      if ($relativePath.EndsWith(\"templates\\runtime\\verify.ps1\", [System.StringComparison]::O\u001b[0m\r\n\u001b[7m\u001b[0mrdinalIgnoreCase)) {\u001b[0m\r\n\u001b[7m\u001b[0m        continue\u001b[0m\r\n\u001b[7m\u001b[0m      }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m      $content = Get-Content -LiteralPath $file.FullName -Raw\u001b[0m\r\n\u001b[7m\u001b[0m      $text = if ($null -eq $content) { \"\" } else { [string]$content }\u001b[0m\r\n\u001b[7m\u001b[0m      foreach ($pattern in $blockedPatterns) {\u001b[0m\r\n\u001b[7m\u001b[0m        if ($text.Contains($pattern)) {\u001b[0m\r\n\u001b[7m\u001b[0m          throw \"发现已移除的 feedback MCP 引用: $relativePath contains \u0027$pattern\u0027\"\u001b[0m\r\n\u001b[7m\u001b[0m        }\u001b[0m\r\n\u001b[7m\u001b[0m      }\u001b[0m\r\n\u001b[7m\u001b[0m    }\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mfunction Invoke-AgentPackageFreshnessCheck {\u001b[0m\r\n\u001b[7m\u001b[0m  param([string]$Root)\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $packageRoot = Join-Path $Root \"agent\"\u001b[0m\r\n\u001b[7m\u001b[0m  $packageConfig = Join-Path $packageRoot \".ai-sync.yml\"\u001b[0m\r\n\u001b[7m\u001b[0m  $refreshScript = Join-Path $Root \"refresh-agent-package.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m  $packageSourceMarker = Join-Path $Root \"docs\\codex-harness-engineering\\templates\\package-as\u001b[0m\r\n\u001b[7m\u001b[0msets\\root\\install-agent.ps1\"\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if (-not (Test-Path -LiteralPath $packageConfig -PathType Leaf)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  $hasRefreshScript = Test-Path -LiteralPath $refreshScript -PathType Leaf\u001b[0m\r\n\u001b[7m\u001b[0m  $hasPackageSourceMarker = Test-Path -LiteralPath $packageSourceMarker -PathType Leaf\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if ($hasPackageSourceMarker -and -not $hasRefreshScript) {\u001b[0m\r\n\u001b[7m\u001b[0m    throw \"检测到 agent package source repo 标记，但缺少 refresh-agent-package.ps1，无法校验 \u001b[0m\r\n\u001b[7m\u001b[0mfreshness。\"\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  if (-not ($hasRefreshScript -and $hasPackageSourceMarker)) {\u001b[0m\r\n\u001b[7m\u001b[0m    return\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m  \u0026 powershell -NoProfile -ExecutionPolicy Bypass -File $refreshScript -RepoRoot $Root -Packa\u001b[0m\r\n\u001b[7m\u001b[0mgeRoot $packageRoot -CheckOnly | Out-Host\u001b[0m\r\n\u001b[7m\u001b[0m  if ($LASTEXITCODE -ne 0) {\u001b[0m\r\n\u001b[7m\u001b[0m    throw \"agent package freshness 检查失败。\"\u001b[0m\r\n\u001b[7m\u001b[0m  }\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0m$resolvedProjectRoot = (Resolve-Path -LiteralPath $ProjectRoot).Path\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mforeach ($command in $Commands) {\u001b[0m\r\n\u001b[7m\u001b[0m  Invoke-VerificationCommand -Command $command -Root $resolvedProjectRoot\u001b[0m\r\n\u001b[7m\u001b[0m}\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mTest-CodexHookCommandCompatibility -Root $resolvedProjectRoot -AdditionalPaths $HookConfigPat\u001b[0m\r\n\u001b[7m\u001b[0mhs\u001b[0m\r\n\u001b[7m\u001b[0mTest-PowerShellSyntax -Root $resolvedProjectRoot\u001b[0m\r\n\u001b[7m\u001b[0mTest-NoStaleFeedbackMcpReferences -Root $resolvedProjectRoot\u001b[0m\r\n\u001b[7m\u001b[0mInvoke-AgentPackageFreshnessCheck -Root $resolvedProjectRoot\u001b[0m\r\n\u001b[7m\u001b[0m\r\n\u001b[7m\u001b[0mWrite-Output \"Verification passed.\"\u001b[0m\r\n\r\n\r\n\n succeeded in 762ms:\nparam(\r\n  [string]$ProjectRoot = \"\",\r\n  [string[]]$Commands = @(\"git diff --check\"),\r\n  [string[]]$HookConfigPaths = @()\r\n)\r\n\r\nSet-StrictMode -Version Latest\r\n$ErrorActionPreference = \"Stop\"\r\n\r\nif ([string]::IsNullOrWhiteSpace($ProjectRoot)) {\r\n  $ProjectRoot = $PSScrip