  - capability_id: "api-010"
    title: "文件元信息与校验"
    route: "file service / OSS"
    related_requirements: ["FR-003", "FR-011"]
    states:
      default:
        required: true
        description: "平台生成文件并记录可校验元信息"
        expected_system_behavior:
          - "记录 fileName、fileSize、contentType、storageKey、checksum、checksumAlgorithm、expiresAt、attemptNo"
          - "storageKey 默认按 exports/{subsystemCode}/{taskCode}/{yyyyMMdd}/{taskId}/{attemptNo}/{fileName} 生成"
          - "checksumAlgorithm 默认 SHA-256"
          - "先写入临时对象，校验通过后发布为可下载对象"
          - "记录 checksumVerifiedAt、publishedAt 和 deliveryReadyAt 或等价事件"
        acceptance_refs: ["AC-003", "AC-021"]
      expired:
        required: true
        description: "文件超过保留期或已标记不可下载"
        expected_system_behavior:
          - "拒绝下载"
          - "返回 410 或等价失效结果"
        acceptance_refs: ["AC-011", "AC-E007"]
      error:
        required: true
        description: "OSS 上传失败、文件校验值不匹配或元信息缺失"
        expected_system_behavior:
          - "拒绝交付文件"
          - "记录审计和失败原因"
          - "不生成下载地址"
          - "保留临时对象定位或清理记录"
        acceptance_refs: ["AC-E005", "AC-E017", "AC-E026"]
      render_error:
        required: true
        description: "XLSX/ZIP 文件渲染失败"
        expected_status: "FAILED"
        error_code: "EXPORT_RENDER_ERROR"
        expected_system_behavior:
          - "记录渲染输入摘要和失败原因"
          - "不得生成下载地址"
        acceptance_refs: ["AC-E027"]
