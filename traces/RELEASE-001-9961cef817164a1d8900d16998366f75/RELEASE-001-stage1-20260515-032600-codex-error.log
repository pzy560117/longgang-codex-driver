        expected_system_behavior:
          - "taskCode 唯一"
          - "enabled 状态可切换"
          - "支持并发上限、保留期、单文件行数阈值、最大导出量和支持格式策略"
          - "支持数据源、参数 schema、查询模板、字段映射和脱敏策略配置"
          - "配置变更只影响新创建任务，已创建任务沿用 configSnapshotDigest"
        acceptance_refs: ["AC-007", "AC-008", "AC-010", "AC-016"]
      disabled:
        required: true
        description: "任务注册或启停后处于禁用"
