 327: function resolveHeaders(
 328:   registry: ExportRegistryRecord,
 329:   rows: Record<string, unknown>[]
 330: ): string[] {
 331:   const headers = parseFieldHeaders(registry);
 332:   if (headers.length === 0 && rows.length > 0) {
 333:     return Object.keys(rows[0]);
 334:   }
 335:   for (const row of rows) {
 336:     const rowHeaders = Object.keys(row);
 337:     if (
 338:       rowHeaders.length !== headers.length ||
 339:       rowHeaders.some((header, index) => header !== headers[index])
 340:     ) {
 341:       throw fileError("FIELD_MAPPING_INVALID", "row headers do not match registry field order");
 342:     }
 343:   }
 344:   return headers;
 345: }
 346: 
 347: function parseFieldHeaders(registry: ExportRegistryRecord): string[] {
 348:   if (!registry.fieldMappings) {
 349:     return [];
 350:   }
 351:   let fieldMappings: Array<{
 352:     headerName?: unknown;
 353:     orderNo?: unknown;
 354:     exportable?: boolean;
 355:   }>;
 356:   try {
 357:     fieldMappings = JSON.parse(registry.fieldMappings) as Array<{
 358:       headerName?: unknown;
 359:       orderNo?: unknown;
 360:       exportable?: boolean;
 361:     }>;
 362:   } catch {
 363:     throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings must be valid JSON");
 364:   }
 365:   if (!Array.isArray(fieldMappings)) {
 366:     throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings must be an array");
 367:   }
 368:   return fieldMappings
 369:     .filter((mapping) => mapping.exportable !== false)
 370:     .sort((left, right) => Number(left.orderNo ?? 0) - Number(right.orderNo ?? 0))
 371:     .map((mapping) => {
 372:       if (typeof mapping.headerName !== "string" || mapping.headerName.length === 0) {
 373:         throw fileError("FIELD_MAPPING_INVALID", "registry fieldMappings contain empty headers");
 374:       }
 375:       return mapping.headerName;
 376:     });
 377: }
 378: 
 379: function positiveInteger(value: number | null | undefined, fallback: number): number {
 380:   return Number.isInteger(value) && Number(value) > 0 ? Number(value) : fallback;
 381: }
 382: 
 383: function encodeStorageKey(storageKey: string): string {
 384:   return storageKey.split("/").map(encodeURIComponent).join("/");
 385: }
 386: 
 387: function toArrayBuffer(body: Buffer): ArrayBuffer {
 388:   return body.buffer.slice(
 389:     body.byteOffset,
 390:     body.byteOffset + body.byteLength
 391:   ) as ArrayBuffer;
 392: }
 393: 
 394: function fileError(code: string, message: string): Error {
 395:   const error = new Error(`${code}: ${message}`);
 396:   error.name = code;
 397:   return error;
 398: }

