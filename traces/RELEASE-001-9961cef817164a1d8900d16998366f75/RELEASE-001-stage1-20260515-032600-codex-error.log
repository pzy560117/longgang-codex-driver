 641: async function hasAcceptedCancelRequest(
 642:   db: Kysely<ExportPlatformDatabase>,
 643:   taskId: string,
 644:   attemptNo: number
 645: ): Promise<boolean> {
 646:   const row = await db
 647:     .selectFrom("export_audit_logs")
 648:     .select((eb) => eb.fn.count<number>("audit_id").as("cancel_count"))
 649:     .where("task_id", "=", taskId)
 650:     .where("attempt_no", "=", attemptNo)
 651:     .where("action", "=", "CANCEL_REQUEST")
 652:     .where("result", "=", "ACCEPTED")
 653:     .executeTakeFirst();
 654: 
 655:   return Number(row?.cancel_count ?? 0) > 0;
 656: }
