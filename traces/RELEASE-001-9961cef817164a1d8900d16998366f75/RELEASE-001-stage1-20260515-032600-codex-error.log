 464: function mapRows(input: {
 465:   rows: Record<string, unknown>[];
 466:   mappings: FieldMapping[];
 467:   maskingPolicy: MaskingPolicy;
 468: }): Record<string, unknown>[] {
 469:   return input.rows.map((row) => {
 470:     const output: Record<string, unknown> = {};
 471:     for (const mapping of input.mappings) {
 472:       if (!(mapping.fieldCode in row)) {
 473:         throw queryError("FIELD_MAPPING_INVALID", `field ${mapping.fieldCode} is not selected`);
 474:       }
 475:       const rawValue = row[mapping.fieldCode];
 476:       output[mapping.headerName] = mapping.sensitive
 477:         ? maskValue(rawValue, mapping, input.maskingPolicy)
 478:         : rawValue;
 479:     }
 480:     return output;
 481:   });
 482: }
 483: 
 484: function validateMaskingRules(mappings: FieldMapping[], maskingPolicy: MaskingPolicy): void {
 485:   for (const mapping of mappings) {
 486:     if (!mapping.sensitive) {
 487:       continue;
 488:     }
 489:     const ruleCode = mapping.maskingRuleCode;
 490:     const rule = ruleCode ? maskingPolicy.rules?.[ruleCode] : undefined;
 491:     if (!rule || !["PHONE", "PERSON_NAME"].includes(rule.type)) {
 492:       throw queryError("MASKING_RULE_ERROR", `masking rule ${ruleCode ?? ""} is missing`);
 493:     }
 494:   }
 495: }
 496: 
 497: function maskValue(
 498:   value: unknown,
 499:   mapping: FieldMapping,
 500:   maskingPolicy: MaskingPolicy
 501: ): unknown {
 502:   const ruleCode = mapping.maskingRuleCode;
 503:   const rule = ruleCode ? maskingPolicy.rules?.[ruleCode] : undefined;
 504:   if (!rule) {
 505:     throw queryError("MASKING_RULE_ERROR", `masking rule ${ruleCode ?? ""} is missing`);
 506:   }
 507:   const text = String(value ?? "");
 508:   if (rule.type === "PHONE") {
 509:     const prefix = rule.preservePrefix ?? 3;
 510:     const suffix = rule.preserveSuffix ?? 4;
 511:     if (text.length <= prefix + suffix) {
 512:       return "*".repeat(text.length);
 513:     }
 514:     return `${text.slice(0, prefix)}${"*".repeat(text.length - prefix - suffix)}${text.slice(-suffix)}`;
 515:   }
 516:   if (rule.type === "PERSON_NAME") {
 517:     if (text.length <= 1) {
 518:       return "*";
 519:     }
 520:     if (text.length === 2) {
 521:       return `${text.slice(0, 1)}*`;
 522:     }
 523:     return `${text.slice(0, 1)}${"*".repeat(text.length - 2)}${text.slice(-1)}`;
 524:   }
 525:   throw queryError("MASKING_RULE_ERROR", `masking rule ${ruleCode} is not supported`);
 526: }
