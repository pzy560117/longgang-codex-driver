 147: 
 148:     for (let index = 0; index < maxTasksPerPoll; index += 1) {
 149:       const acquired = await acquireNextLease({
 150:         db: options.db,
 151:         workerId: options.workerId,
 152:         leaseDurationSeconds
 153:       });
 154: 
 155:       if (!acquired) {
 156:         break;
 157:       }
 158: 
 159:       result.dispatched += 1;
 160:       const requestId = await findRequestIdForTask(
 161:         options.db,
 162:         acquired.task.taskId,
 163:         options.workerId
 164:       );
 165:       const now = await getDatabaseTime(options.db);
 166: 
 167:       await appendWorkerAudit({
 168:         db: options.db,
