 322: async function runSampleExport(t, rowCount, overrides = {}) {
 323:   const db = await createTestDatabase(t);
 324:   const now = await getDatabaseTime(db);
 325:   const runId = overrides.runId ?? `${Date.now()}-${Math.random().toString(16).slice(2, 8)}`;
 326:   const createdAt = new Date(now.getTime() + 1000);
 327:   const seed = {
 328:     runId,
 329:     createdAt,
 330:     createdAtFrom: toMysqlDateTimeLiteral(new Date(createdAt.getTime() - 1000)),
 331:     createdAtTo: toMysqlDateTimeLiteral(new Date(createdAt.getTime() + 1000)),
 332:     supplierId: `SUP-${runId}`,
 333:     purchaseOrgId: `PO-${runId}`,
 334:     keyword: `PO-${runId}`
 335:   };
 336:   await registerSampleRegistry({
 337:     ...overrides.registryOverrides,
 338:     requestId: overrides.registryRequestId ?? `req-sample-registry-${rowCount}`
 339:   });
 340:   await seedRows(db, rowCount, seed);
 341:   const createdTask = await createSampleTask({
 342:     requestId: overrides.taskRequestId ?? `req-sample-create-${rowCount}`,
 343:     clientRequestId: `${overrides.clientRequestId ?? `sample-client-${rowCount}`}-${runId}`,
 344:     createdAtFrom: seed.createdAtFrom,
 345:     createdAtTo: seed.createdAtTo,
 346:     supplierId: seed.supplierId,
 347:     purchaseOrgId: seed.purchaseOrgId,
 348:     keyword: seed.keyword
 349:   });
 350:   const storage = createProductionEquivalentObjectStorageAdapter();
 351:   const { task, totals } = await processTaskUntilTerminal(db, createdTask.taskId, storage);
 352:   const fileMetadata = await createExportFileRepository(db).findFileMetadata(task.taskId, task.attemptNo);
 353:   const events = await createExportTaskEventRepository(db).listRecentTaskEvents(task.taskId);
 354:   const audits = await createExportAuditRepository(db).listAuditLogsForTask(task.taskId);
 355:   const checkpoint = await createCheckpointRepository(db).findLatestCheckpoint(
 356:     task.taskId,
 357:     task.attemptNo
 358:   );
 359: 
 360:   return {
 361:     db,
 362:     task,
 363:     createdTask,
 364:     seed,
 365:     storage,
 366:     metrics: totals,
 367:     fileMetadata,
 368:     events,
 369:     audits,
 370:     checkpoint,
 371:     packageData: fileMetadata?.publishedStorageKey
 372:       ? await inspectPublishedFile(storage, fileMetadata.publishedStorageKey)
 373:       : null
 374:   };
 375: }
