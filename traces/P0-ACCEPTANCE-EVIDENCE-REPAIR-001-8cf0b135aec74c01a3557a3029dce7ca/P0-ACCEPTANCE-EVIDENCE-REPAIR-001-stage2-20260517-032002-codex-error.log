 await requireRegistryAdmin({\n      db,\n      auth,\n      action: enabled ? \"REGISTRY_ENABLE\" : \"REGISTRY_DISABLE\",\n      now,\n      taskCode\n    });\n\n    const repository = createExportRegistryRepository(db);\n    const registry = await repository.setRegistryEnabled({ taskCode, enabled, now });\n    if (!registry) {\n      return rejectRegistryWithAudit({\n        db,\n        auth,\n        error: new ApiError(404, \"TASK_NOT_REGISTERED\", \"registry not found\"),\n        action: enabled ? \"REGISTRY_ENABLE\" : \"REGISTRY_DISABLE\",\n        now,\n        taskCode\n      });\n    }\n\n    await appendAudit({\n      db,\n      auth,\n      taskId: null,\n      attemptNo: null,\n      taskCode: registry.taskCode,\n      subsystemCode: registry.subsystemCode,\n      action: enabled ? \"REGISTRY_ENABLE\" : \"REGISTRY_DISABLE\",\n      now\n    });\n\n    return registryEnvelope(registry, auth);\n  });\n}\n\r\n\n succeeded in 439ms:\ncodex\nç›®å‰å®žçŽ°æœ¬èº«æ²¡æœ‰æ˜Žæ˜¾ç±»åž‹é€ƒé€¸æˆ–ç¡¬ç¼–ç å¯†é’¥ï¼Œæµ‹è¯•ä¹Ÿç¡®å®žé€šè¿‡ Fastify + MySQL è·¯å¾„è¦†ç›–äº†ä¼ªé€ ç­¾åã€è¿‡æœŸ/æœªæ¥ issuedAtã€è·¨ç§Ÿæˆ·è¯¦æƒ…/åˆ—è¡¨/ä¸‹è½½/é…ç½®æ‹’ç»ã€‚æœ€åŽæˆ‘ä¼šå¤è·‘ä»»åŠ¡ç»™å‡ºçš„éªŒè¯å‘½ä»¤ï¼Œç¡®è®¤ review ä½¿ç”¨ fresh evidenceã€‚\nexec\n\"C:\\\\Program Files\\\\PowerShell\\\\7\\\\pwsh.exe\" -Command \u0027npm run arch:check; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; powershell -NoProfile -ExecutionPolicy Bypass -Command \u0027\"\u0027. .\\\\scripts\\\\docker-test-env.ps1; if (\"\u0027$LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm run test:api; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }\u0027\"\u0027; if (\"\u0027$LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm run test:contract; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; git diff --check -- task.json src/audit-log src/task-api src/routes contracts/openapi.yaml tests/api tests/contract docs/testing/verify-matrix.md\u0027 in E:\\2026\\alpha-project\\longgang-codex-driver\n succeeded in 6339ms:\n