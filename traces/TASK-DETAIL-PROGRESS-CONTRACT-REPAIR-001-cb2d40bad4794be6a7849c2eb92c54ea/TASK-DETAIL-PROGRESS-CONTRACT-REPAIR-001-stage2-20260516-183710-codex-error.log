  54:   expiresAt: string;
  55:   fileName: string;
  56:   contentType: string;
  57:   fileSize: number;
  58:   checksum: string;
  59:   checksumAlgorithm: string;
  60:   attemptNo: number;
  61: };
  62: 
  63: function digest(value: unknown): string {
  64:   return `sha256:${createHash("sha256").update(JSON.stringify(value)).digest("hex")}`;
  65: }
  66: 
  67: function taskEnvelope(task: ExportTaskRecord, extra: Record<string, unknown> = {}) {
  68:   return {
  69:     taskId: task.taskId,
  70:     taskCode: task.taskCode,
  71:     subsystemCode: task.subsystemCode,
  72:     tenantId: task.tenantId,
  73:     createdBy: task.createdBy,
  74:     fileFormat: task.fileFormat,
  75:     status: task.status,
  76:     clientRequestId: task.clientRequestId,
  77:     idempotencyScope: task.idempotencyScope,
  78:     requestDigest: task.requestDigest,
  79:     configSnapshotDigest: task.configSnapshotDigest,
  80:     attemptNo: task.attemptNo,
  81:     lockOwner: task.lockOwner,
  82:     lockExpireAt: task.lockExpireAt?.toISOString() ?? null,
  83:     leaseRenewedAt: task.leaseRenewedAt?.toISOString() ?? null,
  84:     createdAt: task.createdAt.toISOString(),
  85:     updatedAt: task.updatedAt.toISOString(),
  86:     totalCount: null,
  87:     processedCount: 0,
  88:     progressPercent: 0,
  89:     errorCode: null,
  90:     errorMessage: null,
  91:     failureStage: null,
  92:     lastSuccessStage: null,
  93:     ...extra
  94:   };
  95: }
  96: 
  97: function parseJsonRecord(value: string | null | undefined): Record<string, unknown> | null {
  98:   if (!value) {
  99:     return null;
 100:   }
 101: 
 102:   try {
 103:     const parsed = JSON.parse(value) as unknown;
 104:     return parsed && typeof parsed === "object" && !Array.isArray(parsed)
 105:       ? (parsed as Record<string, unknown>)
 106:       : null;
 107:   } catch {
 108:     return null;
 109:   }
 110: }
 111: 
 112: function readNonNegativeInteger(value: unknown): number | null {
 113:   if (typeof value !== "number" || !Number.isFinite(value)) {
 114:     return null;
 115:   }
 116: 
 117:   if (value < 0) {
 118:     return null;
 119:   }
 120: 
 121:   return Math.trunc(value);
 122: }
 123: 
 124: function readNonEmptyString(value: unknown): string | null {
 125:   if (typeof value !== "string" || value.trim() === "") {
 126:     return null;
 127:   }
 128: 
 129:   return value;
 130: }
 131: 
 132: function clampProgressPercent(value: number): number {
 133:   if (!Number.isFinite(value)) {
 134:     return 0;
 135:   }
 136: 
 137:   return Math.min(100, Math.max(0, Number(value.toFixed(2))));
 138: }
 139: 
 140: function responseCodeMessage(code: string | null): string | null {
 141:   switch (code) {
 142:     case "QUERY_EXECUTION_ERROR":
 143:       return "query execution error";
 144:     case "DATASOURCE_UNAVAILABLE":
 145:       return "datasource unavailable";
 146:     case "QUERY_TEMPLATE_INVALID":
 147:       return "query template invalid";
 148:     case "FIELD_MAPPING_INVALID":
 149:       return "field mapping invalid";
 150:     case "MASKING_RULE_ERROR":
 151:       return "masking rule error";
 152:     case "EXPORT_RENDER_ERROR":
 153:       return "export render error";
 154:     case "FILE_VERIFY_ERROR":
 155:       return "file verification failed";
 156:     case "EXPORT_LIMIT_EXCEEDED":
 157:       return "export limit exceeded";
 158:     default:
 159:       return null;
 160:   }
 161: }
 162: 
 163: function resolveTotalCount(input: {
 164:   task: ExportTaskRecord;
 165:   checkpoint: CheckpointRecord | undefined;
 166:   events: TaskEventRecord[];
 167: }): number {
 168:   const eventTotal = input.events.reduce<number | null>((current, event) => {
 169:     const checkpoint = parseJsonRecord(event.batchCheckpoint);
 170:     const totalCount = readNonNegativeInteger(checkpoint?.totalCount);
 171:     if (totalCount !== null) {
 172:       return current === null ? totalCount : Math.max(current, totalCount);
 173:     }
 174:     return current;
 175:   }, null);
 176: 
 177:   if (eventTotal !== null) {
 178:     return eventTotal;
 179:   }
 180: 
 181:   if (input.task.status === "COMPLETED") {
 182:     return input.checkpoint?.processedCount ?? 0;
 183:   }
 184: 
 185:   return 0;
 186: }
 187: 
 188: function resolveProcessedCount(input: {
 189:   task: ExportTaskRecord;
 190:   checkpoint: CheckpointRecord | undefined;
 191:   totalCount: number;
 192: }): number {
 193:   const checkpointCount = input.checkpoint?.processedCount ?? 0;
 194:   if (input.totalCount > 0) {
 195:     return Math.min(checkpointCount, input.totalCount);
 196:   }
 197: 
 198:   if (input.task.status === "COMPLETED" && checkpointCount === 0) {
 199:     return input.totalCount;
 200:   }
 201: 
 202:   return checkpointCount;
 203: }
 204: 
 205: function resolveProgressPercent(input: {
 206:   task: ExportTaskRecord;
 207:   processedCount: number;
 208:   totalCount: number;
 209: }): number {
 210:   if (input.totalCount > 0) {
 211:     return clampProgressPercent((input.processedCount / input.totalCount) * 100);
 212:   }
 213: 
 214:   if (input.task.status === "COMPLETED") {
 215:     return 100;
 216:   }
 217: 
 218:   return 0;
 219: }
 220: 
 221: function resolveTaskFailure(
 222:   audits: AuditLogRecord[],
 223:   events: TaskEventRecord[]
 224: ): {
 225:   errorCode: string | null;
 226:   errorMessage: string | null;
 227: } {
 228:   const auditFailures = audits
 229:     .filter((audit) => audit.result === "FAILED" && audit.errorCode !== "SUCCESS")
 230:     .map((audit) => ({
 231:       occurredAt: audit.occurredAt,
 232:       errorCode: audit.errorCode,
 233:       errorMessage: responseCodeMessage(audit.errorCode)
 234:     }));
 235: 
 236:   const eventFailures = events.flatMap((event) => {
 237:     const checkpoint = parseJsonRecord(event.batchCheckpoint);
 238:     const errorCode = readNonEmptyString(checkpoint?.errorCode);
 239:     if (!errorCode || errorCode === "SUCCESS") {
 240:       return [];
 241:     }
 242: 
 243:     return [
 244:       {
 245:         occurredAt: event.occurredAt,
 246:         errorCode,
 247:         errorMessage: readNonEmptyString(checkpoint?.errorMessage) ?? responseCodeMessage(errorCode)
 248:       }
 249:     ];
 250:   });
 251: 
 252:   const failedRecord = [...auditFailures, ...eventFailures].sort(
 253:     (left, right) => right.occurredAt.getTime() - left.occurredAt.getTime()
 254:   )[0];
 255: 
 256:   if (!failedRecord) {
 257:     return {
 258:       errorCode: null,
 259:       errorMessage: null
 260:     };
 261:   }
 262: 
 263:   return {
 264:     errorCode: failedRecord.errorCode,
 265:     errorMessage: failedRecord.errorMessage
 266:   };
 267: }
