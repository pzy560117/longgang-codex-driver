 1962: test("create task idempotent replay returns existing task after registry guard changes", async (t) => {
 1963:   const db = await createTestDatabase(t);
 1964:   const objectStorageServer = await createLocalObjectStorageServer(t);
 1965:   const app = await createServer(t, objectStorageServer);
 1966:   const runId = `${Date.now()}-${process.pid}-registry-guard-replay`;
 1967:   const taskCode = `purchase-order-registry-guard-replay-${runId}`;
 1968:   const clientRequestId = "client-registry-guard-replay";
