 1867:     method: "POST",
 1868:     url: "/api/export/registries",
 1869:     headers: createHeaders(`req-registry-guard-registry-${runId}`),
 1870:     payload: createRegistryPayload(taskCode)
 1871:   });
 1872: 
 1873:   assert.equal(createRegistryResponse.statusCode, 201);
 1874: 
 1875:   const rejectionCases = [
 1876:     {
 1877:       label: "unsupported-format",
 1878:       clientRequestId: "client-registry-guard-format",
 1879:       requestId: `req-registry-guard-format-${runId}`,
 1880:       payload: {
 1881:         ...createTaskPayload(taskCode, "client-registry-guard-format"),
 1882:         fileFormat: "ZIP"
 1883:       }
 1884:     },
 1885:     {
 1886:       label: "missing-required-query-param",
 1887:       clientRequestId: "client-registry-guard-missing-required",
 1888:       requestId: `req-registry-guard-missing-required-${runId}`,
 1889:       payload: {
 1890:         ...createTaskPayload(taskCode, "client-registry-guard-missing-required"),
 1891:         queryParams: {
 1892:           createdAtFrom: "2026-05-01T00:00:00+08:00"
 1893:         }
 1894:       }
 1895:     },
 1896:     {
 1897:       label: "undeclared-query-param",
 1898:       clientRequestId: "client-registry-guard-undeclared",
 1899:       requestId: `req-registry-guard-undeclared-${runId}`,
 1900:       payload: {
 1901:         ...createTaskPayload(taskCode, "client-registry-guard-undeclared"),
 1902:         queryParams: {
 1903:           createdAtFrom: "2026-05-01T00:00:00+08:00",
 1904:           createdAtTo: "2026-05-13T23:59:59+08:00",
