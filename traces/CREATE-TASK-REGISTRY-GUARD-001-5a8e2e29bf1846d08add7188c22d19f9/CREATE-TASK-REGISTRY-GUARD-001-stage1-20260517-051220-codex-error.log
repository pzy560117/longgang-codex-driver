  288:   schema: ParameterSchema,
  289:   queryParams: Record<string, unknown>
  290: ): void {
  291:   for (const required of schema.required ?? []) {
  292:     if (queryParams[required] === undefined || queryParams[required] === null) {
  293:       throw queryError("QUERY_TEMPLATE_INVALID", `required parameter ${required} is missing`);
  294:     }
  295:   }
  296: 
  297:   const allowedKeys = new Set(Object.keys(schema.properties ?? {}));
  298:   for (const key of Object.keys(queryParams)) {
  299:     if (allowedKeys.size > 0 && !allowedKeys.has(key)) {
  300:       throw queryError("QUERY_TEMPLATE_INVALID", `parameter ${key} is not declared`);
  301:     }
