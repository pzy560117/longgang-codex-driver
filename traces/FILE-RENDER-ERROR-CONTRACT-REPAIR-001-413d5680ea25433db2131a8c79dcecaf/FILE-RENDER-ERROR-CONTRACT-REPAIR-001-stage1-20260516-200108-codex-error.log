 316: function splitRows(
 317:   rows: Record<string, unknown>[],
 318:   headers: string[],
 319:   singleFileMaxRows: number
 320: ): FilePart[] {
 321:   if (rows.length === 0) {
 322:     return [{ partNo: 1, fileName: "part-0001.xlsx", headers, rows: [] }];
 323:   }
 324: 
 325:   const parts: FilePart[] = [];
 326:   for (let index = 0; index < rows.length; index += singleFileMaxRows) {
 327:     const partNo = parts.length + 1;
 328:     parts.push({
 329:       partNo,
 330:       fileName: `part-${String(partNo).padStart(4, "0")}.xlsx`,
 331:       headers,
 332:       rows: rows.slice(index, index + singleFileMaxRows)
 333:     });
 334:   }
 335:   return parts;
 336: }
