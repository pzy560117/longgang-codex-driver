 338: function buildFileName(input: PublishRowsInput): string {
 339:   const extension = input.rows.length > positiveInteger(input.registry.singleFileMaxRows, 20000)
 340:     ? "zip"
 341:     : input.task.fileFormat.toLowerCase();
 342:   return `${input.task.taskCode}-${input.task.taskId}-attempt-${input.attemptNo}.${extension}`;
 343: }
