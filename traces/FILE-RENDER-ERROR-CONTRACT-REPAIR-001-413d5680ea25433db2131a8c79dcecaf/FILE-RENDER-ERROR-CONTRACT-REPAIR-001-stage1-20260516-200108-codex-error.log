 384: function resolveHeaders(
 385:   registry: ExportRegistryRecord,
 386:   rows: Record<string, unknown>[]
 387: ): string[] {
 388:   const headers = parseFieldHeaders(registry);
 389:   if (headers.length === 0 && rows.length > 0) {
 390:     return Object.keys(rows[0]);
 391:   }
 392:   for (const row of rows) {
 393:     const rowHeaders = Object.keys(row);
 394:     if (
 395:       rowHeaders.length !== headers.length ||
 396:       rowHeaders.some((header, index) => header !== headers[index])
 397:     ) {
 398:       throw fileError("FIELD_MAPPING_INVALID", "row headers do not match registry field order");
 399:     }
 400:   }
 401:   return headers;
 402: }
