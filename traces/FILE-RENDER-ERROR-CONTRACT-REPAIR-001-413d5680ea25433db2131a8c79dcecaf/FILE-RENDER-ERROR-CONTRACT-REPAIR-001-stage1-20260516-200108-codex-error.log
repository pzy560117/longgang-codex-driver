 345: function buildStoragePrefix(task: ExportTaskRecord, attemptNo: number, now: Date): string {
 346:   const datePart = `${now.getUTCFullYear()}${String(now.getUTCMonth() + 1).padStart(2, "0")}${String(now.getUTCDate()).padStart(2, "0")}`;
 347:   return `exports/${task.subsystemCode}/${task.taskCode}/${datePart}/${task.taskId}/${attemptNo}`;
 348: }
