  19:   scanned: number;
  20:   deleted: number;
  21:   retried: number;
  22: };
  23: 
  24: export type CleanupObjectStorage = {
  25:   deleteObject(storageKey: string): Promise<void>;
  26: };
  27: 
  28: export function createCleanupJob(options: CleanupJobOptions) {
  29:   const files = createExportFileRepository(options.db);
  30:   const audits = createExportAuditRepository(options.db);
  31:   const events = createExportTaskEventRepository(options.db);
  32:   const storage = options.storage ?? createCleanupObjectStorageFromEnv();
  33:   const maxFilesPerPoll = options.maxFilesPerPoll ?? 10;
  34: 
  35:   async function pollOnce(): Promise<CleanupPollResult> {
  36:     const now = await getDatabaseTime(options.db);
  37:     const candidates = await files.listExpiredPublishedFiles({
  38:       now,
  39:       limit: maxFilesPerPoll
  40:     });
  41:     const result: CleanupPollResult = {
  42:       scanned: candidates.length,
  43:       deleted: 0,
  44:       retried: 0
  45:     };
  46: 
  47:     for (const candidate of candidates) {
  48:       const invalidatedAt = await getDatabaseTime(options.db);
  49:       await files.invalidateDownloadMetadata({
  50:         taskId: candidate.taskId,
  51:         attemptNo: candidate.attemptNo,
  52:         now: invalidatedAt
  53:       });
  54: 
  55:       try {
  56:         await storage.deleteObject(candidate.publishedStorageKey);
  57:         if (candidate.tempStorageKey) {
  58:           await storage.deleteObject(candidate.tempStorageKey);
  59:         }
  60:         const deletedAt = await getDatabaseTime(options.db);
  61:         await files.markObjectDeleted({
  62:           taskId: candidate.taskId,
  63:           attemptNo: candidate.attemptNo,
  64:           now: deletedAt
  65:         });
  66:         await appendCleanupEvent({
  67:           events,
  68:           candidate,
  69:           eventType: "FILE_CLEANUP_DONE",
  70:           requestId: cleanupRequestId(options.workerId),
  71:           now: deletedAt,
  72:           checkpoint: {
  73:             storageKey: candidate.publishedStorageKey,
  74:             tempStorageKey: candidate.tempStorageKey,
  75:             cleanupResult: "deleted"
  76:           }
  77:         });
  78:         await audits.appendAuditLog({
  79:           auditId: `audit_${randomUUID()}`,
  80:           taskId: candidate.taskId,
  81:           attemptNo: candidate.attemptNo,
  82:           taskCode: candidate.taskCode,
  83:           subsystemCode: candidate.subsystemCode,
  84:           operatorId: candidate.operatorId,
  85:           action: "EXPIRE_MARK",
  86:           result: "SUCCESS",
  87:           errorCode: "SUCCESS",
  88:           requestId: cleanupRequestId(options.workerId),
  89:           occurredAt: deletedAt,
  90:           now: deletedAt
  91:         });
  92:         result.deleted += 1;
  93:       } catch (error) {
  94:         const failedAt = await getDatabaseTime(options.db);
  95:         await appendCleanupEvent({
  96:           events,
  97:           candidate,
  98:           eventType: "FILE_CLEANUP_RETRY",
  99:           requestId: cleanupRequestId(options.workerId),
 100:           now: failedAt,
 101:           checkpoint: {
 102:             storageKey: candidate.publishedStorageKey,
 103:             tempStorageKey: candidate.tempStorageKey,
 104:             cleanupResult: "retry",
 105:             error: error instanceof Error ? error.message : String(error)
 106:           }
 107:         });
 108:         await audits.appendAuditLog({
 109:           auditId: `audit_${randomUUID()}`,
 110:           taskId: candidate.taskId,
 111:           attemptNo: candidate.attemptNo,
 112:           taskCode: candidate.taskCode,
 113:           subsystemCode: candidate.subsystemCode,
 114:           operatorId: candidate.operatorId,
 115:           action: "CLEANUP_FAILED",
 116:           result: "FAILED",
 117:           errorCode: "FILE_CLEANUP_DELETE_ERROR",
 118:           requestId: cleanupRequestId(options.workerId),
 119:           occurredAt: failedAt,
 120:           now: failedAt
 121:         });
 122:         result.retried += 1;
 123:       }
 124:     }
 125: 
 126:     return result;
 127:   }
 128: 
 129:   return { pollOnce };
 130: }
