  assert.deepEqual(checkpoint.renderInputSummary, {
    taskId: task.taskId,
    taskCode: task.taskCode,
    attemptNo: 0,
    fileName: `${task.taskCode}-${task.taskId}-attempt-0.xlsx`,
    format: "XLSX",
    totalRowCount: 1,
    partCount: 1,
    singleFileMaxRows: 20000
  });
});

