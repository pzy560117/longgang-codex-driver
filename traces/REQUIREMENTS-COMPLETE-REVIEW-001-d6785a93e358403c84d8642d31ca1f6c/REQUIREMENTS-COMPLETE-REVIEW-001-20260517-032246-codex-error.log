        description: "执行阶段失败"
        expected_system_behavior:
          - "记录失败阶段、错误码、上一成功阶段和当前批次检查点"
          - "失败证据可与任务日志、审计日志和文件证据串联"
        acceptance_refs: ["AC-010", "AC-019", "AC-020"]
  - capability_id: "sample-001"
