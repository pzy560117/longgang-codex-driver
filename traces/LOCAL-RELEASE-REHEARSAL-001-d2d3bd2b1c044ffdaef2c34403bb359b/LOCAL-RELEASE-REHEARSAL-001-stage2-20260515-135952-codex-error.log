    now
  });

  const task = await createExportTaskRepository(db).createPendingTask({
    taskId: `exp-file-${runId}`,
    taskCode,
    subsystemCode,
    tenantId: "tenant-001",
    createdBy: "u001",
    fileFormat: overrides.fileFormat ?? "XLSX",
    clientRequestId: null,
    idempotencyScope: null,
    requestDigest: `sha256:${runId}`,
